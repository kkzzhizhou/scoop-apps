{
    "version": "10.55",
    "description": "Video game library manager and launcher with support for 3rd party libraries like Steam, GOG, Epic, Origin, Ubisoft Connect, and more!",
    "homepage": "https://playnite.link",
    "license": "MIT",
    "url": "https://github.com/JosefNemec/Playnite/releases/download/10.55/10.55.7z",
    "hash": "0797ce086c890428c7c04c73c7e0699962f79d12b9318b10c495bb6f14a868fb",
    "pre_install": "Copy-Item \"$persist_dir\\config.json\" \"$dir\" -ErrorAction SilentlyContinue",
    "uninstaller": {
        "script": "Copy-Item \"$dir\\config.json\" \"$persist_dir\" -ErrorAction SilentlyContinue -Force"
    },
    "bin": [
        [
            "Playnite.DesktopApp.exe",
            "Playnite"
        ]
    ],
    "shortcuts": [
        [
            "Playnite.DesktopApp.exe",
            "Playnite"
        ]
    ],
    "persist": [
        "browsercache",
        "cache",
        "Extensions",
        "ExtensionsData",
        "Themes",
        "library"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/JosefNemec/Playnite/releases/latest",
        "jsonpath": {
            "version": "$.tag_name",
            "download": "$.assets[?(@.name =~ /\\.7z/i)].browser_download_url",
            "hash": "$.assets[?(@.name =~ /\\.7z/i)].digest"
        }
    },
    "autoupdate": {
        "url": "$matchDownload",
        "hash": "$matchHash"
    }
}
