{
    "version": "4.8.1",
    "description": "An AI-powered IDE",
    "homepage": "https://www.codebuddy.cn/ide/",
    "license": "Proprietary",
    "architecture": {
        "64bit": {
            "url": "https://download.codebuddy.cn/aiide/win32-x64-user/CodeBuddy-win32-x64-user-4.8.1.24687134-bdd6e91e-cn.exe",
            "hash": "28278153b7508aae628b26d0868e2e061e9b0ddac6542fac795a17f8b6dd1968",
            "extract_dir": "{code_GetDestDir}"
        }
    },
    "innosetup": true,
    "post_install": [
        "if (!(Test-Path \"$dir\\data\\extensions\") -and (Test-Path \"$env:USERPROFILE\\.codebuddycn\\extensions\")) {",
        "    info '[Portable Mode] Copying extensions...'",
        "    Copy-Item \"$env:USERPROFILE\\.codebuddycn\\extensions\" \"$dir\\data\" -Recurse",
        "}",
        "if (!(Test-Path \"$dir\\data\\user-data\") -and (Test-Path \"$env:AppData\\CodeBuddy CN\")) {",
        "    info '[Portable Mode] Copying user data...'",
        "    Copy-Item \"$env:AppData\\CodeBuddy CN\" \"$dir\\data\\user-data\" -Recurse",
        "}",
        "$extensions_file = \"$dir\\data\\extensions\\extensions.json\"",
        "if ((Test-Path \"$extensions_file\")) {",
        "    info 'Adjusting path in extensions file...'",
        "    (Get-Content \"$extensions_file\") -replace '(?<=codebuddycn(/|\\\\\\\\)).*?(?=(/|\\\\\\\\)data(/|\\\\\\\\)extensions)', $version | Set-Content \"$extensions_file\"",
        "}"
    ],
    "bin": [
        [
            "bin/buddycn.cmd",
            "codebuddycn"
        ]
    ],
    "shortcuts": [
        [
            "CodeBuddy CN.exe",
            "CodeBuddy CN",
            "--user-data-dir=\"$dir\\data\\user-data\" --extensions-dir=\"$dir\\data\\extensions\""
        ]
    ],
    "persist": "data"
}
