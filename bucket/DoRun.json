{
    "version": "0.2.4.38",
    "description": "Fast Windows launcher with indexed apps, custom commands, hotkeys, startup tasks, cron-style scheduling, and usage-based ranking.",
    "homepage": "https://github.com/dodorz/dorun",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/dodorz/dorun/releases/download/v0.2.4.38/DoRun-v0.2.4.38-windows-x64.zip",
            "hash": "4bb4a4c13c714f3a86858bc9738141436b54505423fa204f4eddd3864ff550be"
        }
    },
    "bin": "DoRun.exe",
    "installer": {
        "script": [
            "'DoRun.yaml', 'Command.conf' | ForEach-Object {",
            "    if (!(Test-Path \"$persist_dir\\$_\")) { New-Item -ItemType File \"$dir\\$_\" -Force | Out-Null }",
            "}"
        ]
    },
    "shortcuts": [
        [
            "DoRun.exe",
            "DoRun"
        ]
    ],
    "persist": [
        "DoRun.yaml",
        "Command.conf"
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/dodorz/dorun/releases/download/v$version/DoRun-v$version-windows-x64.zip"
            }
        }
    }
}
