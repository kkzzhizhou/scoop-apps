{
    "version": "1.4.1",
    "description": "A Desktop App for Easily Viewing and Editing Markdown Files",
    "homepage": "https://github.com/tk04/Marker",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/tk04/Marker/releases/download/master/Marker_1.4.1_x64-setup.nsis.zip",
            "hash": "6ac2ac344eab98218a353a152f4d1e3b95ffd32f5091fd0d30178305b2e195e6"
        }
    },
    "bin": "Marker.exe",
    "installer": {
        "script": [
            "$exefile = (Get-ChildItem \"$dir\" '*.exe' | Select-Object -First 1).FullName",
            "Expand-7ZipArchive \"$exefile\" \"$dir\" -Removal",
            "Remove-Item \"$dir\\`$PLUGINSDIR\",\"$dir\\uninstall.exe\" -Force -Recurse"
        ]
    },
    "shortcuts": [
        [
            "Marker.exe",
            "Marker"
        ]
    ],
    "checkver": {
        "url": "https://github.com/tk04/Marker/releases/tag/master",
        "regex": "Release Marker v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/tk04/Marker/releases/download/master/Marker_$version_x64-setup.nsis.zip"
            }
        }
    }
}
