{
    "version": "1.10",
    "description": "sqlmap是一个自动化的SQL注入工具，其主要功能是扫描，发现并利用给定的URL进行SQL注入",
    "notes": [
        "【工具类型】: 安全测试工具",
        "【主要功能】: 自动化SQL注入工具，扫描、发现并利用URL进行SQL注入",
        "【适用场景】: SQL注入测试、数据库审计、渗透测试",
        "【技术特点】: Python开发，命令行工具，需要Python环境，功能强大"
    ],
    "homepage": "https://sqlmap.org/",
    "license": "GNU",
    "suggest": {
        "python": "uv"
    },
    "url": "https://github.com/sqlmapproject/sqlmap/archive/refs/tags/1.10.zip",
    "hash": "97b8fe8e06ed8b6c75c234f111393bae79e2c3d3283c086351354716277dfff1",
    "extract_dir": "sqlmap-1.10",
    "pre_install": [
        "Set-Content \"$dir\\sqlmap.bat\" '@pushd %~dp0",
        "@uv run python \"sqlmap.py\" %*",
        "@popd' -Encoding Ascii"
    ],
    "bin": "sqlmap.bat",
    "checkver": {
        "github": "https://github.com/sqlmapproject/sqlmap",
        "regex": "/releases/tag/([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://github.com/sqlmapproject/sqlmap/archive/refs/tags/$version.zip",
        "extract_dir": "sqlmap-$version"
    }
}
