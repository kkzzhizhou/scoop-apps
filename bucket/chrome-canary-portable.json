            "hash": "58923cff7c396315b9a6c98f54388d75d22048eb3b9cd84965b518c2f24ba6ef"
        }
    },
    "installer": {
        "script": "Expand-7zipArchive \"$dir\\chrome.7z\" -ExtractDir 'Chrome-bin' -Removal"
