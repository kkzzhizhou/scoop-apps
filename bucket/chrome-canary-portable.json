            "hash": "30f66922983eccb6c9f82579c838ff20adce9a9d32d4f1f9befde9f9a945ecc9"
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/acd5ug4ly4mv6xniza5oeespbymq_152.0.7948.0/152.0.7948.0_chrome_installer.exe#/dl.7z",
