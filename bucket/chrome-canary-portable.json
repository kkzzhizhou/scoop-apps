            "hash": "cf8340e09c7137db12c3c99fde5c68a51381a4989d0addf721345c736f74bf8a"
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/ad6frnckluyhmrdeyxyr2snnk6rq_151.0.7885.0/151.0.7885.0_chrome_installer.exe#/dl.7z",
