    "suggest": {
        "JDK": [
            "java/oraclejdk",
            "java/openjdk"
        ]
    },
    "url": "https://github.com/DeEpinGh0st/MDUT-Extend-Release/releases/download/v1.2.0/MDUT-Extend-1.2.0.zip",
    "hash": "4b7bc48f796c3f83e725989270d1e86ec3e20c29c1a1c3a3474eb7f08877395e",
    "pre_install": [
        "",
        "$batContent = @\"",
        "@echo off",
        "setlocal EnableDelayedExpansion",
        "",
        "set \"jdk_path=\"",
        "",
        "for %%J in (ORACLE_JDK_8_HOME JDK_8_HOME) do (",
        "if defined %%J (",
        "set \"jdk_path=!%%J!\\bin\\\"",
        ")",
        ")",
        "",
        "if not defined jdk_path if defined JAVA_HOME (",
        "set \"jdk_path=%JAVA_HOME%\\bin\\\"",
        ")",
        "",
        "@pushd %~dp0",
        "@\"%jdk_path%java.exe\" -jar \"Multiple.Database.Utilization.Tools-2.1.1-Extend-$version-CE-jar-with-dependencies.jar\" %*",
        "@popd",
        "",
        "endlocal",
        "\"@",
        "",
        "$path = \"$dir/mdut-extend-release.bat\"",
        "Set-Content -Path $path -Value $batContent -Encoding Ascii",
        ""
    ],
    "bin": "mdut-extend-release.bat",
    "shortcuts": [
        [
            "mdut-extend-release.bat",
            "Mdut-extend-release"
        ]
    ],
    "persist": "data.db",
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/DeEpinGh0st/MDUT-Extend-Release/releases/download/v$version/MDUT-Extend-$version.zip"
    }
