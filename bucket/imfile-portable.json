    "description": "A full-featured download manager.",
    "homepage": "https://imfile.io/",
    "license": {
        "identifier": "MIT license",
        "url": "https://github.com/imfile-io/imfile-desktop#MIT-1-ov-file"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/imfile-io/imfile-desktop/releases/download/v2.0.6/imFile-2.0.6-x64.zip",
            "hash": "a6f7adb4af3ae3dd9aa2c9b815aaaf944b1249f3ac3fb0de3ea3d62e2c905d73"
        },
        "arm64": {
            "url": "https://github.com/imfile-io/imfile-desktop/releases/download/v2.0.6/imFile-2.0.6-arm64.zip",
            "hash": "9ebc4015253d6465267aef3dc6ceb9967bf3c352d9824d246cc0afad782e3c54"
        }
    },
    "installer": {
        "script": [
            "# handle runtime cache",
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\" -Target \"$env:APPDATA\\imFile\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "uninstaller": {
        "script": [
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\imFile\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "shortcuts": [
        [
            "imFile.exe",
            "imFile"
        ]
    ],
    "checkver": {
        "github": "https://api.github.com/repos/imfile-io/imfile-desktop/releases",
        "jp": "$[0].tag_name",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/imfile-io/imfile-desktop/releases/download/v$version/imFile-$version-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/imfile-io/imfile-desktop/releases/download/v$version/imFile-$version-arm64.zip"
            }
        }
    }
}
