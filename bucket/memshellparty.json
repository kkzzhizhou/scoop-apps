{
    "version": "2.8.0",
    "description": "一款专注于 Java 主流 Web 中间件的内存马快速生成工具，致力于简化安全研究人员和红队成员的工作流程，提升攻防效率",
    "homepage": "https://party.memshell.news",
    "license": "MIT",
    "notes": "https://github.com/ViCrack/scoop-bucket/blob/master/bucket/memshellparty.json https://github.com/vicrack/scoop-bucket",
    "suggest": {
        "JDK": ["java/oraclejdk", "java/openjdk"]
    },
    "url": "https://github.com/ReaJason/MemShellParty/releases/download/v2.8.0/boot-2.8.0.jar",
    "hash": "44a165bce640fbb68b8b37199ba672e79b1dd1d822fffee3811e1e29a0ee42b7",
    "pre_install": [
        "",
        "$batContent = @\"",
        "@echo off",
        "setlocal EnableDelayedExpansion",
        "",
        "set \"jdk_path=\"",
        "set \"addOpens=\"",
        "",
        "set \"common_addOpens=--add-opens java.base/java.lang=ALL-UNNAMED --add-opens java.base/java.lang.invoke=ALL-UNNAMED --add-opens java.base/java.util=ALL-UNNAMED --add-opens java.desktop/sun.awt=ALL-UNNAMED --add-opens java.base/sun.nio.ch=ALL-UNNAMED --add-opens=java.base/java.util=ALL-UNNAMED --add-opens=java.xml/com.sun.org.apache.xalan.internal.xsltc.trax=ALL-UNNAMED --add-opens=java.xml/com.sun.org.apache.xalan.internal.xsltc.runtime=ALL-UNNAMED\"",
        "",
        "for %%J in (JDK_19_HOME JDK_17_HOME JDK_11_HOME) do (",
        "if defined %%J (",
        "set \"jdk_path=!%%J!\\bin\\\"",
        "set \"addOpens=%common_addOpens%\"",
        ")",
        ")",
        "",
        "if not defined jdk_path if defined JAVA_HOME (",
        "set \"jdk_path=%JAVA_HOME%\\bin\\\"",
        ")",
        "",
        "if not exist \"%jdk_path%java.exe\" (",
        "echo ERROR: Java executable not found in %jdk_path%.",
        "exit /b 1",
        ")",
        "",
        "set \"javafx_args=\"",
        "if defined JAVAFX_HOME (",
        "if exist \"%JAVAFX_HOME%\\lib\" (",
        "set \"javafx_args=--module-path %JAVAFX_HOME%\\lib --add-modules javafx.controls,javafx.fxml\"",
        ") else (",
        "echo WARNING: JAVAFX_HOME is defined but the lib directory is missing.",
        ")",
        ")",
        "",
        "@pushd %~dp0",
        "@\"%jdk_path%java.exe\" %javafx_args% %addOpens% -jar \"boot-$version.jar\" %*",
        "@popd",
        "",
        "endlocal",
        "\"@",
        "",
        "$path = \"$dir/memshellparty.bat\"",
        "Set-Content -Path $path -Value $batContent -Encoding Ascii",
        ""
    ],
    "bin": "memshellparty.bat",
    "shortcuts": [["memshellparty.bat", "Memshellparty"]],
    "checkver": {
        "github": "https://github.com/ReaJason/MemShellParty"
    },
    "autoupdate": {
        "url": "https://github.com/ReaJason/MemShellParty/releases/download/v$version/boot-$version.jar"
    }
}
