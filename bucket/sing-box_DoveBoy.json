        "You can run with a directory of configs using: 'sing-box run -C $persist_dir\\config.d'"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/SagerNet/sing-box/releases/download/v1.13.5/sing-box-1.13.5-windows-amd64.zip",
            "extract_dir": "sing-box-1.13.5-windows-amd64",
            "hash": "841a46ab1fef823fefd4248229db5220f09535c883b4cfc6d4fbe5903bc3f1d1"
        },
        "32bit": {
            "url": "https://github.com/SagerNet/sing-box/releases/download/v1.13.5/sing-box-1.13.5-windows-386.zip",
            "extract_dir": "sing-box-1.13.5-windows-386",
            "hash": "c1644083fc9439b442a063534cd0fc7a1243cce6e9aff2f83b4585342ade01b9"
        },
        "arm64": {
            "url": "https://github.com/SagerNet/sing-box/releases/download/v1.13.5/sing-box-1.13.5-windows-arm64.zip",
