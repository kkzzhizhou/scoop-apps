            "hash": "683973dd1861e6f3b3e5cec840e7242c0eac7363396da17a85df4eeca3767e54"
        },
        "arm64": {
            "url": "https://github.com/SagerNet/sing-box/releases/download/v1.13.2/sing-box-1.13.2-windows-arm64.zip",
