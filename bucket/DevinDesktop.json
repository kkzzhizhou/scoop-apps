{
    "version": "3.4.27",
    "description": "Manage fleets of local and cloud agents from one surface.",
    "homepage": "https://devin.ai/desktop",
    "license": {
        "identifier": "Proprietary",
        "url": "https://cognition.com/legal/platform-terms-of-service"
    },
    "innosetup": true,
    "architecture": {
        "64bit": {
            "url": "https://windsurf-stable.codeiumdata.com/win32-x64-user/stable/0d4bf12ed4a7597cb8ae9016fe8474468aad98a2/DevinUserSetup-x64-3.4.27.exe",
            "hash": "36126cd613e3f76d600afbce5af3bfbcf1c146d38d570cc58f8640f5e1154afa"
        },
        "arm64": {
            "url": "https://windsurf-stable.codeiumdata.com/win32-arm64-user/stable/0d4bf12ed4a7597cb8ae9016fe8474468aad98a2/DevinUserSetup-arm64-3.4.27.exe",
            "hash": "9e7f8ad9d0158c11c3d5ddd60fcb9fbe9325b68851fb6ccc98829dd3ea84a967"
        }
    },
    "extract_dir": "{code_GetDestDir}",
    "pre_install": [
        "Remove-Item \"$dir\\`$*\", \"$dir\\Uninst*\" -Recurse",
        "Rename-Item -Path \"$dir\\{code_GetExeBasename}\" -NewName 'Windsurf.exe'",
        "Rename-Item -Path \"$dir\\{code_GetVisualElementsManifest}\" -NewName 'VisualElementsManifest.xml'",
        "Rename-Item -Path \"$dir\\bin\\{code_GetBinDirApplicationCmdFilename}\" -NewName 'windsurf.cmd'",
        "Rename-Item -Path \"$dir\\bin\\{code_GetBinDirApplicationFilename}\" -NewName 'windsurf'"
    ],
    "post_install": [
        "if (!(Test-Path \"$dir\\data\\extensions\") -and (Test-Path \"$env:USERPROFILE\\.windsurf\\extensions\")) {",
        "    info '[Portable Mode] Copying extensions...'",
        "    Copy-Item \"$env:USERPROFILE\\.windsurf\\extensions\" \"$dir\\data\" -Recurse",
        "}",
        "if (!(Test-Path \"$dir\\data\\user-data\") -and (Test-Path \"$env:AppData\\Windsurf\")) {",
        "    info '[Portable Mode] Copying user data...'",
        "    Copy-Item \"$env:AppData\\Windsurf\" \"$dir\\data\\user-data\" -Recurse",
        "}",
        "$extensions_file = \"$dir\\data\\extensions\\extensions.json\"",
        "if ((Test-Path \"$extensions_file\")) {",
        "    info 'Adjusting path in extensions file...'",
        "    (Get-Content \"$extensions_file\") -replace '(?<=windsurf(/|\\\\\\\\)).*?(?=(/|\\\\\\\\)data(/|\\\\\\\\)extensions)', $version | Set-Content \"$extensions_file\"",
        "}"
    ],
    "bin": "bin\\windsurf.cmd",
    "shortcuts": [
        [
            "Windsurf.exe",
            "Windsurf",
            "--user-data-dir=\"$dir\\data\\user-data\" --extensions-dir=\"$dir\\data\\extensions\""
        ]
    ],
    "persist": "data",
    "checkver": {
        "url": "https://docs.devin.ai/desktop/changelog.md",
        "regex": "win32-x64-user/stable/(?<Code>[\\w]+)/DevinUserSetup-x64-([\\d.]+).exe"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://windsurf-stable.codeiumdata.com/win32-x64-user/stable/$matchCode/DevinUserSetup-x64-$version.exe"
            },
            "arm64": {
                "url": "https://windsurf-stable.codeiumdata.com/win32-arm64-user/stable/$matchCode/DevinUserSetup-arm64-$version.exe"
            }
        }
    }
}
