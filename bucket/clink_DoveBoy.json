    ],
    "url": "https://github.com/chrisant996/clink/releases/download/v1.9.22/clink.1.9.22.9d46b9.zip",
    "hash": "9ad9e03cc1804d902a5e5901954daa184a7ea9db2c9d240b20ba9d95bc9a570f",
    "env_set": {
        "CLINK_DIR": "$dir"
    },
    "bin": "clink.bat",
    "checkver": {
        "github": "https://github.com/chrisant996/clink",
        "jsonpath": "$..browser_download_url",
        "regex": "/v(?<tag>[\\d.]+)/clink\\.([\\d.]+)\\.(?<commit>[\\w.]+)\\.zip"
    },
    "autoupdate": {
