{
    "version": "1781619484",
    "description": "zipdetails - Display details about the internal structure of Zip files.",
    "homepage": "https://github.com/pmqs/zipdetails",
    "license": "Artistic-1.0-Perl",
    "depends": "main/perl",
    "url": "https://raw.githubusercontent.com/pmqs/zipdetails/refs/heads/main/bin/zipdetails",
    "hash": "2ee418a89b0f39c28bd966be892e01adcb092ec21ea0a60e691dfeb5b583e5d0",
    "pre_install": [
        "Rename-Item \"$dir/zipdetails\" zipdetails.pl",
        "@\"",
        "@perl.exe \"$dir/zipdetails.pl\" %*",
        "\"@ > \"$dir/zipdetails.cmd\""
    ],
    "bin": "zipdetails.cmd",
    "checkver": {
        "script": "try { Get-Date (Invoke-RestMethod 'https://api.github.com/repositories/351812480/commits?path=/bin/zipdetails&per_page=1' -Headers $(if ($auth = Get-GitHubToken) { @{authorization=\"Bearer $auth\"} }))[0].commit.committer.date -UFormat %s } catch { '' }",
        "regex": "\\A(\\d+)\\Z"
    },
    "autoupdate": {
        "url": "https://raw.githubusercontent.com/pmqs/zipdetails/refs/heads/main/bin/zipdetails",
        "extract_dir": "Image-ExifTool-$version"
    }
}
