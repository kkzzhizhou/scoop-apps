        "Move-Item ($srcdir + \"\\PhysX\") -Destination \"$dir\" | Out-Null",
        "Move-Item ($srcdir + \"\\NvDLISR\") -Destination \"$dir\" | Out-Null",
        "Move-Item ($srcdir + \"\\HDAudio\") -Destination \"$dir\" | Out-Null",
