{
    "version": "13.59",
    "description": "A command-line application for reading, writing and editing meta information in a wide variety of files.",
    "homepage": "https://exiftool.org",
    "license": "GPL-1.0-or-later|Artistic-1.0-Perl",
    "depends": "main/perl",
    "url": "https://downloads.sourceforge.net/project/exiftool/Image-ExifTool-13.59.tar.gz",
    "extract_dir": "Image-ExifTool-13.59",
    "hash": "sha1:8429367c8289c21499696dcba6fc6b8eb2de5017",
    "pre_install": [
        "Rename-Item \"$dir/exiftool\" exiftool.pl",
        "@\"",
        "@perl.exe \"$dir/exiftool.pl\" %*",
        "\"@ > \"$dir/exiftool.cmd\""
    ],
    "bin": "exiftool.cmd",
    "checkver": {
        "url": "https://exiftool.org/ver.txt",
        "regex": "\\A([\\d.]+)\\Z"
    },
    "autoupdate": {
        "url": "https://downloads.sourceforge.net/project/exiftool/Image-ExifTool-$version.tar.gz",
        "extract_dir": "Image-ExifTool-$version"
    }
}
