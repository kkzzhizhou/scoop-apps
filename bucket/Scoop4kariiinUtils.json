{
    "version": "0.1.3",
    "description": "A PowerShell Script Module for Scoop bucket Scoop4kariiin, which contains several functions to help building app manifests.",
    "homepage": "https://github.com/AkariiinMKII/Scoop4kariiinUtils",
    "license": "Unlicense",
    "notes": [
        "This module provides custom functions used by scoop manifests in Scoop4kariiin bucket.",
        "If you want to use it in your own manifests, please read the documentation:",
        "https://github.com/AkariiinMKII/Scoop4kariiinUtils/blob/main/README.md"
    ],
    "url": "https://github.com/AkariiinMKII/Scoop4kariiinUtils/archive/v0.1.3.zip",
    "hash": "6b9011ab4df7fec59e7e60080e043b896d335ea202e8aeacf341f47ac9eacd7e",
    "extract_dir": "Scoop4kariiinUtils-0.1.3",
    "psmodule": {
        "name": "Scoop4kariiinUtils"
    },
    "installer": {
        "script": "Remove-Item \"$dir\\LICENSE\", \"$dir\\README.md\", \"$dir\\.gitignore\" -Force -Recurse -ErrorAction SilentlyContinue"
    },
    "pre_uninstall": [
        "Write-Host ''",
        "Write-Host '[WARN] Manifests in Scoop4kariiin bucket need functions in this app, try re-installing if error occurs.' -ForegroundColor Yellow"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/AkariiinMKII/Scoop4kariiinUtils/tags",
        "regex": "tags/v([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://github.com/AkariiinMKII/Scoop4kariiinUtils/archive/v$version.zip",
        "extract_dir": "Scoop4kariiinUtils-$version"
    }
}
