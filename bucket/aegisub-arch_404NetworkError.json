{
    "version": "migration04-01",
    "description": "A cross-platform advanced subtitle editor",
    "homepage": "https://github.com/arch1t3cht/Aegisub",
    "license": "BSD-3-Clause",
    "architecture": {
        "64bit": {
            "url": "https://github.com/arch1t3cht/Aegisub/releases/download/migration04-01/Windows.MSVC.Release.-.portable.zip",
            "hash": "a7e5fc4268abf2e805d7b07dcc76285638e7f130fa8a4d4c38046211bb742934"
        }
    },
    "pre_install": [
        "Expand-7zipArchive -Path \"$dir\\aegisub-portable-64.zip\" -ExtractDir 'aegisub-portable' -Removal",
        "'config.json', 'hotkey.json' | ForEach {",
        "   if (Test-Path \"$persist_dir\\$_\") {",
        "       Copy-Item \"$persist_dir\\$_\" \"$dir\\\"",
        "   }",
        "}"
    ],
    "pre_uninstall": [
        "# Manually persist files",
        "'config.json', 'hotkey.json' | ForEach {",
        "   if (Test-Path \"$dir\\$_\") {",
        "       ensure \"$persist_dir\" | Out-Null",
        "       Copy-Item \"$dir\\$_\" \"$persist_dir\\\"",
        "   }",
        "}"
    ],
    "shortcuts": [
        [
            "aegisub.exe",
            "Aegisub"
        ]
    ],
    "persist": [
        "config",
        "config.json",
        "hotkey.json"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/arch1t3cht/Aegisub/releases/latest",
        "jsonpath": "$.tag_name",
        "regex": "([\\w\\-_]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/arch1t3cht/Aegisub/releases/download/$version/Windows.MSVC.Release.-.portable.zip"
            }
        }
    }
}
