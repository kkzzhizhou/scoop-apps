{
    "version": "5.21",
    "description": " Jar Analyzer - 一个JAR包分析工具，批量分析搜索，方法调用关系搜索，字符串搜索，Spring分析，CFG分析，JVM Stack Frame分析，远程分析Tomcat，进阶表达式搜索，自定义SQL查询，字节码查看，命令行分析，使用简易RASP保护",
    "homepage": "https://github.com/jar-analyzer/jar-analyzer",
    "license": "Freeware",
    "url": "https://github.com/jar-analyzer/jar-analyzer/releases/download/5.21/jar-analyzer-5.21-windows-full.zip",
    "hash": "4a3f6062a02184cdb273e08e445c3ffc05a7dcfdded5a3cc925af7a2a59bd660",
    "extract_dir": "jar-analyzer-5.21-windows-full",
    "pre_install": [
        "Rename-Item \"$dir\\start.bat\" 'jar-analyzer.bat'",
        "$filePath = \"$dir\\jar-analyzer.bat\"",
        "$existingContent = Get-Content $filePath -Raw",
        "$newContent = \"@pushd %~dp0`r`n\" + $existingContent +\"`r`n@popd\"",
        "$newContent | Set-Content $filePath"
    ],
    "bin": "jar-analyzer.bat",
    "shortcuts": [
        [
            "jar-analyzer.bat",
            "Jar Analyzer"
        ]
    ],
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/jar-analyzer/jar-analyzer/releases/download/$version/jar-analyzer-$version-windows-full.zip",
        "extract_dir": "jar-analyzer-$version-windows-full"
    }
}
