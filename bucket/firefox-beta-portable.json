{
    "version": "154.0b1",
    "description": "Beta builds of Firefox: the popular open source web browser.",
    "homepage": "https://www.mozilla.org/en-US/firefox/beta/",
    "license": "MPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/154.0b1/win64/en-US/Firefox%20Setup%20154.0b1.exe#/dl.7z",
            "hash": "sha512:c091c7386967a45f4dad38301307fbc3f64ac5c7e6ec8061714cc538c9aec4501f311bd9c2b1a58fa203c8bd19c40b69aba60dd26d3678d756daf16e5d5bb7ea"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/154.0b1/win32/en-US/Firefox%20Setup%20154.0b1.exe#/dl.7z",
            "hash": "sha512:a52857ff15a3b0b9b82e787af10fa4e18c55442dcf9bc1f6c06f237f39c9a16cb65a5f0e5484cbb3b18b50696cddd7b920f4709ef15a95cf8331150cea9d37ab"
        }
    },
    "extract_dir": "core",
    "bin": [
        [
            "firefox.exe",
            "firefox-beta",
            "-profile \"$dir\\profile\""
        ]
    ],
    "shortcuts": [
        [
            "firefox.exe",
            "Firefox Beta",
            "-profile \"$dir\\profile\""
        ]
    ],
    "persist": "profile",
    "checkver": {
        "url": "https://product-details.mozilla.org/1.0/firefox_versions.json",
        "jsonpath": "$.LATEST_FIREFOX_DEVEL_VERSION"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win64/en-US/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64/en-US/$basename"
                }
            },
            "32bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win32/en-US/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win32/en-US/$basename"
                }
            }
        }
    }
}
