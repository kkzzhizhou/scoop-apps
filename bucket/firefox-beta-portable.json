            "hash": "sha512:6e464638850668b97730f2f0e456e396fbb3f87620601bb16bcd9bb7b1187474645807063821f7d6af561d1e12acc6466448f41d0b5ee67bdcc2f87b674fc2c5"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/153.0b6/win32/en-US/Firefox%20Setup%20153.0b6.exe#/dl.7z",
            "hash": "sha512:849e48d90cfbc6b70538878e4e586ee4b582f8dc4a1b89691459362bfe48096a72f1f94d29f2647537bdf6050355b8c1b07f6ffcdfd3f3699d35048a6294c70f"
