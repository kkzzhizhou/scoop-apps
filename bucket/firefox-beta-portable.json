            "hash": "sha512:ba916cbf1c30699e3539a4bd50da00850fba6ca770c0b6600cb12a45fb1387a42db2cc19f9283c71ee4e28c9a6f862893992020e797a54dd79d6a5296e216ebf"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/151.0b6/win32/en-US/Firefox%20Setup%20151.0b6.exe#/dl.7z",
            "hash": "sha512:3dcae98b89a8ea7b09ea27beed692274fb47833a45e5a496d8dfb7cc12a503ab4f0322ce0ca51ca070478470f0f253dcf414d811a6d1af0f580560bc9c7ed67e"
        }
    },
    "extract_dir": "core",
    "bin": [
        [
            "firefox.exe",
            "firefox-beta",
            "-profile \"$dir\\profile\""
        ]
    ],
    "shortcuts": [
        [
            "firefox.exe",
            "Firefox Beta",
            "-profile \"$dir\\profile\""
        ]
    ],
    "persist": "profile",
    "checkver": {
        "url": "https://product-details.mozilla.org/1.0/firefox_versions.json",
        "jsonpath": "$.LATEST_FIREFOX_DEVEL_VERSION"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win64/en-US/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64/en-US/$basename"
                }
            },
            "32bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win32/en-US/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win32/en-US/$basename"
                }
            }
        }
    }
}
