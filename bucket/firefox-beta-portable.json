{
    "version": "150.0b10",
    "description": "Beta builds of Firefox: the popular open source web browser.",
    "homepage": "https://www.mozilla.org/en-US/firefox/beta/",
    "license": "MPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/150.0b10/win64/en-US/Firefox%20Setup%20150.0b10.exe#/dl.7z",
            "hash": "sha512:5c3da32b894639bfc6468b57bbf6830014bf0147c8dc5305de691c3f6d8fe1cc5330f70a100dc4638bf2ff0d4e2546e24e34a76883d130ffc8f74062a89d838f"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/150.0b10/win32/en-US/Firefox%20Setup%20150.0b10.exe#/dl.7z",
            "hash": "sha512:a27ea657191cfda67707675a4db86822dfc9b92054cb8cd3a5658c3888081b32552ff42e90fd0ae6f09a885a52ff922fdf567deb6261b610710cd6b3ab5e1dfc"
        }
    },
    "extract_dir": "core",
    "bin": [
        [
            "firefox.exe",
            "firefox-beta",
            "-profile \"$dir\\profile\""
        ]
    ],
    "shortcuts": [
        [
            "firefox.exe",
            "Firefox Beta",
            "-profile \"$dir\\profile\""
        ]
    ],
    "persist": "profile",
    "checkver": {
        "url": "https://product-details.mozilla.org/1.0/firefox_versions.json",
        "jsonpath": "$.LATEST_FIREFOX_DEVEL_VERSION"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win64/en-US/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64/en-US/$basename"
                }
            },
            "32bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win32/en-US/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win32/en-US/$basename"
                }
            }
        }
    }
}
