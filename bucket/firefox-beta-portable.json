            "hash": "sha512:e3adf9a7243c55d0f00ff7968700f2b8481c5fda1e7f7f7745066f286062161f0886bd8afbe9fee3c773f455ae4a4959467e45d1099b43e59e2e832c4c88eb06"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/149.0b6/win32/en-US/Firefox%20Setup%20149.0b6.exe#/dl.7z",
            "hash": "sha512:008dd2042b362beea80a2850a78f3c0f40382378114ffbd0bee4e8868e4ffc779610d1843f8dd47212a0afa216887badc426604a47614b04ed265571e7bc7acf"
