    "homepage": "https://www.mozilla.org/en-US/firefox/beta/",
    "license": "MPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/153.0b7/win64/en-US/Firefox%20Setup%20153.0b7.exe#/dl.7z",
            "hash": "sha512:2d7f1d514c0a237ebcd8e388eec31ae2129166acbdaec2049977b46c9c1c7799fe3d2a8cab09c3cc23a6e06a56c414ffe91c94c5e90150e922f2e3cc97f1504a"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/153.0b7/win32/en-US/Firefox%20Setup%20153.0b7.exe#/dl.7z",
            "hash": "sha512:a9c82b0e512a49af9b0a7aec9bc88881b86ceea09fc2efe5bcad88c75293af5fcc5aa042d05e0e9c96b8ff8c417e9020d6fa2ccbc84512f2842ec940f5006c71"
        }
    },
    "extract_dir": "core",
    "bin": [
        [
            "firefox.exe",
            "firefox-beta",
            "-profile \"$dir\\profile\""
        ]
    ],
    "shortcuts": [
        [
            "firefox.exe",
            "Firefox Beta",
            "-profile \"$dir\\profile\""
        ]
    ],
    "persist": "profile",
    "checkver": {
        "url": "https://product-details.mozilla.org/1.0/firefox_versions.json",
        "jsonpath": "$.LATEST_FIREFOX_DEVEL_VERSION"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win64/en-US/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64/en-US/$basename"
                }
            },
            "32bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win32/en-US/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win32/en-US/$basename"
                }
            }
        }
    }
}
