{
    "version": "2.1.0",
    "description": "使用Flutter开发的BiliBili第三方客户端",
    "homepage": "https://github.com/bggRGjQaUbCoE/PiliPlus",
    "license": {
        "identifier": "GPL-3.0 license",
        "url": "https://github.com/bggRGjQaUbCoE/PiliPlus#GPL-3.0-1-ov-file"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/bggRGjQaUbCoE/PiliPlus/releases/download/2.1.0/PiliPlus_windows_2.1.0+5109_x64_setup.exe",
            "hash": "73b00d3ab3343f904fb3a64f4ca941e4ec4c9c40ea696e74927b4ac0bb80eb60"
        }
    },
    "innosetup": true,
    "installer": {
        "script": [
            "# handle runtime cache",
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\appdata\" -Target \"$env:APPDATA\\com.example\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "uninstaller": {
        "script": [
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\com.example\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "bin": "piliplus.exe",
    "shortcuts": [
        [
            "piliplus.exe",
            "PiliPlus"
        ]
    ],
    "checkver": {
        "github": "https://api.github.com/repos/bggRGjQaUbCoE/PiliPlus/releases",
        "jp": "$[0].assets[*].browser_download_url",
        "regex": "/releases/download/([\\d.]+)/PiliPlus_windows_([\\d.]+)%2B([\\d]+)_x64",
        "replace": "${1}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/bggRGjQaUbCoE/PiliPlus/releases/download/$match1/PiliPlus_windows_$match2+$match3_x64_setup.exe"
            }
        }
    }
}
