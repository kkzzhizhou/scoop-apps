        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/140.10.0esr/win32/zh-CN/Firefox%20Setup%20140.10.0esr.exe#/dl.7z",
            "hash": "sha512:b11f290ef9fc3b45d98573caf72f5183bcd73fd0e44d4b116014652b7394902c3331dd43032ae265668b6d63c7be5990a9e5777897d7f10b498a9dcff68a9c2b"
