{
    "version": "1.0.138",
    "description": "The AI IDE for prototype to productionr",
    "homepage": "https://kiro.dev/",
    "license": {
        "identifier": "Proprietary",
        "url": "https://kiro.dev/license/"
    },
    "architecture": {
        "64bit": {
            "url": "https://prod.download.desktop.kiro.dev/releases/stable/win32-x64/signed/1.0.138/kiro-ide-1.0.138-stable-win32-x64.zip",
            "hash": "d69c9e6a720394aed178a8f26295c3ca09a51f8b656a2e383cba35f90692b998"
        }
    },
    "post_install": [
        "if (!(Test-Path \"$dir\\data\\extensions\") -and (Test-Path \"$env:USERPROFILE\\.kiro\\extensions\")) {",
        "    info '[Portable Mode] Copying extensions...'",
        "    Move-Item \"$env:USERPROFILE\\.kiro\\extensions\" \"$dir\\data\" -Recurse",
        "}",
        "if (!(Test-Path \"$dir\\data\\user-data\") -and (Test-Path \"$env:AppData\\Kiro\")) {",
        "    info '[Portable Mode] Copying user data...'",
        "    Move-Item \"$env:AppData\\Kiro\" \"$dir\\data\\user-data\" -Recurse",
        "}",
        "$extensions_file = \"$dir\\data\\extensions\\extensions.json\"",
        "if ((Test-Path \"$extensions_file\")) {",
        "    info 'Adjusting path in extensions file...'",
        "    (Get-Content \"$extensions_file\") -replace '(?<=kiro(/|\\\\\\\\)).*?(?=(/|\\\\\\\\)data(/|\\\\\\\\)extensions)', $version | Set-Content \"$extensions_file\"",
        "}"
    ],
    "bin": [
        [
            "bin\\kiro.cmd",
            "kiro",
            "--user-data-dir=\"$dir\\data\\user-data\" --extensions-dir=\"$dir\\data\\extensions\""
        ]
    ],
    "shortcuts": [
        [
            "Kiro.exe",
            "Kiro",
            "--user-data-dir=\"$dir\\data\\user-data\" --extensions-dir=\"$dir\\data\\extensions\""
        ]
    ],
    "persist": "data",
    "checkver": {
        "url": "https://prod.download.desktop.kiro.dev/stable/metadata-win32-x64-user-stable.json",
        "jsonpath": "$.currentRelease"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://prod.download.desktop.kiro.dev/releases/stable/win32-x64/signed/$version/kiro-ide-$version-stable-win32-x64.zip"
            }
        }
    }
}
