{
    "version": "1.12.5.1654",
    "description": "Modern, dynamic a functional dialect of the LISP programming language for JVM",
    "homepage": "https://clojure.org",
    "license": "EPL-1.0",
    "notes": "Please fully exit and restart any active terminal sessions.",
    "suggest": {
