{
    "version": "1.3",
    "description": "具有交互式界面的自动 SSTI 检测工具",
    "notes": [
        "【工具类型】: Python工具",
        "【主要功能】: 具有交互式界面的自动 SSTI 检测工具",
        "【适用场景】: SSTI漏洞检测与利用、Web渗透测试、CTF竞赛",
        "【技术特点】: 基于Python开发，需Python环境"
    ],
    "homepage": "https://github.com/vladko312/SSTImap",
    "license": "GPL-3.0",
    "suggest": {
        "python": "uv"
    },
    "url": "https://github.com/vladko312/SSTImap/archive/refs/tags/v1.3.zip",
    "hash": "1cc1f1d19068bc8f76c9a31b56584f185054dd133f6fa3e1c1206521f6b8414d",
    "extract_dir": "SSTImap-1.3",
    "pre_install": [
        "Set-Content \"$dir\\sstimap.bat\" '@pushd %~dp0",
        "@uv run python \"sstimap.py\" %*",
        "@popd' -Encoding Ascii"
    ],
    "post_install": [
        "uv venv \"$dir\\.venv\"",
        "uv pip install -r $dir\\requirements.txt --python \"$dir\\.venv\\Scripts\\python.exe\""
    ],
    "bin": "sstimap.bat",
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/vladko312/SSTImap/archive/refs/tags/v$version.zip",
        "extract_dir": "SSTImap-$version"
    }
}
