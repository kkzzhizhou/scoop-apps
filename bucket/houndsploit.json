{
    "version": "master",
    "description": "An advanced graphical search engine for Exploit-DB.",
    "homepage": "https://github.com/nicolas-carolo/houndsploit",
    "license": "BSD-3-Clause",
    "suggest": {
        "python": "uv"
    },
    "url": "https://github.com/nicolas-carolo/houndsploit/archive/refs/heads/master.zip",
    "extract_dir": "houndsploit-master",
    "post_install": [
        "powershell.exe -ExecutionPolicy Bypass -File \"$dir\\install_db_windows.ps1\"",
        "uv venv \"$dir\\.venv\"",
        "uv pip install -r $dir\\requirements.txt --python \"$dir\\.venv\\Scripts\\python.exe\"",
        "cd \"$dir\"",
        "@uv run python \".\\setup.py\" install"
    ],
    "notes": [
        "【工具类型】: Python工具",
        "【主要功能】: An advanced graphical search engine for Exploit-DB.",
        "【适用场景】: Exploit-DB图形化搜索、漏洞利用查找",
        "【技术特点】: 基于Python开发，需Python环境"
    ]
}
