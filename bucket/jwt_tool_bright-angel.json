    "hash": "03aa6c5b41e8bcfff2dd983592ddc46b4557894934b234bc682edd2869434f80",
    "extract_dir": "jwt_tool-2.3.0",
    "pre_install": [
        "Set-Content \"$dir\\jwt_tool.bat\" '@pushd %~dp0",
        "@uv run python jwt_tool.py %*",
        "@popd' -Encoding Ascii"
