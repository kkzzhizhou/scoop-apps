    "post_install": [
        "uv venv \"$dir\\.venv\"",
        "uv pip install -r $dir\\requirements.txt --python \"$dir\\.venv\\Scripts\\python.exe\""
    ],
    "bin": "jwt_tool.bat",
    "autoupdate": {
        "url": "https://github.com/ticarpi/jwt_tool/archive/refs/tags/v$version.zip",
        "extract_dir": "jwt_tool-$version"
    },
    "notes": [
        "【工具类型】: Python工具",
        "【主要功能】: 🐍 用于测试、调整和破解 JSON Web 令牌的工具包",
        "【适用场景】: JWT令牌安全测试、身份认证绕过检测",
        "【技术特点】: 基于Python开发，需Python环境"
