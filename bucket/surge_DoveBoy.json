        "arm64": {
            "url": "https://github.com/surge-downloader/Surge/releases/download/v0.7.8/Surge_0.7.8_windows_arm64.zip",
            "hash": "646c14d411a4781b20472c5709323e5c5c4f739705f5757e75fbb672d5d96e67"
        }
    },
    "installer": {
        "script": [
            "# handle runtime cache",
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\appdata\" -Target \"$env:APPDATA\\surge\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "uninstaller": {
        "script": [
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\surge\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "bin": "surge.exe",
    "checkver": {
        "url": "https://api.github.com/repos/surge-downloader/Surge/releases",
        "jp": "$[0].assets[*].browser_download_url",
        "regex": "/releases/download/v([\\d.]+)/Surge_([\\d.]+)_windows"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/surge-downloader/Surge/releases/download/v$version/Surge_$version_windows_amd64.zip"
            },
            "32bit": {
                "url": "https://github.com/surge-downloader/Surge/releases/download/v$version/Surge_$version_windows_386.zip"
            },
            "arm64": {
                "url": "https://github.com/surge-downloader/Surge/releases/download/v$version/Surge_$version_windows_arm64.zip"
            }
        },
        "hash": {
            "url": "$baseurl/Surge_$version_checksums.txt"
        }
    }
}
