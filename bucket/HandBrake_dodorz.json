{
    "version":  "1.11.2",
    "description":  "A tool for converting video from nearly any format to a selection of modern, widely supported codecs.",
    "homepage":  "https://handbrake.fr",
    "license":  "GPL-2.0-only",
    "architecture":  {
                         "64bit":  {
                                       "url":  "https://github.com/HandBrake/HandBrake/releases/download/1.11.2/HandBrake-1.11.2-x86_64-Win_GUI.zip",
                                       "hash":  "6becb8e5a041941d5f2fd6fe83c66fc15b2b16190e2e79f5ad47eb4cd18df8cd"
                                   }
                     },
    "extract_dir":  "HandBrake",
    "installer":  {
                      "script":  [
                                     "if(!(Test-Path \"$persist_dir\\portable.ini\")) { Copy-Item \"$dir\\HandBrake\\portable.ini.template\" \"$dir\\portable.ini\" | Out-Null }"
                                 ]
                  },
    "persist":  "portable.ini",
    "shortcuts":  [
                      [
                          "HandBrake.exe",
                          "HandBrake"
                      ]
                  ],
    "checkver":  {
                     "github":  "https://github.com/HandBrake/HandBrake"
                 },
    "autoupdate":  {
                       "architecture":  {
                                            "64bit":  {
                                                          "url":  "https://github.com/HandBrake/HandBrake/releases/download/$version/HandBrake-$version-x86_64-Win_GUI.zip"
                                                      }
                                        },
                       "hash":  {
                                    "url":  "https://handbrake.fr/rotation.php?file=$basename",
                                    "regex":  "\u003ctd\u003e$sha256\u003c/td\u003e"
                                }
                   }
}
