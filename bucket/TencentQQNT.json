{
    "version": "9.9.28.260319",
    "description": "A new version of Tencent QQ based on Electron.",
    "homepage": "https://im.qq.com/pcqq/index.shtml",
    "license": "Unknown",
    "notes": [
        "The app runtime is persisted by scoop, while user data is saved in path:",
        "\"$env:USERPROFILE\\Documents\\Tencent Files\""
    ],
    "depends": "Scoop4kariiin/Scoop4kariiinUtils",
    "architecture": {
        "64bit": {
            "url": "https://dldir1v6.qq.com/qqfile/qq/QQNT/Windows/QQ_9.9.28_260319_x64_01.exe#/dl.7z",
            "hash": "9856871a4fcc36dc56faedc4e5209f20fe21b23077c2386705dc4a0d509b7b31"
        },
        "32bit": {
            "url": "https://dldir1v6.qq.com/qqfile/qq/QQNT/Windows/QQ_9.9.28_260319_x86_01.exe#/dl.7z",
            "hash": "ab9c16639091b15cea92fc0b911544b84994d62789d7c9983a158e7db3e5d7a1"
        },
        "arm64": {
            "url": "https://dldir1v6.qq.com/qqfile/qq/QQNT/Windows/QQ_9.9.28_260319_arm64_01.exe#/dl.7z",
            "hash": "f1a0ab88af56a2f789a8b64a61c207cce199a28b3cf978c7818b1a0d413390b1"
        }
    },
    "extract_dir": "Files",
    "installer": {
        "script": [
            "Import-Module -Name Scoop4kariiinUtils -ErrorAction Stop",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\QQ\" -AppData",
            "Remove-Module -Name Scoop4kariiinUtils -ErrorAction SilentlyContinue"
        ]
    },
    "shortcuts": [
        [
            "QQ.exe",
            "QQ"
        ]
    ],
    "uninstaller": {
        "script": [
            "Import-Module -Name Scoop4kariiinUtils -ErrorAction Stop",
            "Dismount-ExternalRuntimeData -Target \"QQ\" -AppData",
            "Remove-Module -Name Scoop4kariiinUtils -ErrorAction SilentlyContinue"
        ]
    },
    "checkver": {
        "script": [
            "$check_regex = [regex]\"QQNT\\/Windows\\/QQ_([\\d.]+)_([\\d]+)_x64_01\\.exe\"",
            "$check_url = \"https://cdn-go.cn/qq-web/im.qq.com_new/latest/rainbow/windowsConfig.js\"",
            "$check_page = Invoke-WebRequest -Uri $check_url -UseBasicParsing | Select-Object -ExpandProperty Content",
            "$check_page -match $check_regex",
            "$fetch_version_head = $matches[1]",
            "$fetch_version_tail = $matches[2]",
            "$fetch_version = ($fetch_version_head, $fetch_version_tail) -Join \".\"",
            "$current_version_tail = $json.version -Split \"\\.\" | Select-Object -Last 1",
            "if ([int]$fetch_version_tail -ge [int]$current_version_tail) {",
            "    return $fetch_version",
            "} else {",
            "    Write-Warning \"[TencentQQNT] Fetched latest version: $fetch_version, aborting update...\"",
            "    return $json.version",
            "}"
        ],
        "regex": "([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://dldir1v6.qq.com/qqfile/qq/QQNT/Windows/QQ_$matchHead_$buildVersion_x64_01.exe#/dl.7z"
            },
            "32bit": {
                "url": "https://dldir1v6.qq.com/qqfile/qq/QQNT/Windows/QQ_$matchHead_$buildVersion_x86_01.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://dldir1v6.qq.com/qqfile/qq/QQNT/Windows/QQ_$matchHead_$buildVersion_arm64_01.exe#/dl.7z"
            }
        }
    }
}
