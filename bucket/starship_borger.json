{
    "version": "2.0.0",
    "description": "A PC port of Starfox 64",
    "homepage": "https://github.com/HarbourMasters/Starship",
    "license": "Unlicense",
    "notes": [
        "ATTENTION: Starship requires specific n64 rom(s) of Starfox 64 to function.",
        "Place the rom(s) in $persist_dir.",
        "Learn more at https://github.com/HarbourMasters/Starship?tab=readme-ov-file#quick-start"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/HarbourMasters/Starship/releases/download/v2.0.0/Starship-Barnard-Alfa-Windows.zip",
            "hash": "42444eeccda0406cb40826ebce0b6f7a46338a9dc25c8e9d9a536807d504ae6a"
        }
    },
    "pre_install": [
        "$files = @('starship.cfg.json', 'default.sav', 'imgui.ini')",
        "foreach ($file in $files) {",
        "    if (!(Test-Path \"$persist_dir\\$file\")) {",
        "        New-Item -ItemType File -ErrorAction SilentlyContinue \"$dir\\$file\" | Out-Null",
        "    }",
        "}"
    ],
    "post_install": [
        "$files = @('starship.cfg.json', 'default.sav', 'imgui.ini')",
        "foreach ($file in $files) {",
        "    if (Test-Path \"$persist_dir\\$file.bak\") {",
        "        Copy-Item -Force \"$persist_dir\\$file.bak\" \"$dir\\$file\"",
        "    } else {",
        "        New-Item -ErrorAction SilentlyContinue -ItemType File \"$dir\\$file\" | Out-Null",
        "    }",
        "}"
    ],
    "shortcuts": [
        [
            "starship.exe",
            "StarFox 64 [n64][sf64]"
        ]
    ],
    "persist": [
        "mods",
        "Save",
        "starship.cfg.json",
        "default.sav",
        "imgui.ini"
    ],
    "uninstaller": {
        "script": [
            "$files = @('starship.cfg.json', 'default.sav', 'imgui.ini')",
            "foreach ($file in $files) {",
            "    Copy-Item -Force \"$dir\\$file\" \"$persist_dir\\$file.bak\"",
            "}"
        ]
    },
    "checkver": {
        "github": "https://github.com/HarbourMasters/Starship",
        "regex": "https://github.com/HarbourMasters/Starship/releases/download/v(?<version>([\\d\\.]+))/Starship-(?<majorName>(\\w+))-(?<minorName>(\\w+))-Windows.zip",
        "replace": "${version}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/HarbourMasters/Starship/releases/download/v$version/Starship-$matchMajorname-$matchMinorname-Windows.zip"
            }
        }
    }
}
