{
    "##": "Tolaria",
    "version": "2026.7.14",
    "description": "Desktop app to manage markdown knowledge bases",
    "homepage": "https://github.com/refactoringhq/tolaria",
    "license": "AGPL-3.0",
    "url": "https://github.com/refactoringhq/tolaria/releases/download/v2026-07-14/Tolaria_2026.7.14_x64-setup.exe#/dl.7z",
    "hash": "84ff6acce6505a9bd106c80d88ee9543798c39193b2ba84e8f11f7bef23ec958",
    "pre_install": "Remove-Item \"$dir\\`$PLUGINSDIR\" -Force -Recurse",
    "shortcuts": [
        [
            "tolaria.exe",
            "Tolaria"
        ]
    ],
    "checkver": {
        "script": [
            "$ErrorActionPreference = 'Stop'",
            "$url = 'https://github.com/refactoringhq/tolaria/releases/latest'",
            "$res = Invoke-WebRequest -Uri $url -Method Head -UseBasicParsing",
            "$finalUrl = if ($res.BaseResponse.ResponseUri) { $res.BaseResponse.ResponseUri.AbsoluteUri } else { $res.BaseResponse.RequestMessage.RequestUri.AbsoluteUri }",
            "if ($finalUrl -notmatch '/releases/tag/v(\\d{4})-(\\d{2})-(\\d{2})$') { throw \"Unable to parse latest version from: $finalUrl\" }",
            "$version = \"$($Matches[1]).$([int]$Matches[2]).$([int]$Matches[3])\"",
            "$tag = \"$($Matches[1])-$($Matches[2])-$($Matches[3])\"",
            "\"$version $tag\""
        ],
        "regex": "([\\d.]+) ([\\d-]+)",
        "replace": "$1"
    },
    "autoupdate": {
        "url": "https://github.com/refactoringhq/tolaria/releases/download/v$match2/Tolaria_$version_x64-setup.exe#/dl.7z"
    }
}
