        "32bit": {
            "url": [
                "https://archive.mozilla.org/pub/firefox/releases/150.0b2/win32/it/Firefox%20Setup%20150.0b2.exe#/dl.7z",
                "https://raw.githubusercontent.com/starise/scoop-confetti/master/scripts/firefox-policies.json#/policies.json"
