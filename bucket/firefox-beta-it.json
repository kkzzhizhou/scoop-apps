        "32bit": {
            "url": [
                "https://archive.mozilla.org/pub/firefox/releases/149.0b10/win32/it/Firefox%20Setup%20149.0b10.exe#/dl.7z",
                "https://raw.githubusercontent.com/starise/scoop-confetti/master/scripts/firefox-policies.json#/policies.json"
