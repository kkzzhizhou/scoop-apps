        "32bit": {
            "url": [
                "https://archive.mozilla.org/pub/firefox/releases/151.0b5/win32/it/Firefox%20Setup%20151.0b5.exe#/dl.7z",
                "https://raw.githubusercontent.com/starise/scoop-confetti/master/scripts/firefox-policies.json#/policies.json"
