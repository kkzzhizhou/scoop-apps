                "sha512:7576ffe38a1fcb792c0b18cf97ce9d81eec9d042e7cae11763c979c9aab047b1611964ef04dd57e41b4d1a697efd93061fa9e0aac37f425bbeb228b8d60de84d",
                "cb75fbc7489904edf08041213b70c67c8dad3f54fdecdadd623fdb0f44cbaef6"
            ]
        }
    },
    "extract_dir": "core",
    "pre_install": [
        "if(!(Test-Path \"$persist_dir\\distribution\")) {",
        "  New-Item \"$persist_dir\\distribution\" -Type Directory -Force | Out-Null",
        "  Move-Item \"$dir\\policies.json\" \"$persist_dir\\distribution\\policies.json\"",
        "}"
    ],
    "persist": "distribution",
    "bin": [
        [
            "firefox.exe",
            "firefox-beta"
        ]
    ],
    "shortcuts": [
        [
            "firefox.exe",
            "Firefox Beta"
        ]
    ],
    "checkver": {
        "url": "https://product-details.mozilla.org/1.0/firefox_versions.json",
        "jsonpath": "$.LATEST_FIREFOX_RELEASED_DEVEL_VERSION"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win64/it/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64/it/$basename"
                }
            },
            "32bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win32/it/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win32/it/$basename"
                }
            }
        }
    }
}
