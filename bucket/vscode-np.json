{
    "version": "1.117.0",
    "description": "Lightweight but powerful source code editor",
    "homepage": "https://code.visualstudio.com/",
    "license": {
        "identifier": "Freeware",
        "url": "https://code.visualstudio.com/License/"
    },
    "architecture": {
        "64bit": {
            "url": "https://vscode.download.prss.microsoft.com/dbazure/download/stable/173f07e5fc9aeeb33a6a7ea1c62a7456dc1d5108/VSCodeSetup-x64-1.117.0.exe#/setup.exe",
            "hash": "e8e3b1904d067061fb9fb6524dafe5bdbf8f4e65d9f0df87ac2c07d33ddf4f1a"
        },
        "arm64": {
            "url": "https://vscode.download.prss.microsoft.com/dbazure/download/stable/173f07e5fc9aeeb33a6a7ea1c62a7456dc1d5108/VSCodeSetup-arm64-1.117.0.exe#/setup.exe",
            "hash": "c50273322dffba3bb3f1b0c11ce311413a2eb9abeb79c68c45d614e41d391675"
        }
    },
    "env_add_path": "bin",
    "shortcuts": [
        [
            "code.exe",
            "Visual Studio Code"
        ]
    ],
    "pre_install": [
        "innounp -x -q \"-d$dir\" \"$dir\\setup.exe\" *> $null",
        "Copy-Item \"$dir\\{code_GetDestDir}\\*\" \"$dir\" -Recurse",
        "Remove-Item \"$dir\\{code_GetDestDir}\" -Recurse",
        "Remove-Item \"$dir\\{app}\" -Recurse",
        "Remove-Item \"$dir\\install_script.iss\""
    ],
    "persist": "data",
    "checkver": {
        "url": "https://code.visualstudio.com/sha?build=stable",
        "regex": "version\":\"(?<Code>[\\d\\w]+)\",\"productVersion\":\"(?<version>[\\d.]+)",
        "replace": "${version}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://vscode.download.prss.microsoft.com/dbazure/download/stable/$matchCode/VSCodeSetup-x64-$version.exe#/setup.exe",
                "hash": {
                    "url": "https://code.visualstudio.com/sha?build=stable",
                    "jsonpath": "$.products[?(@.platform.os == 'win32-x64')].sha256hash"
                }
            },
            "arm64": {
                "url": "https://vscode.download.prss.microsoft.com/dbazure/download/stable/$matchCode/VSCodeSetup-arm64-$version.exe#/setup.exe",
                "hash": {
                    "url": "https://code.visualstudio.com/sha?build=stable",
                    "jsonpath": "$.products[?(@.platform.os == 'win32-arm64')].sha256hash"
                }
            }
        }
    }
}
