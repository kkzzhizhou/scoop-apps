{
    "version": "1.5.0.1413b",
    "description": "Locate files and folders by name instantly.",
    "homepage": "https://www.voidtools.com",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "http://www.voidtools.com/Everything-1.5.0.1413b.x64-Setup.exe",
            "hash": "33aaad9a14de4864b3b1c49ea4e3ee58810fab925bc1f8de0b622bf5caaba017"
        },
        "32bit": {
            "url": "http://www.voidtools.com/Everything-1.5.0.1413b.x86-Setup.exe",
            "hash": "36514300ab65e21eb7bc534c1eccc4f82afa8545db3496d281e12844e59763f1"
        }
    },
    "pre_install": "if (-not (is_admin)) { abort \"`n[ERROR]  $app requires admin rights to $cmd.\" }",
    "installer": {
        "script": [
            "Start-Process -FilePath \"$dir\\$fname\" -ArgumentList @('/S', \"/D=$dir\") -WindowStyle Hidden -Wait",
            "Remove-Item -Path \"$dir\\$fname\" -Force -ErrorAction SilentlyContinue"
        ]
    },
    "post_install": [
        "Remove-Item -Path \"$Env:Public\\Desktop\\Everything.lnk\" -Force",
        "Remove-Item -Path \"$([Environment]::GetFolderPath('commonstartmenu'))\\Programs\\Everything.lnk\" -Force"
    ],
    "bin": "Everything.exe",
    "shortcuts": [
        [
            "Everything.exe",
            "Everything"
        ]
    ],
    "pre_uninstall": [
        "if (-not (is_admin)) { abort \"`n[ERROR]  $app requires admin rights to $cmd.\" }",
        "Stop-Process -Name 'Everything' -Force -ErrorAction SilentlyContinue"
    ],
    "uninstaller": {
        "script": "Start-Process -FilePath \"$dir\\Uninstall.exe\" -ArgumentList @('/S') -WindowStyle Hidden -Wait"
    },
    "checkver": {
        "url": "https://www.voidtools.com/forum/viewtopic.php?sd=d&t=9787",
        "regex": "Everything-([\\d.]+b)\\.x64"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "http://www.voidtools.com/Everything-$version.x64-Setup.exe"
            },
            "32bit": {
                "url": "http://www.voidtools.com/Everything-$version.x86-Setup.exe"
            }
        }
    }
}
