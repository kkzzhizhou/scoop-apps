{
    "version": "0_10_9",
    "description": "DRL (D**m, the Roguelike) is a fast and furious coffee-break Roguelike game, inspired by DOOM",
    "homepage": "https://drl.chaosforge.org/",
    "license": "GPL-2.0-only",
    "architecture": {
        "64bit": {
            "url": "https://github.com/chaosforgeorg/drl/releases/download/0_10_9/drl-win-0109.zip",
            "hash": "dab1292e551488e123fe281408ece8bf7df65c1e02730501f879d2f9fd623758"
        }
    },
    "extract_dir": "drl-win-0109",
    "pre_install": [
        "Copy-Item \"$persist_dir\\save\" \"$dir\" -ErrorAction SilentlyContinue",
        "Copy-Item \"$persist_dir\\settings.lua\" \"$dir\" -ErrorAction SilentlyContinue",
        "Copy-Item \"$persist_dir\\player.wad\" \"$dir\" -ErrorAction SilentlyContinue"
    ],
    "uninstaller": {
        "script": [
            "ensure \"$persist_dir\" | Out-Null",
            "Copy-Item \"$dir\\save\" \"$persist_dir\" -Force -ErrorAction SilentlyContinue",
            "Copy-Item \"$dir\\settings.lua\" \"$persist_dir\" -Force  -ErrorAction SilentlyContinue",
            "Copy-Item \"$dir\\player.wad\" \"$persist_dir\" -Force  -ErrorAction SilentlyContinue"
        ]
    },
    "shortcuts": [
        [
            "drl.exe",
            "DRL"
        ]
    ],
    "persist": "screenshot",
    "checkver": {
        "url": "https://api.github.com/repos/chaosforgeorg/drl/releases/latest",
        "jsonpath": "$..browser_download_url",
        "regex": "/releases/download/(?<tag>v?(?<version>[\\w.-]+))/(?<filebase>drl-win-[\\w]+).zip"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/chaosforgeorg/drl/releases/download/$matchTag/$matchFilebase.zip"
            }
        },
        "extract_dir": "$matchFilebase"
    }
}
