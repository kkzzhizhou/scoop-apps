{
    "version": "0.4.5",
    "description": "OneForAll是一款功能强大的子域收集工具",
    "homepage": "https://github.com/shmilylty/OneForAll",
    "license": "GPL-3.0",
    "suggest": {
        "python": "uv"
    },
    "url": "https://github.com/shmilylty/OneForAll/archive/refs/tags/v0.4.5.zip",
    "hash": "ed7854064b454764bb7295865184e7ece8abe9d5ccdbe1734cb709c62bc3243e",
    "extract_dir": "OneForAll-0.4.5",
    "pre_install": [
        "Set-Content \"$dir\\oneforall.bat\" '@pushd %~dp0",
        "@uv run python \"oneforall.py\" %*",
        "@popd' -Encoding Ascii"
    ],
    "post_install": [
        "uv venv \"$dir\\.venv\"",
        "uv pip install -r $dir\\requirements.txt --python \"$dir\\.venv\\Scripts\\python.exe\""
    ],
    "bin": "oneforall.bat",
    "shortcuts": [
        [
            "oneforall.bat",
            "oneforall"
        ]
    ],
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/shmilylty/OneForAll/archive/refs/tags/v$version.zip",
        "extract_dir": "OneForAll-$version"
    },
    "notes": [
        "【工具类型】: Python工具",
        "【主要功能】: OneForAll是一款功能强大的子域收集工具",
        "【适用场景】: 子域名收集、信息收集、攻击面发现",
        "【技术特点】: 基于Python开发，需Python环境"
    ]
}
