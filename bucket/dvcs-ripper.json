{
    "version": "2020-08-17T16.38.26",
    "description": "Rip web accessible (distributed) version control systems: SVN/GIT/HG...",
    "homepage": "https://github.com/kost/dvcs-ripper",
    "license": "UNKNOWN",
    "suggest": {
        "PERL": [
            "perl"
        ]
    },
    "url": "https://github.com/kost/dvcs-ripper/archive/refs/heads/master.zip",
    "hash": "49aebbef47ae3749249fe312767d5cb685b0c878d5954cf9e90080f8eff4fc19",
    "extract_dir": "dvcs-ripper-master",
    "pre_install": [
        "Set-Content \"$dir\\hg-decode.bat\" '@pushd %~dp0",
        "perl hg-decode.pl %*",
        "@popd' -Encoding Ascii",
        "Set-Content \"$dir\\rip-bzr.bat\" '@pushd %~dp0",
        "perl rip-bzr.pl %*",
        "@popd' -Encoding Ascii",
        "Set-Content \"$dir\\rip-cvs.bat\" '@pushd %~dp0",
        "perl rip-cvs.pl %*",
        "@popd' -Encoding Ascii",
        "Set-Content \"$dir\\rip-gitr.bat\" '@pushd %~dp0",
        "perl rip-git.pl %*",
        "@popd' -Encoding Ascii",
        "Set-Content \"$dir\\rip-hg.bat\" '@pushd %~dp0",
        "perl rip-hg.pl %*",
        "@popd' -Encoding Ascii",
        "Set-Content \"$dir\\rip-svn.bat\" '@pushd %~dp0",
        "perl rip-svn.pl %*",
        "@popd' -Encoding Ascii"
    ],
    "bin": [
        "hg-decode.bat",
        "rip-bzr.bat",
        "rip-cvs.bat",
        "rip-gitr.bat",
        "rip-hg.bat",
        "rip-svn.bat"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/kost/dvcs-ripper/commits",
        "regex": "([\\d-]+T)(\\d+):(\\d+):(\\d+)",
        "replace": "$1$2.$3.$4"
    },
    "autoupdate": {
        "url": "https://github.com/kost/dvcs-ripper/archive/refs/heads/master.zip"
    },
    "notes": [
        "【工具类型】: 安全测试工具",
        "【主要功能】: 版本控制系统泄露检测工具，支持SVN、GIT、HG等版本控制系统",
        "【适用场景】: 代码泄露检测、安全评估、渗透测试",
        "【技术特点】: 基于Perl开发，命令行工具，支持多种版本控制系统"
    ]
}
