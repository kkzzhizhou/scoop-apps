{
    "version": "2.2.8",
    "description": "A space to find, build, and collaborate with agent teammates",
    "homepage": "https://lobehub.com/",
    "license": {
        "url": "https://github.com/lobehub/lobehub?tab=License-1-ov-file"
    },
    "architecture": {
        "64bit": {
            "url": "https://cdn-desktop-releases.lobehub.com/stable/2.2.8/LobeHub-2.2.8-setup.exe#/dl.7z",
            "hash": "f05e5cbe6d5187e7f0293f4fe696e43078e0449af1ca0910597dd84e418117de",
            "installer": {
                "script": [
                    "Expand-7ZipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\" -Removal",
                    "Remove-Item \"$dir\\`$PLUGINSDIR\",\"$dir\\`$R0\"  -Force -Recurse"
                ]
            }
        }
    },
    "bin": "LobeHub.exe",
    "shortcuts": [
        [
            "LobeHub.exe",
            "LobeHub"
        ]
    ],
    "checkver": {
        "url": "https://lobehub.com/changelog/versions/v2",
        "regex": "Version <!-- -->([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://cdn-desktop-releases.lobehub.com/stable/$version/LobeHub-$version-setup.exe#/dl.7z"
            }
        }
    }
}
