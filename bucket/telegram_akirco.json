        "jsonpath": "$..name",
        "re": "tportable-x64.([\\d.]+).zip"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://updates.tdesktop.com/tx64/tportable-x64.$version.zip"
            },
            "32bit": {
                "url": "https://updates.tdesktop.com/tsetup/tportable.$version.zip"
            }
        }
    }
