{
    "version": "0.5.0",
    "description": "Manhuagui manga reader and downloader with a graphical interface, supports downloading hidden content and exporting to CBZ and PDF formats.",
    "homepage": "https://github.com/lanyeeee/manhuagui-downloader",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/lanyeeee/manhuagui-downloader/releases/download/v0.5.0/manhuagui-downloader_0.5.0_windows_x64_portable.zip",
            "hash": "40a0398a6ea53fa8bc0ae8215bfd371e00def3c8495c2bbc66ccaa719bb78325"
        }
    },
    "post_install": [
        "& \"$(Find-BucketDirectory -Root -Name (coalesce $bucket 'muggle'))/scripts/DoradoHelper.ps1\" -Action Mount -PersistDir \"$persist_dir\" -Target \"$env:APPDATA/com.lanyeeee.manhuagui-downloader\""
    ],
    "pre_uninstall": [
        "& \"$(Find-BucketDirectory -Root -Name (coalesce $bucket 'muggle'))/scripts/DoradoHelper.ps1\" -Action Dismount -Target \"$env:APPDATA/com.lanyeeee.manhuagui-downloader\""
    ],
    "bin": "manhuagui-downloader.exe",
    "shortcuts": [
        [
            "manhuagui-downloader.exe",
            "Manhuagui Downloader"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/lanyeeee/manhuagui-downloader/releases/latest",
        "jsonpath": "$..tag_name",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/lanyeeee/manhuagui-downloader/releases/download/v$version/manhuagui-downloader_$version_windows_x64_portable.zip"
            }
        }
    }
}
