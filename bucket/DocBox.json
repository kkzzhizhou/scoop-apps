{
    "version": "2.12.43",
    "homepage": "https://www.ghxi.com/docbox.html",
    "description": "DocBox Green",
    "license": "Freeware",
    "url": "https://cloud-0-index.vercel.app/api/raw/?path=/packages/scoop/DocBox_2.12.43.7z#/dl.7z_",
    "hash": "14E9D7537E18EE9BE9687F8ACE288095F50743B5898D7CF071532EC9F358DD56",
    "pre_install": "Expand-7zipArchive -Path \"$dir\\dl.7z_\" -DestinationPath \"$dir\" -Removal -Switches '-pmuggle'",
    "persist_external": [
        "$env:AppData\\DocBox"
    ],
    "post_install": [
        ". \"$(Find-BucketDirectory -Root -Name (coalesce $bucket 'muggle'))/scripts/persist-external.ps1\"",
        "Invoke-PersistExternalInstall -Manifest $manifest -PersistDir $persist_dir -Dir $dir"
    ],
    "pre_uninstall": [
        ". \"$(Find-BucketDirectory -Root -Name (coalesce $bucket 'muggle'))/scripts/persist-external.ps1\"",
        "Invoke-PersistExternalUninstall -Manifest $manifest -Dir $dir"
    ],
    "shortcuts": [
        [
            "DocBox.exe",
            "稻壳阅读器"
        ]
    ]
}
