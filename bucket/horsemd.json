{
    "version": "0.6.5",
    "description": "A free Typora alternative, and then some — tabs + file-tree + WYSIWYG Markdown editor for Windows & macOS | 免费的 Typora 平替：标签页 + 文件树 + 所见即所得",
    "homepage": "https://horsemd.yangsir.net/",
    "license": {
        "identifier": "MIT license",
        "url": "https://github.com/BND-1/horseMD#MIT-1-ov-file"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/BND-1/horseMD/releases/download/v0.6.5/HorseMD-Setup-0.6.5.exe#/dl.7z",
            "hash": "sha512:39ca84210e4a68ab1b04d1b5195035185abc49d08654a27fe6a87b1edb59dbdacf74c3d0a8ef7ec0bcd4fcde60473258af31df62e936fd17449e1c81046b5274",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\", \"$dir\\uninst*\" -Force -Recurse"
            ]
        }
    },
    "installer": {
        "script": [
            "# handle runtime cache",
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\appdata\" -Target \"$env:APPDATA\\horse\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "uninstaller": {
        "script": [
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\horse\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "bin": "HorseMD.exe",
    "shortcuts": [
        [
            "HorseMD.exe",
            "HorseMD"
        ]
    ],
    "checkver": {
        "github": "https://api.github.com/repos/BND-1/horseMD/releases",
        "jp": "$[0].assets[*].browser_download_url",
        "regex": "/releases/download/v([\\d.]+)/(?<file>HorseMD(?:-|\\.)Setup(?:-|\\.)([\\d.]+)\\.exe)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/BND-1/horseMD/releases/download/v$version/$matchFile#/dl.7z"
            }
        },
        "hash": {
            "url": "$baseurl/latest.yml",
            "regex": "(?sm)$basename.*?sha512:\\s+$base64"
        }
    }
}
