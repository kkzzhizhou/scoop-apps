        "identifier": "GPL-2.0-or-later",
        "url": "https://github.com/dolphin-emu/dolphin/blob/master/COPYING"
    },
    "suggest": {
        "Microsoft Visual C++ Runtime 2022": "extras/vcredist2022"
    },
    "architecture": {
