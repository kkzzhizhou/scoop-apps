    "license": {
        "identifier": "GPL-2.0-or-later",
        "url": "https://github.com/dolphin-emu/dolphin/blob/master/COPYING"
    },
    "suggest": {
        "Microsoft Visual C++ Runtime 2022": "extras/vcredist2022"
    },
    "architecture": {
        "64bit": {
            "url": "https://dl.dolphin-emu.org/builds/ba/67/dolphin-master-2603-277-x64.7z",
            "hash": "cd6fcb7447f67db2bd9a10c0ebd886c70fef5f7011a205bcb9931aa0788e644e",
