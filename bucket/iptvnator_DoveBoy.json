    "hash": "sha512:9ee8351f374c467b151aacfff5ece834a1118ceb8363441c47cb0ff7fb7b9a2371c78568c5a9eba1be8bb3a66b7a2d663388411b254e3a1f7b8950f70f7b4319",
    "architecture": {
        "64bit": {
            "pre_install": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\""
        },
        "32bit": {
            "pre_install": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-32.7z\" \"$dir\""
