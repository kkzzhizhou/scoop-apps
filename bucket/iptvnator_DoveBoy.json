            "ensure \"$persist_dir\" | Out-Null",
            "New-Item \"$env:APPDATA\\iptvnator\" -ItemType Junction -Target \"$persist_dir\" | Out-Null"
        ]
    },
    "uninstaller": {
        "script": "Remove-Item \"$env:APPDATA\\iptvnator\" -Recurse -Force -ErrorAction 'SilentlyContinue'"
    },
    "shortcuts": [
        [
            "iptvnator.exe",
            "IPTVnator"
        ]
    ],
    "checkver": {
        "github": "https://api.github.com/repos/4gray/iptvnator/releases",
        "jp": "$[0].tag_name",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://github.com/4gray/iptvnator/releases/download/v$version/iptvnator-$version-windows-x64-setup.exe#/dl.7z",
        "hash": {
            "url": "$baseurl/latest.yml",
