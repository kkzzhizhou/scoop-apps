            "hash": "65a135103dfd1b72d5906c7216069f1e6aec669ad45622be513ec6e871e9c013"
        }
    },
    "pre_install": [
        "if([Environment]::Is64BitOperatingSystem){",
        "    Remove-Item -Recurse -Force \"$dir\\win-x86\" -ErrorAction SilentlyContinue;",
        "}else{",
        "    Remove-Item -Recurse -Force \"$dir\\win-x64\",\"$dir\\BCUninstaller.exe\" -ErrorAction SilentlyContinue;",
        "    if(Test-Path \"$dir\\win-x86\"){ Move-Item \"$dir\\win-x86\\*\" \"$dir\" -Force }",
        "    Remove-Item -Recurse -Force \"$dir\\win-x86\" -ErrorAction SilentlyContinue;",
        "}",
        "ensure \"$persist_dir\" | Out-Null",
        "Copy-Item \"$persist_dir\\BCUninstaller.settings\" \"$dir\" -ErrorAction 'SilentlyContinue'"
    ],
    "uninstaller": {
        "script": "Copy-Item \"$dir\\BCUninstaller.settings\" \"$persist_dir\" -ErrorAction 'SilentlyContinue' -Force"
    },
    "bin": "BCUninstaller.exe",
    "shortcuts": [
        [
            "BCUninstaller.exe",
            "BC Uninstaller"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repositories/64677873/releases/latest",
        "jsonpath": "$..browser_download_url",
        "regex": "download/v(?<tag>[\\d.]+)/BCUninstaller_([\\d.]+)_portable.zip"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Klocman/Bulk-Crap-Uninstaller/releases/download/v$matchTag/BCUninstaller_$version_portable.zip"
            },
            "32bit": {
                "url": "https://github.com/Klocman/Bulk-Crap-Uninstaller/releases/download/v$matchTag/BCUninstaller_$version_portable.zip"
            }
        }
    }
}
