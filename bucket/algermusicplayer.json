{
    "version": "5.1.0",
    "description": "一个基于 electron typescript vue3 的桌面音乐播放器",
    "homepage": "https://github.com/algerkong/AlgerMusicPlayer",
    "license": {
        "identifier": "Apache-2.0 license",
        "url": "https://github.com/algerkong/AlgerMusicPlayer#Apache-2.0-1-ov-file"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/algerkong/AlgerMusicPlayer/releases/download/v5.1.0/AlgerMusicPlayer-5.1.0-win-x64.exe#/dl.7z",
            "hash": "a46e74cbb167df6968b6ca26313713c32e129925cfe164aef31743a9d46d3dac",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\" -Force -Recurse"
            ]
        },
        "32bit": {
            "url": "https://github.com/algerkong/AlgerMusicPlayer/releases/download/v5.1.0/AlgerMusicPlayer-5.1.0-win-ia32.exe#/dl.7z",
            "hash": "808a5d2ba2ca66cf7eae5b10ab682ea9202960fcfbac0eae45d0a36f70a6b0a8",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-32.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\" -Force -Recurse"
            ]
        },
        "arm64": {
            "url": "https://github.com/algerkong/AlgerMusicPlayer/releases/download/v5.1.0/AlgerMusicPlayer-5.1.0-win-arm64.exe#/dl.7z",
            "hash": "7b60a8382e33d4e26b4db4ead2bd09be246ec2b71294493ed9c64e6f47938523",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-arm64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\" -Force -Recurse"
            ]
        }
    },
    "installer": {
        "script": [
            "# handle runtime cache",
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\" -Target \"$env:APPDATA\\AlgerMusicPlayer\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "uninstaller": {
        "script": [
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\AlgerMusicPlayer\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "bin": "AlgerMusicPlayer.exe",
    "shortcuts": [
        [
            "AlgerMusicPlayer.exe",
            "AlgerMusicPlayer"
        ]
    ],
    "checkver": {
        "script": [
            "$url = 'https://api.github.com/repos/algerkong/AlgerMusicPlayer/releases'",
            "$cont = (Invoke-WebRequest $url).Content",
            "$r = 'AlgerMusicPlayer-([\\d.]+)-win-x64\\.' ",
            "if (!($cont -match $r)) { error \"Could not match $r in $url\"; continue }",
            "$version = $matches[1]",
            "$r = 'AlgerMusicPlayer-([\\d.]+)-win-ia32\\.' ",
            "if (!($cont -match $r)) { error \"Could not match $r in $url\"; continue }",
            "$ia32 = $matches[1]",
            "$r = 'AlgerMusicPlayer-([\\d.]+)-win-arm64\\.' ",
            "if (!($cont -match $r)) { error \"Could not match $r in $url\"; continue }",
            "$arm64 = $matches[1]",
            "Write-Output $version $ia32 $arm64"
        ],
        "regex": "([\\d.]+) (?<ia32>[\\d.]+) (?<arm64>[\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/algerkong/AlgerMusicPlayer/releases/download/v$version/AlgerMusicPlayer-$version-win-x64.exe#/dl.7z"
            },
            "32bit": {
                "url": "https://github.com/algerkong/AlgerMusicPlayer/releases/download/v$matchIa32/AlgerMusicPlayer-$matchIa32-win-ia32.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/algerkong/AlgerMusicPlayer/releases/download/v$matchArm64/AlgerMusicPlayer-$matchArm64-win-arm64.exe#/dl.7z"
            }
        }
    }
}
