{
    "version": "2.0.0-beta.16",
    "description": "Termora is a cross-platform terminal emulator and SSH client for Windows, macOS and Linux.",
    "homepage": "https://termora.app",
    "license": "AGPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://github.com/TermoraDev/termora/releases/download/2.0.0-beta.16/termora-2.0.0-beta.16-windows-x86-64.zip",
            "hash": "c0d93ffdc50836ad595b8eec7eec689efbb42e52ee7fe2b2af0584d5a9970d36"
        },
        "arm64": {
            "url": "https://github.com/TermoraDev/termora/releases/download/2.0.0-beta.16/termora-2.0.0-beta.16-windows-aarch64.zip",
            "hash": "e90f3d8d241ec394b04aab1091434c6491856c2c6c7120de90538302db1bcd02"
        }
    },
    "extract_dir": "Termora",
    "bin": "Termora.exe",
    "persist": [
        "data"
    ],
    "shortcuts": [
        [
            "Termora.exe",
            "Termora"
        ]
    ],
    "pre_install": [
        "if (!(Test-Path \"$dir\\data\")) { New-Item -ItemType Directory -Path \"$dir\\data\" | Out-Null }"
    ],
    "env_set": {
        "TERMORA_BASE_DATA_DIR": "$persist_dir\\data"
    },
    "notes": [
        "This manifest tracks the latest prerelease (beta) version. The stable release is 1.0.17.",
        "To use the stable channel instead, change checkver to {\"github\":\"https://github.com/TermoraDev/termora\"} and set version to the latest stable tag."
    ],
    "checkver": {
        "url": "https://github.com/TermoraDev/termora/releases",
        "regex": "/releases/tag/([\\d.]+-beta\\.\\d+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/TermoraDev/termora/releases/download/$version/termora-$version-windows-x86-64.zip"
            },
            "arm64": {
                "url": "https://github.com/TermoraDev/termora/releases/download/$version/termora-$version-windows-aarch64.zip"
            }
        }
    }
}
