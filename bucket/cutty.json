{
	"version": "0.18.5",
	"description": "A modern terminal emulator forked from Alacritty",
	"homepage": "https://github.com/gold-silver-copper/CuTTY",
	"license": "Apache-2.0",
	"url": "https://github.com/gold-silver-copper/CuTTY/releases/download/v0.18.5/CuTTY-v0.18.5-portable.exe#/cutty.exe",
	"hash": "8c577082b8e04eb48139399f39dffb581a768ad58322b7c5b47eaceca4b8891d",
	"bin": "cutty.exe",
	"shortcuts": [
		["cutty.exe", "CuTTY", "--working-directory \"%USERPROFILE%\""]
	],
	"checkver": {
		"script": [
			"$release = Invoke-RestMethod -Headers @{ 'User-Agent' = 'Codex' } -Uri 'https://api.github.com/repos/gold-silver-copper/CuTTY/releases/latest'",
			"$asset = $release.assets | Where-Object { $_.name -eq \"CuTTY-$($release.tag_name)-portable.exe\" } | Select-Object -First 1",
			"Write-Output \"$($release.tag_name.TrimStart('v')) $($asset.browser_download_url) $($asset.digest.Replace('sha256:', ''))\""
		],
		"regex": "(?<version>[\\d.]+)\\s(?<url>[^\\s]+)\\s(?<hash>[^\\s]+)"
	},
	"autoupdate": {
		"url": "$matchUrl#/cutty.exe",
		"hash": "$matchHash"
	}
}
