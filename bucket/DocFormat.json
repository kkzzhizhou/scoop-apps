{
    "version": "1.8.7",
    "description": "Local Official Document Format Auto-Processing Tool",
    "homepage": "https://github.com/KaguraNanaga/docformat-gui",
    "license": "MIT",
    "depends": "uv",
    "url": "https://github.com/KaguraNanaga/docformat-gui/archive/refs/tags/v1.8.7.zip",
    "hash": "2ef7b0224b6a41d73b3dd36b297d917a37809d5e9281ea2f4cfddc871c8f8cec",
    "extract_dir": "docformat-gui-1.8.7",
    "installer": {
        "script": [
            "Set-Location \"$dir\"",
            "uv init --bare",
            "uv add -r requirements.txt",
            "Set-Content \"$dir\\DocFormat.bat\" '@start uvw.exe run \"%~dp0\\docformat_gui.py\" %*' -Encoding ASCII"
        ]
    },
    "bin": "DocFormat.bat",
    "shortcuts": [
        [
            "DocFormat.bat",
            "DocFormat"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/KaguraNanaga/docformat-gui/releases",
        "jsonpath": "$[0].tag_name",
        "regex": "v?([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://github.com/KaguraNanaga/docformat-gui/archive/refs/tags/v$version.zip",
        "extract_dir": "docformat-gui-$version"
    }
}
