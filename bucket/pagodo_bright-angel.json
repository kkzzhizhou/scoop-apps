    "hash": "a014a87dff472852f22092d48d0858dac58220da7cdff298d3f37964938f65eb",
    "extract_dir": "pagodo-2.7.0",
    "pre_install": [
        "Set-Content \"$dir\\pagodo.bat\" '@pushd %~dp0",
        "@uv run python \"pagodo.py\" %*",
        "@popd' -Encoding Ascii"
    ],
    "post_install": [
        "uv venv \"$dir\\.venv\"",
        "uv pip install -r $dir\\requirements.txt --python \"$dir\\.venv\\Scripts\\python.exe\""
    ],
    "bin": "pagodo.bat",
    "shortcuts": [
        [
            "pagodo.bat",
            "pagodo"
        ]
    ],
    "checkver": "github",
