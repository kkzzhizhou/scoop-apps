{
    "version": "2026.2.0",
    "description": "ScummVM is a program which allows you to run certain classic graphical adventure and role-playing games",
    "homepage": "https://www.scummvm.org/",
    "license": {
        "identifier": "GPL-3.0",
        "url": "https://github.com/scummvm/scummvm/blob/master/COPYING"
    },
    "architecture": {
        "32bit": {
            "url": "https://downloads.scummvm.org/frs/scummvm/2026.2.0/scummvm-2026.2.0-win32.zip",
            "hash": "a76dc39c07951f8cf23f6fd5a16cefcbd94fddfadb7667800c277dbd2247ee15",
            "extract_dir": "scummvm-2026.2.0-win32"
        },
        "64bit": {
            "url": "https://downloads.scummvm.org/frs/scummvm/2026.2.0/scummvm-2026.2.0-win32-x86_64.zip",
            "hash": "87f271d4c7396472ce85a85fcd94d2bdb2ed59d15ffcd067d559c58462ebadbd",
            "extract_dir": "scummvm-2026.2.0-win32-x86_64"
        }
    },
    "pre_install": [
        "if (Test-Path \"$dir\\scummvm-$version.exe\") {",
        "   Rename-Item -Path \"$dir\\scummvm-$version.exe\" -NewName \"scummvm.exe\"",
        "}",
        "if (!(Test-Path \"$persist_dir\\scummvm.ini\")) {",
        "   New-Item -Path \"$dir\" -Name \"scummvm.ini\" -ItemType \"File\" | Out-Null",
        "}"
    ],
    "shortcuts": [
        [
            "scummvm.exe",
            "ScummVM"
        ]
    ],
    "persist": [
        "scummvm.ini",
        "saves",
        "themes",
        "extras"
    ],
    "checkver": {
        "github": "https://github.com/scummvm/scummvm"
    },
    "autoupdate": {
        "hash": {
            "url": "$url.sha256"
        },
        "architecture": {
            "32bit": {
                "url": "https://downloads.scummvm.org/frs/scummvm/$version/scummvm-$version-win32.zip",
                "extract_dir": "scummvm-$version-win32"
            },
            "64bit": {
                "url": "https://downloads.scummvm.org/frs/scummvm/$version/scummvm-$version-win32-x86_64.zip",
                "extract_dir": "scummvm-$version-win32-x86_64"
            }
        }
    }
}
