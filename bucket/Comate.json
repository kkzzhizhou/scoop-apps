{
    "version": "2.0.2",
    "description": "An AI-powered IDE",
    "homepage": "https://comate.baidu.com/zh/download/ai-ide",
    "license": "Proprietary",
    "architecture": {
        "64bit": {
            "url": "https://comate-ide.cdn.bcebos.com/download/stable/eedf99648c91f3511a97065963783dfaa18955e7-254698121/Comate-win32-x64.zip",
            "hash": "63d8ddefd155596a168d6119095e08803e6ebd6b238c12331229f7ecc18955fc",
            "extract_dir": "VSCode-win32-x64"
        },
        "arm64": {
            "url": "https://comate-ide.cdn.bcebos.com/download/stable/eedf99648c91f3511a97065963783dfaa18955e7-254698121/Comate-win32-arm64.zip",
            "hash": "afdf9d1efd81f9ee27d6e67fb9c5154cf8c35381316e29357245ae7719172185",
            "extract_dir": "VSCode-win32-arm64"
        }
    },
    "post_install": [
        "if (!(Test-Path \"$dir\\data\\extensions\") -and (Test-Path \"$env:USERPROFILE\\.comate\\extensions\")) {",
        "    info '[Portable Mode] Copying extensions...'",
        "    Copy-Item \"$env:USERPROFILE\\.comate\\extensions\" \"$dir\\data\" -Recurse",
        "}",
        "if (!(Test-Path \"$dir\\data\\user-data\") -and (Test-Path \"$env:AppData\\Comate\")) {",
        "    info '[Portable Mode] Copying user data...'",
        "    Copy-Item \"$env:AppData\\Comate\" \"$dir\\data\\user-data\" -Recurse",
        "}",
        "$extensions_file = \"$dir\\data\\extensions\\extensions.json\"",
        "if ((Test-Path \"$extensions_file\")) {",
        "    info 'Adjusting path in extensions file...'",
        "    (Get-Content \"$extensions_file\") -replace '(?<=comate(/|\\\\\\\\)).*?(?=(/|\\\\\\\\)data(/|\\\\\\\\)extensions)', $version | Set-Content \"$extensions_file\"",
        "}"
    ],
    "bin": [
        [
            "bin/Comate.cmd",
            "comate"
        ]
    ],
    "shortcuts": [
        [
            "Comate.exe",
            "Comate",
            "--user-data-dir=\"$dir\\data\\user-data\" --extensions-dir=\"$dir\\data\\extensions\""
        ]
    ],
    "persist": "data"
}
