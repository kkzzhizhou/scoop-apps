            "firefox.exe",
            "firefox-nightly"
        ]
    ],
    "shortcuts": [
        [
            "firefox.exe",
            "Firefox Nightly"
        ],
        [
            "firefox.exe",
            "Firefox Nightly Profile Manager",
            "-P"
        ]
    ],
    "persist": [
        "distribution",
        "profile"
    ],
