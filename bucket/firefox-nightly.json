    "notes": [
        "To set profile 'Scoop-Nightly' as *DEFAULT*, or profiles/settings was lost after update:",
        "  - Run 'Firefox Nightly Profile Manager', choose 'Scoop-Nightly' then click 'Start Nightly'.",
        "  - Visit 'about:profiles' page in Firefox Nightly to check *DEFAULT* profile.",
        "For details: https://support.mozilla.org/en-US/kb/profile-manager-create-remove-switch-firefox-profiles"
    ],
    "architecture": {
        "64bit": {
            "url": "https://archive.mozilla.org/pub/firefox/nightly/2026/03/2026-03-31-21-08-27-mozilla-central/firefox-151.0a1.en-US.win64.installer.exe#/dl.7z",
            "hash": "sha512:6c150320b8fd197472be6f7dac8f2a24f1032e8c8b51339d171540e0365b22ff56029b745fa06de7ff2d1d2e11b274b4567cd50fe8b79ae9abdabb53b6d2d108"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/nightly/2026/03/2026-03-31-21-08-27-mozilla-central/firefox-151.0a1.en-US.win32.installer.exe#/dl.7z",
