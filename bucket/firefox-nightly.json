            "hash": "sha512:0fd6c7bf4a52405f120445c4dcae8545f8c24ba35a75f5b5a66905e95d6a7164432581a6b1a8f66b5a9857c19612efb89db955b67ba072dc4ba77a40d3a55051"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/nightly/2026/03/2026-03-17-21-20-32-mozilla-central/firefox-150.0a1.en-US.win32.installer.exe#/dl.7z",
