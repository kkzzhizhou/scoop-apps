            "hash": "sha512:aedbaf3974cd2c48b89c3247d1766cd0c9a6879cc1eeef694571ba338b60cf70aadd082f0b46e9caae311730ea2d339be18e70964e714cb843316abdbb31317b"
        },
        "32bit": {
