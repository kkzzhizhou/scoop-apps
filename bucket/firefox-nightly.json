            "hash": "sha512:7b555ddb2ebb7c09e1d73bb2a598829341670bce6cf1b7ddf9d4737e1a3fef653fe852b60000a4b4cabf5cdb4fe779fd1b41a4612532a08dcfa2625283a66795"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/nightly/2026/07/2026-07-20-18-01-21-mozilla-central/firefox-155.0a1.en-US.win32.installer.exe#/dl.7z",
