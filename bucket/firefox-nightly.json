    "notes": [
        "To set profile 'Scoop-Nightly' as *DEFAULT*, or profiles/settings was lost after update:",
        "  - Run 'Firefox Nightly Profile Manager', choose 'Scoop-Nightly' then click 'Start Nightly'.",
        "  - Visit 'about:profiles' page in Firefox Nightly to check *DEFAULT* profile.",
        "For details: https://support.mozilla.org/en-US/kb/profile-manager-create-remove-switch-firefox-profiles"
    ],
    "architecture": {
        "64bit": {
            "url": "https://archive.mozilla.org/pub/firefox/nightly/2026/03/2026-03-21-20-51-52-mozilla-central/firefox-150.0a1.en-US.win64.installer.exe#/dl.7z",
            "hash": "sha512:da8427d5ed8880d6e5f34e04f9f41a3dc0eb8b7151c54d981ebfa41cbec471dcde4263a5e4c483b0af14725a601070c0cda841bb573a50a15daf97427c0c30f9"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/nightly/2026/03/2026-03-21-20-51-52-mozilla-central/firefox-150.0a1.en-US.win32.installer.exe#/dl.7z",
