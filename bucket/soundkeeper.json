{
    "version": "1.3.5",
    "description": "Prevents SPDIF/HDMI/Bluetooth digital audio playback devices from sleeping.",
    "homepage": "https://veg.by/en/projects/soundkeeper/",
    "license": "MIT",
    "url": "https://veg.by/files/winsoft/soundkeeper.7z",
    "hash": "8fb5a3d80b24ff4b2601e86f2638e09a1479464c0a2b568a1c7d2d941912f80f",
    "architecture": {
        "64bit": {
            "bin": [
                ["SoundKeeper64.exe", "SoundKeeper"],
                "SoundKeeper64.exe",
                "SoundKeeperAll.exe",
                "SoundKeeperZero.exe",
                "SoundKeeperAllZero.exe",
                "SoundKeeperOpenOnly.exe"
            ]
        }
    },
    "pre_install": [
        "Remove-Item \"$dir\\SoundKeeperARM64.exe\" -ErrorAction SilentlyContinue",
        "Remove-Item \"$dir\\SoundKeeper32.exe\" -ErrorAction SilentlyContinue",
        "Copy-Item \"$dir\\SoundKeeper64.exe\" \"$dir\\SoundKeeperAll.exe\"",
        "Copy-Item \"$dir\\SoundKeeper64.exe\" \"$dir\\SoundKeeperZero.exe\"",
        "Copy-Item \"$dir\\SoundKeeper64.exe\" \"$dir\\SoundKeeperAllZero.exe\"",
        "Copy-Item \"$dir\\SoundKeeper64.exe\" \"$dir\\SoundKeeperOpenOnly.exe\""
    ],
    "notes": "Usage: $dir\\ReadMe.txt",
    "checkver": {
        "url": "https://veg.by/en/projects/soundkeeper/",
        "regex": "Sound Keeper v([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://veg.by/files/winsoft/soundkeeper.7z"
    }
}
