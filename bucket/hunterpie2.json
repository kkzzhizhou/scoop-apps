{
    "homepage": "https://github.com/HunterPie/HunterPie/",
    "version": "2.14.0.461",
    "description": "HunterPie is a modern and simple to use overlay with support for Discord Rich Presence for Monster Hunter: World and Rise",
    "url": "https://github.com/HunterPie/HunterPie/releases/download/v2.14.0.461/2.14.0.461.zip",
    "hash": "7912bd0a033f26113915913fee873e7f622f0dd74da6951e61c3adad42dcef1c",
    "pre_install": [
        "if(!(Test-Path \"$persist_dir\\config.json\")) {",
        "   Write-Output \"Generating config...\"",
        "   Start-Process \"$dir\\hunterpie.exe\"",
        "   Start-Sleep -Seconds 4",
        "   Stop-Process -Name hunterpie",
        "}"
    ],
    "bin": "HunterPie.exe",
    "shortcuts": [
        [
            "HunterPie.exe",
            "HunterPie"
        ]
    ],
    "persist": [
        "config.json",
        "DataExport/"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/HunterPie/HunterPie/releases/latest",
        "jsonpath": {
            "version": "$.tag_name",
            "download": "$.assets[0].browser_download_url",
            "hash": "$.assets[0].digest"
        },
        "regex": "v([\\d\\.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchDownload",
                "hash": "$matchHash"
            }
        }
    }
}
