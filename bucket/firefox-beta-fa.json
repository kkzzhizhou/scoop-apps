            "hash": "sha512:1de23f2592a37d31d948c9a58008551b20697793fc2f32ab7120e4e5bbc5ea5110fe0d621aca582725949722488d79b2340b064a48b9cd4ea2c733d8d8fe205e"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/153.0b6/win32/fa-IR/Firefox%20Setup%20153.0b6.exe#/dl.7z",
            "hash": "sha512:1de23f2592a37d31d948c9a58008551b20697793fc2f32ab7120e4e5bbc5ea5110fe0d621aca582725949722488d79b2340b064a48b9cd4ea2c733d8d8fe205e"
