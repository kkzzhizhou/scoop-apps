{
    "version": "1.5.0",
    "description": "🧡 Follow everything in one place",
    "homepage": "https://follow.is/",
    "license": {
        "identifier": "GPL-3.0 license",
        "url": "https://github.com/RSSNext/Folo#GPL-3.0-1-ov-file"
    },
    "url": "https://github.com/RSSNext/Folo/releases/download/desktop/v1.5.0/Folo-1.5.0-windows-x64.exe#/dl.7z",
    "hash": "sha512:979152c7eefefa539c5ffb7e70e6117a717810f72e62df4c30c3384c2ff11c7647c06fff0fdbac2b4dbfe9e03da92bfc0489bd78e4e07532f1e2df16cf24f204",
    "pre_install": [
        "Get-Item \"$dir\\Folo*.nupkg\" | Rename-Item -NewName 'Folo.nupkg'",
        "Expand-7zipArchive \"$dir\\Folo.nupkg\" \"$dir\" -ExtractDir 'lib\\net45'",
        "Remove-Item \"$dir\\*.gif\", \"$dir\\*.nupkg\", \"$dir\\RELEASES\",  \"$dir\\*.ico\", \"$dir\\Update.exe\" -Force -Recurse"
    ],
    "installer": {
        "script": [
            "# handle runtime cache",
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\" -Target \"$env:APPDATA\\Folo\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "uninstaller": {
        "script": [
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\Folo\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "bin": "Folo.exe",
    "shortcuts": [
        [
            "Folo.exe",
            "Folo"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/RSSNext/Folo/releases/latest",
        "regex": "/releases/tag/desktop/v([\\w.-]+)"
    },
    "autoupdate": {
        "url": "https://github.com/RSSNext/Folo/releases/download/desktop/v$version/Folo-$version-windows-x64.exe#/dl.7z",
        "hash": {
            "url": "$baseurl/latest.yml",
            "regex": "sha512:\\s+$base64"
        }
    }
}
