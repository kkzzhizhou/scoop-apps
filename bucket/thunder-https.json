{
    "version": "2.0",
    "description": "专业的迅雷专用链转换工具，可将thunder://开头的加密链接转换为可直接使用的HTTP/HTTPS下载地址。支持Windows/macOS双平台（lite版本支持全平台），提供优雅的现代化界面和高效稳定的转换服务。",
    "homepage": "https://github.com/helloworldpxy/thunder-https",
    "license": {
        "identifier": "MPL-2.0 license",
        "url": "https://github.com/helloworldpxy/thunder-https#MPL-2.0-1-ov-file"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/helloworldpxy/thunder-https/releases/download/v2.0/Thunder.HTTPS.Setup.2.0.0.exe#/dl.7z",
            "hash": "1a7deb1a93a7549e06ca1a89adb9c61dae6a18b12c2aee6b3d8c0d462b088e06",
            "pre_install": "Remove-Item \"$dir\\`$*\" -Force -Recurse"
        }
    },
    "installer": {
        "script": [
            "# handle runtime cache",
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\appdata\" -Target \"$env:APPDATA\\thunder-https\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "uninstaller": {
        "script": [
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\thunder-https\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "bin": [
        [
            "Thunder HTTPS.exe",
            "ThunderHTTPS"
        ]
    ],
    "shortcuts": [
        [
            "Thunder HTTPS.exe",
            "ThunderHTTPS"
        ]
    ],
    "checkver": {
        "github": "https://api.github.com/repos/helloworldpxy/thunder-https/releases/latest",
        "jp": "$.assets[*].browser_download_url",
        "regex": "/releases/download/v([\\d.]+)/(?<file>.*\\.exe)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/helloworldpxy/thunder-https/releases/download/v$version/$matchFile#/dl.7z"
            }
        }
    }
}
