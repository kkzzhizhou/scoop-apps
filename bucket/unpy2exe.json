{
    "version": "2018-04-26T19.36.40",
    "description": "从使用 py2exe 创建的可执行文件中提取 .pyc 文件",
    "notes": [
        "【工具类型】: 逆向工具",
        "【主要功能】: 从py2exe生成的可执行文件中提取.pyc文件，用于逆向分析",
        "【适用场景】: 逆向工程、代码分析、安全研究",
        "【技术特点】: Python开发，命令行工具，需要Python环境"
    ],
    "homepage": "https://github.com/matiasb/unpy2exe",
    "license": "unknown",
    "suggest": {
        "python": "uv"
    },
    "url": "https://github.com/matiasb/unpy2exe/archive/refs/heads/master.zip",
    "hash": "4830c3ead08301c3079f2eb39443e00c5839fde813ada86f2e28fd6930a38fc1",
    "extract_dir": "unpy2exe-master",
    "pre_install": [
        "Set-Content \"$dir\\unpy2exe.bat\" '@pushd %~dp0",
        "@uv run python \"unpy2exe.py\" %*",
        "@popd' -Encoding Ascii"
    ],
    "post_install": [
        "uv venv \"$dir\\.venv\"",
        "uv pip install -r $dir\\requirements.txt --python \"$dir\\.venv\\Scripts\\python.exe\""
    ],
    "bin": "unpy2exe.bat",
    "checkver": {
        "url": "https://api.github.com/repos/matiasb/unpy2exe/commits",
        "regex": "([\\d-]+T)(\\d+):(\\d+):(\\d+)",
        "replace": "$1$2.$3.$4"
    },
    "autoupdate": {
        "url": "https://github.com/matiasb/unpy2exe/archive/refs/heads/master.zip"
    }
}
