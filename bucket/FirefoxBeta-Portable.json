{
    "version": "153.0b8",
    "description": "Firefox Beta. Beta builds of Firefox: the popular open source web browser.",
    "homepage": "https://www.mozilla.org/en-US/firefox/beta/",
    "license": "MPL-2.0",
    "changelog": "https://www.mozilla.org/en-US/firefox/104.0beta/releasenotes/",
    "notes": [
        "To set profile 'Scoop-Beta' as *DEFAULT*, or profiles/settings was lost after update:",
        "  - Run 'Firefox Beta Profile Manager', choose 'Scoop-Beta' then click 'Start Firefox'.",
        "  - Visit 'about:profiles' page in Firefox Beta to check *DEFAULT* profile.",
        "For details: https://support.mozilla.org/en-US/kb/profile-manager-create-remove-switch-firefox-profiles"
    ],
    "architecture": {
        "64bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/153.0b8/win64/en-US/Firefox%20Setup%20153.0b8.exe#/dl.7z",
            "hash": "sha512:d3b7b6679eba9f8da7be2e17bf7a601a4d6c0668afa378a2883d9ec28996423a35eca20581ea21cc2e2b513225b44accb0680004a9501584d09a5134146042d2"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/153.0b8/win32/en-US/Firefox%20Setup%20153.0b8.exe#/dl.7z",
            "hash": "sha512:df95459834dcca4217f9e4b8cb2cc3a2742429f617103f914d5d835b5b1b11457762ca6bde10ddaf786d38d3d335094f0914a19eb5347e2b684a979f4e7d36f5"
        }
    },
    "extract_dir": "core",
    "post_install": [
        "firefox-beta -CreateProfile \"Scoop-Beta $persist_dir\\profile\"",
        "$Addition = \"$persist_dir\\addition\"",
        "if (Test-Path $Addition) {",
        "  info 'Copying additional items...'",
        "  Copy-Item -Path $Addition\\* -Destination $dir -Force -Recurse -ErrorAction SilentlyContinue",
        "}"
    ],
    "bin": [
        [
            "firefox.exe",
            "firefox-beta"
        ]
    ],
    "shortcuts": [
        [
            "firefox.exe",
            "Firefox Beta"
        ],
        [
            "firefox.exe",
            "Firefox Beta Profile Manager",
            "-P"
        ]
    ],
    "persist": [
        "distribution",
        "profile"
    ],
    "checkver": {
        "url": "https://community.chocolatey.org/packages/firefox-dev#releasenotes",
        "regex": "version &#39;([\\db.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win64/en-US/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64/en-US/$basename"
                }
            },
            "32bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win32/en-US/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win32/en-US/$basename"
                }
            }
        }
    }
}
