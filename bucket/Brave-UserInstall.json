    },
    "changelog": "https://brave.com/latest/",
    "architecture": {
        "64bit": {
            "url": "https://github.com/brave/brave-browser/releases/download/v1.91.180/BraveBrowserStandaloneSilentSetup.exe#/setup.exe",
            "hash": "aca365fb42fcc09f3c13358743790e9b23e237f626eb0f91b686bbd4c00aea40"
        },
        "32bit": {
            "url": "https://github.com/brave/brave-browser/releases/download/v1.91.180/BraveBrowserStandaloneSilentSetup32.exe#/setup.exe",
            "hash": "ea3b891da2775a6d3e721871709f8a7a59dbfea86e20e3a34761b54cf8441196"
        },
        "arm64": {
            "url": "https://github.com/brave/brave-browser/releases/download/v1.91.180/BraveBrowserStandaloneSilentSetupArm64.exe#/setup.exe",
            "hash": "24cfb0998ed186405aff55abab9480928d86a103ea9dfb67b725c1923983a19a"
        }
    },
    "pre_install": [
        "$processname = \"Brave\"",
        "$process = Get-Process $processname -ErrorAction SilentlyContinue",
        "if ($process) {",
        "   $process.CloseMainWindow()",
        "   Start-Sleep -Seconds 5",
        "   if (!$process.HasExited) {",
        "       Start-Sleep -Seconds 25",
        "       $process | Stop-Process -Force",
        "   }",
        "}"
    ],
    "installer": {
        "script": [
            "$LocalApplicationData = [Environment]::GetFolderPath(\"LocalApplicationData\")",
            "$filepath = \"$LocalApplicationData\\BraveSoftware\\Brave-Browser\\Application\\brave.exe\"",
            "if(((Test-Path -Path $filepath -PathType Leaf) -eq $false) -or ((Get-Command $filepath).Version.ToString().Substring(4) -lt [System.Version]\"$version\"))",
            "{",
            "   &\"$dir\\setup.exe\" | Out-Null",
            "   if(((Test-Path -Path $filepath -PathType Leaf) -eq $false) -or ((Get-Command $filepath).Version.ToString().Substring(4) -lt [System.Version]\"$version\"))",
            "   {",
            "       exit 1",
            "   }",
            "}",
            "if (Test-Path -Path \"$dir\\setup.exe\") { Remove-Item \"$dir\\setup.exe\" -Force }"
        ]
    },
    "post_install": [
        "$programname = \"Brave\"",
        "$DesktopPath = [Environment]::GetFolderPath(\"DesktopDirectory\")",
        "if (Test-Path \"$DesktopPath\\$programname.lnk\") {Remove-Item \"$DesktopPath\\$programname.lnk\" -Force}"
    ],
    "checkver": {
        "url": "https://github.com/brave/brave-browser/blob/master/CHANGELOG_DESKTOP.md",
        "regex": "releases/tag/v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/brave/brave-browser/releases/download/v$version/BraveBrowserStandaloneSilentSetup.exe#/setup.exe"
            },
            "32bit": {
                "url": "https://github.com/brave/brave-browser/releases/download/v$version/BraveBrowserStandaloneSilentSetup32.exe#/setup.exe"
            },
            "arm64": {
                "url": "https://github.com/brave/brave-browser/releases/download/v$version/BraveBrowserStandaloneSilentSetupArm64.exe#/setup.exe"
            }
        },
        "hash": {
            "url": "$url.sha256",
            "regex": "$sha256.*?\\.exe"
        }
    }
}
