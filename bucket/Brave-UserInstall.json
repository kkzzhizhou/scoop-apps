    "architecture": {
        "64bit": {
            "url": "https://github.com/brave/brave-browser/releases/download/v1.90.124/BraveBrowserStandaloneSilentSetup.exe#/setup.exe",
            "hash": "cf24112b06f9e6ba420cdfe2a71d4086cfa6aa1686b7a4ad97f6aa99016f152d"
        },
        "32bit": {
            "url": "https://github.com/brave/brave-browser/releases/download/v1.90.124/BraveBrowserStandaloneSilentSetup32.exe#/setup.exe",
            "hash": "97266642b3106a51888011887a9c3532b9d48937d0ad8a740ad40b361ad0ebcb"
