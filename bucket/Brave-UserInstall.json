    "architecture": {
        "64bit": {
            "url": "https://github.com/brave/brave-browser/releases/download/v1.91.171/BraveBrowserStandaloneSilentSetup.exe#/setup.exe",
            "hash": "8c5d6433dd29827355b30eda09366a6fee6e5f3ee2c80d625e9134f48904d350"
        },
        "32bit": {
            "url": "https://github.com/brave/brave-browser/releases/download/v1.91.171/BraveBrowserStandaloneSilentSetup32.exe#/setup.exe",
            "hash": "401aff780c13fdbfee46dba6058e5ccb18f50b66a8ec7a021914368206b15baf"
