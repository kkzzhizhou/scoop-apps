{
    "version": "1.6.2",
    "description": "A free, open-source app store for GitHub releases — browse, discover, and install apps with one click. Powered by Kotlin and Compose Multiplatform for Android & Desktop (Linux, MacOS, Windows).",
    "homepage": "https://www.github-store.org/",
    "license": {
        "identifier": "Apache-2.0 license",
        "url": "https://github.com/OpenHub-Store/GitHub-Store#Apache-2.0-1-ov-file"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/OpenHub-Store/GitHub-Store/releases/download/1.6.2/GitHub-Store-1.6.2.msi",
            "hash": "47ba4af52738fa5c1a49fde246429f021fe69b0f6dc168499ef5de0b654cb002"
        }
    },
    "innosetup": true,
    "pre_install": [
        "Copy-Item \"$dir\\GitHub-Store\\*\" \"$dir\" -Force -Recurse",
        "Remove-Item \"$dir\\GitHub-Store\" -Force -Recurse"
    ],
    "bin": "Github-Store.exe",
    "shortcuts": [
        [
            "Github-Store.exe",
            "Github-Store"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/OpenHub-Store/GitHub-Store/releases",
        "jp": "$[0].assets[*].browser_download_url",
        "regex": "/releases/download/([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/OpenHub-Store/GitHub-Store/releases/download/$version/GitHub-Store-$version.msi"
            }
        }
    }
}
