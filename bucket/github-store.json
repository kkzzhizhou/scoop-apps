{
    "version": "1.8.1",
    "description": "A free, open-source app store for GitHub releases — browse, discover, and install apps with one click. Powered by Kotlin and Compose Multiplatform for Android & Desktop (Linux, MacOS, Windows).",
    "homepage": "https://www.github-store.org/",
    "license": {
        "identifier": "Apache-2.0 license",
        "url": "https://github.com/OpenHub-Store/GitHub-Store#Apache-2.0-1-ov-file"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/OpenHub-Store/GitHub-Store/releases/download/v1.8.1/GitHub-Store-1.8.1.msi",
            "hash": "2a8de8e4bcdc2f2055207a5ffea7d03abfa7ee903e925b2ba07c1b0af6fa5ab0"
        }
    },
    "innosetup": true,
    "pre_install": [
        "Copy-Item \"$dir\\GitHub-Store\\*\" \"$dir\" -Force -Recurse",
        "Remove-Item \"$dir\\GitHub-Store\" -Force -Recurse"
    ],
    "bin": "Github-Store.exe",
    "shortcuts": [
        [
            "Github-Store.exe",
            "Github-Store"
        ]
    ],
    "checkver": {
        "github": "https://api.github.com/repos/OpenHub-Store/GitHub-Store/releases",
        "jp": "$[0].assets[*].browser_download_url",
        "regex": "/releases/download/v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/OpenHub-Store/GitHub-Store/releases/download/v$version/GitHub-Store-$version.msi"
            }
        }
    }
}
