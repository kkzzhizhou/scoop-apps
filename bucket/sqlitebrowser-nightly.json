    "checkver": {
        "url": "https://api.github.com/repos/sqlitebrowser/sqlitebrowser/releases/tags/continuous",
        "script": [
            "$release = $page | ConvertFrom-Json",
            "$date = Get-Date $release.updated_at -Format 'yyyyMMdd'",
            "$page -match 'SQLite-dev-(?<commit>[0-9a-f]{7})-win-x64.zip' | Out-Null",
            "Write-Output \"$date-$($matches['commit'])\""
        ],
        "regex": "^(?<version>\\d{8}-(?<commit>[0-9a-f]{7}))$"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
