{
    "homepage": "https://www.yubsoft.com/imgdrive/",
    "description": "A lightweight virtual CD/DVD/Blu-ray drive that enables to emulate up all popular image types of CD, DVD and Blu-ray Discs to drives.",
    "license": "Freeware",
    "version": "2.2.9",
    "url": "https://download.yubsoft.com/imgdrive_2.2.9_portable.zip",
    "hash": "710716052e36d630ecc981df5d9db5f1086987bcb7efc723090768a072004d3d",
    "architecture": {
        "64bit": {
            "extract_dir": "imgdrive_x64"
        },
        "32bit": {
            "extract_dir": "imgdrive_x86"
        },
        "arm64": {
            "extract_dir": "imgdrive_arm64"
        }
    },
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\\imgdrive.ini\")) {",
        "    New-Item -Path \"$persist_dir\\imgdrive.ini\" -ItemType file | Out-Null",
        "}"
    ],
    "shortcuts": [
        [
            "imgdrive.exe",
            "ImgDrive"
        ]
    ],
    "bin": "imgdrive.exe",
    "persist": "imgdrive.ini",
    "checkver": {
        "regex": "imgdrive_([\\d.]+)_portable.zip"
    },
    "autoupdate": {
        "url": "https://download.yubsoft.com/imgdrive_$version_portable.zip"
    }
}
