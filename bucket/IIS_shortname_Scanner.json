    ],
    "bin": "IIS_shortname_Scanner.bat",
    "checkver": {
        "url": "https://api.github.com/repos/lijiejie/IIS_shortname_Scanner/commits",
        "regex": "([\\d-]+T)(\\d+):(\\d+):(\\d+)",
        "replace": "$1$2.$3.$4"
    },
