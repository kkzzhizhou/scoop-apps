{
    "version": "2026.1.5",
    "description": "UniGetUI: The Graphical Interface for your package managers. Could be terribly described as a package manager manager to manage your package managers",
    "homepage": "https://devolutions.net/unigetui/",
    "license": {
        "identifier": "MIT license",
        "url": "https://github.com/Devolutions/UniGetUI#MIT-1-ov-file"
    },
    "url": "https://github.com/Devolutions/UniGetUI/releases/download/v2026.1.5/UniGetUI.Installer.exe",
    "hash": "f7b0e1158644bcf94f4c9302f9454af300df1ccc188d98c6d1a9673d3afceb00",
    "innosetup": true,
    "pre_install": [
        "$Files = [string[]](",
        "    [System.IO.Path]::Combine($dir,'ForceUniGetUIPortable')",
        ")",
        "$Files.ForEach{",
        "    if (-not [System.IO.File]::Exists($_)) {",
        "        $null = [System.IO.File]::Create($_)",
        "    }",
        "}"
    ],
    "shortcuts": [
        [
            "UniGetUI.exe",
            "UniGetUI"
        ]
    ],
    "persist": [
        "ForceUniGetUIPortable",
        "Settings"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/Devolutions/UniGetUI/releases",
        "regex": "/releases/tag/v([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://github.com/Devolutions/UniGetUI/releases/download/v$version/UniGetUI.Installer.exe",
        "hash": {
            "url": "https://github.com/Devolutions/UniGetUI/releases/tag/$version",
            "regex": "sha256: <code>$sha256</code>"
        }
    }
}
