    "pre_install": [
        "function create($path, $type, $content) {",
        "   if (-not (Test-Path \"$path\")) {",
        "       New-Item \"$path\" -ItemType $type -Value $content | Out-Null",
        "       Write-Output \"Creating $path...\"",
        "   }",
        "}",
        "create $dir/user Directory"
    ],
    "persist": "user",
    "architecture": {
        "64bit": {
            "url": "https://github.com/azahar-emu/azahar/releases/download/2125.0.1/azahar-windows-msvc-2125.0.1.zip",
            "hash": "c8c56c58b7e7b7874199027d8fc6d511026e9f8bef32251dbd0776de861b5b72",
            "extract_dir": "azahar-windows-msvc-2125.0.1",
            "bin": [
                "azahar.exe",
                "azahar-room.exe"
            ],
            "shortcuts": [
                [
                    "azahar.exe",
                    "3DS"
                ]
            ]
        }
    },
    "checkver": {
        "github": "https://github.com/azahar-emu/azahar"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/azahar-emu/azahar/releases/download/$version/azahar-windows-msvc-$version.zip",
                "extract_dir": "azahar-windows-msvc-$version"
            }
        }
    }
