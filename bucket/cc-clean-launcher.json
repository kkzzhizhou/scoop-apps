    "pre_install": "Move-Item \"$dir/cc.ps1\" (New-Item -ItemType Directory \"$dir/bin\")",
    "env_add_path": "bin",
    "checkver": {
        "script": "try { Get-Date (Invoke-RestMethod 'https://api.github.com/repositories/353349806/commits?path=cc.ps1&per_page=1' -Headers $(if ($auth = Get-GitHubToken) { @{authorization=\"Bearer $auth\"} }))[0].commit.committer.date -UFormat %s } catch { '' }",
        "regex": "\\A(\\d+)\\Z"
    },
    "autoupdate": {
        "url": "https://raw.githubusercontent.com/brian6932/CC-Clean-Launcher/2023/cc.ps1"
    }
