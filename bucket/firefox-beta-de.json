{
    "version": "151.0b7",
    "description": "Beta builds of Firefox: the popular open source web browser.",
    "homepage": "https://www.mozilla.org/de-DE/firefox/beta/",
    "license": "MPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/151.0b7/win64/de-DE/Firefox%20Setup%20151.0b7.exe#/dl.7z",
            "hash": "sha512:d0cab77ef9bb12dcc7768028f194d059b85a5f4c1250fe1bb7be4fd0e10648a4981ec02048610a0f367e18e8963b74a4ef46dbc84d648fd915a5328a6bb40910"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/151.0b7/win32/de-DE/Firefox%20Setup%20151.0b7.exe#/dl.7z",
            "hash": "sha512:d0cab77ef9bb12dcc7768028f194d059b85a5f4c1250fe1bb7be4fd0e10648a4981ec02048610a0f367e18e8963b74a4ef46dbc84d648fd915a5328a6bb40910"
        }
    },
    "extract_dir": "core",
    "bin": [
        [
            "firefox.exe",
            "firefox-beta-de",
            "-profile \"$dir\\profile\""
        ]
    ],
    "shortcuts": [
        [
            "firefox.exe",
            "Firefox Beta (de)",
            "-profile \"$dir\\profile\""
        ]
    ],
    "persist": "profile",
    "checkver": {
        "url": "https://product-details.mozilla.org/1.0/firefox_versions.json",
        "jsonpath": "$.LATEST_FIREFOX_DEVEL_VERSION"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win64/de-DE/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64/de-DE/$basename"
                }
            },
            "32bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win32/de-DE/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win32/de-DE/$basename"
                }
            }
        }
    }
}
