{
    "version": "151.0b2",
    "description": "Beta builds of Firefox: the popular open source web browser.",
    "homepage": "https://www.mozilla.org/de-DE/firefox/beta/",
    "license": "MPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/151.0b2/win64/de-DE/Firefox%20Setup%20151.0b2.exe#/dl.7z",
            "hash": "sha512:a530755d9ef017fc3b1899c9feac3babdc1c9d569cc714166f7d2127b1151633f8fea40e4f3af0e6d7390f0f9555b03a07e4ed91b13e1dd4455de44ab7300d71"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/151.0b2/win32/de-DE/Firefox%20Setup%20151.0b2.exe#/dl.7z",
            "hash": "sha512:a530755d9ef017fc3b1899c9feac3babdc1c9d569cc714166f7d2127b1151633f8fea40e4f3af0e6d7390f0f9555b03a07e4ed91b13e1dd4455de44ab7300d71"
        }
    },
    "extract_dir": "core",
    "bin": [
        [
            "firefox.exe",
            "firefox-beta-de",
            "-profile \"$dir\\profile\""
        ]
    ],
    "shortcuts": [
        [
            "firefox.exe",
            "Firefox Beta (de)",
            "-profile \"$dir\\profile\""
        ]
    ],
    "persist": "profile",
    "checkver": {
        "url": "https://product-details.mozilla.org/1.0/firefox_versions.json",
        "jsonpath": "$.LATEST_FIREFOX_DEVEL_VERSION"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win64/de-DE/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64/de-DE/$basename"
                }
            },
            "32bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win32/de-DE/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win32/de-DE/$basename"
                }
            }
        }
    }
}
