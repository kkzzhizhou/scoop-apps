    "architecture": {
        "64bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/151.0b10/win64/de-DE/Firefox%20Setup%20151.0b10.exe#/dl.7z",
            "hash": "sha512:60365fcfa824219084408e719da60ea82acbec87332f5a40d621c49104bc32100550e2e2253708e8a31f1784b949101b7bf253fdcf7b03f70220356602b36c43"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/151.0b10/win32/de-DE/Firefox%20Setup%20151.0b10.exe#/dl.7z",
            "hash": "sha512:60365fcfa824219084408e719da60ea82acbec87332f5a40d621c49104bc32100550e2e2253708e8a31f1784b949101b7bf253fdcf7b03f70220356602b36c43"
        }
    },
    "extract_dir": "core",
    "bin": [
        [
            "firefox.exe",
            "firefox-beta-de",
            "-profile \"$dir\\profile\""
        ]
    ],
    "shortcuts": [
        [
            "firefox.exe",
            "Firefox Beta (de)",
            "-profile \"$dir\\profile\""
        ]
    ],
    "persist": "profile",
    "checkver": {
        "url": "https://product-details.mozilla.org/1.0/firefox_versions.json",
        "jsonpath": "$.LATEST_FIREFOX_DEVEL_VERSION"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win64/de-DE/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64/de-DE/$basename"
                }
            },
            "32bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win32/de-DE/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win32/de-DE/$basename"
                }
            }
        }
    }
}
