{
    "version": "153.0b10",
    "description": "Beta builds of Firefox: the popular open source web browser.",
    "homepage": "https://www.mozilla.org/de-DE/firefox/beta/",
    "license": "MPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/153.0b10/win64/de-DE/Firefox%20Setup%20153.0b10.exe#/dl.7z",
            "hash": "sha512:326d4e6b6ded492b55f7e092d276dfa2830c5ebfaaf63145cced32a1be13e622f606064cefc4ee0ba527027836c7fb5124f42ee103165e32bbb5218d0a12c8d1"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/153.0b10/win32/de-DE/Firefox%20Setup%20153.0b10.exe#/dl.7z",
            "hash": "sha512:326d4e6b6ded492b55f7e092d276dfa2830c5ebfaaf63145cced32a1be13e622f606064cefc4ee0ba527027836c7fb5124f42ee103165e32bbb5218d0a12c8d1"
        }
    },
    "extract_dir": "core",
    "bin": [
        [
            "firefox.exe",
            "firefox-beta-de",
            "-profile \"$dir\\profile\""
        ]
    ],
    "shortcuts": [
        [
            "firefox.exe",
            "Firefox Beta (de)",
            "-profile \"$dir\\profile\""
        ]
    ],
    "persist": "profile",
    "checkver": {
        "url": "https://product-details.mozilla.org/1.0/firefox_versions.json",
        "jsonpath": "$.LATEST_FIREFOX_DEVEL_VERSION"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win64/de-DE/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64/de-DE/$basename"
                }
            },
            "32bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win32/de-DE/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win32/de-DE/$basename"
                }
            }
        }
    }
}
