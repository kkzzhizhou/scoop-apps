{
    "homepage": "https://opencc.byvoid.com/",
    "description": "Open Chinese Convert Command Line Tool.",
    "version": "1.4.1",
    "license": "APL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/BYVoid/OpenCC/releases/download/ver.1.4.1/OpenCC-1.4.1-windows-x64-portable.zip",
            "hash": "b686b0ecc3723120e214bab4158dd7b6e784975a312ba18d74f782af77596742"
        },
        "32bit": {
            "url": "https://ci.appveyor.com/api/projects/Carbo/opencc/artifacts/OpenCC.zip?branch=master&job=Environment:%20nodejs_version=none;%20Platform:%20x86",
            "hash": ""
        }
    },
    "extract_dir": "build",
    "bin": [
        "bin\\opencc.exe",
        "bin\\opencc_dict.exe"
    ],
    "checkver": {
        "url": "https://github.com/BYVoid/OpenCC/releases/latest",
        "regex": "/releases/tag/ver.([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/BYVoid/OpenCC/releases/download/ver.$version/OpenCC-$version-windows-x64-portable.zip",
                "hash": {
                    "url": "$url.sha256"
                }
            }
        }
    }
}
