        },
        "64bit": {
            "url": "https://file-assets.apifox.com/download/2.8.33/Apifox-2.8.33.exe#/dl.7z",
            "hash": "58491bd1327fb8fa685067dac2da2f85bedff70ab990c8a35b207155ff13b5d2"
