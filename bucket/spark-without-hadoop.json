{
    "version": "4.1.2",
    "description": "A unified analytics engine for large-scale data processing.",
    "homepage": "https://spark.apache.org/",
    "license": "Apache-2.0",
    "suggest": {
        "JDK": "java/openjdk"
    },
    "url": "https://archive.apache.org/dist/spark/spark-4.1.2/spark-4.1.2-bin-without-hadoop.tgz",
    "hash": "sha512:1ebf249ed110ac2b4f567d4571f27b94f19ead5684c8eaa6df75e0e61dfc63cbf40a502d32c2ec2d0daf527bc274ba7b0843baa93dd7dcefcbe6b3ddc672624b",
    "extract_dir": "spark-4.1.2-bin-without-hadoop",
    "env_add_path": "bin",
    "env_set": {
        "SPARK_HOME": "$dir"
    },
    "persist": "conf",
    "checkver": {
        "url": "https://spark.apache.org/js/downloads.js",
        "regex": "addRelease\\(\"([\\d.]+)\","
    },
    "autoupdate": {
        "url": "https://archive.apache.org/dist/spark/spark-$version/spark-$version-bin-without-hadoop.tgz",
        "hash": {
            "url": "$url.sha512",
            "regex": "$basename: ([A-F0-9\\s]+)$"
        },
        "extract_dir": "spark-$version-bin-without-hadoop"
    }
}
