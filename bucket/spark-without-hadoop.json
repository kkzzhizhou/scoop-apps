{
    "version": "4.2.0",
    "description": "A unified analytics engine for large-scale data processing.",
    "homepage": "https://spark.apache.org/",
    "license": "Apache-2.0",
    "suggest": {
        "JDK": "java/openjdk"
    },
    "url": "https://archive.apache.org/dist/spark/spark-4.2.0/spark-4.2.0-bin-without-hadoop.tgz",
    "hash": "sha512:da791f5587f402a1c4385e864c67f388f095c4a19e8eb4eb5e5663867f09dd4877e945cadd6e47fd7d7d42a532afdf61dd32c91bf8e86e3cbcdb039ff17a07b0",
    "extract_dir": "spark-4.2.0-bin-without-hadoop",
    "env_add_path": "bin",
    "env_set": {
        "SPARK_HOME": "$dir"
    },
    "persist": "conf",
    "checkver": {
        "url": "https://spark.apache.org/js/downloads.js",
        "regex": "addRelease\\(\"([\\d.]+)\","
    },
    "autoupdate": {
        "url": "https://archive.apache.org/dist/spark/spark-$version/spark-$version-bin-without-hadoop.tgz",
        "hash": {
            "url": "$url.sha512",
            "regex": "$basename: ([A-F0-9\\s]+)$"
        },
        "extract_dir": "spark-$version-bin-without-hadoop"
    }
}
