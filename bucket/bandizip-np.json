            "hash": "bbe80322264a7a63530068b89621542a4809912c8ea77bc14c7c81b6ff75f357"
        },
        "32bit": {
            "url": "https://bandisoft.app/bandizip/BANDIZIP-SETUP-STD-ALL.EXE",
            "hash": "0c563f4b742e8ecd5ff9dc877db0b5ab3a60c209ae93f13a177de0cd92518083"
        },
        "arm64": {
            "url": "https://bandisoft.app/bandizip/BANDIZIP-SETUP-STD-ALL.EXE",
            "hash": "0c563f4b742e8ecd5ff9dc877db0b5ab3a60c209ae93f13a177de0cd92518083"
        }
    },
    "pre_install": [
        "if ($env:PROCESSOR_ARCHITECTURE -eq 'ARM64' -or $env:PROCESSOR_ARCHITEW6432 -eq 'ARM64') {",
        "    $src = 'Bandizip.a64.exe'",
        "} elseif ($env:PROCESSOR_ARCHITECTURE -eq 'AMD64' -or $env:PROCESSOR_ARCHITEW6432 -eq 'AMD64') {",
        "    $src = 'Bandizip.x64.exe'",
        "} else {",
        "    $src = 'Bandizip.x86.exe'",
        "}",
        "if (Test-Path \"$dir\\$src\") {",
        "    Remove-Item \"$dir\\Bandizip.exe\" -ErrorAction SilentlyContinue",
        "    Rename-Item \"$dir\\$src\" 'Bandizip.exe'",
        "} else {",
        "    Write-Host \"No $src found in $dir; skipping rename.\"",
        "}"
    ],
    "installer": {
        "script": [
            "Get-ChildItem \"$dir\\Bandizip.*.exe\" | Remove-Item",
            "if (!(Test-Path \"$persist_dir\\Bandizip.ini\")) { New-Item \"$dir\\Bandizip.ini\" | Out-Null }"
        ]
    },
    "post_install": [
        "if ((Get-CimInstance Win32_OperatingSystem).Version -ge '10.0.22000'){",
        "    Start-Process -FilePath \"$dir\\data\\RegPackage.x86.exe\" -ArgumentList '/reg \"$dir\\data\\bzshell.x64.msix\"' -Wait",
        "}"
    ],
    "bin": "Bandizip.exe",
    "shortcuts": [
        [
            "Bandizip.exe",
            "Bandizip"
        ]
    ],
    "persist": "Bandizip.ini",
    "checkver": {
        "url": "https://en.bandisoft.com/bandizip/history/",
        "regex": "class=\"cell1\">v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://bandisoft.app/bandizip/BANDIZIP-SETUP-STD-X64.EXE"
            },
            "32bit": {
                "url": "https://bandisoft.app/bandizip/BANDIZIP-SETUP-STD-ALL.EXE"
            },
            "arm64": {
                "url": "https://bandisoft.app/bandizip/BANDIZIP-SETUP-STD-ALL.EXE"
            }
        },
        "hash": {
            "mode": "download"
        }
    }
}
