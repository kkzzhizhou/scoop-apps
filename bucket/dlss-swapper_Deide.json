            "url": "https://github.com/beeradmoore/dlss-swapper/releases/download/v1.2.5.0/DLSS.Swapper-1.2.5.0-portable.zip",
            "hash": "6c99353e32ed7e555e95963d124308d3bf2d36b83b30dabb922640610becf14a",
            "bin": "DLSS Swapper.exe",
            "shortcuts": [
                [
                    "DLSS Swapper.exe",
                    "DLSS Swapper"
                ]
            ],
            "pre_install": [
                "function create($path, $type, $content) {",
                "   if (-not (Test-Path \"$path\")) {",
                "       New-Item \"$path\" -ItemType $type -Value $content | Out-Null",
                "       Write-Output \"Creating $path...\"",
                "   }",
                "}"
            ]
        }
    },
