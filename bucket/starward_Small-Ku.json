{
	"version": "0.16.4",
	"description": "Game Launcher for miHoYo/hoyoverse.",
	"homepage": "https://github.com/Scighost/Starward",
	"license": {
		"identifier": "MIT",
		"url": "https://github.com/Scighost/Starward/blob/main/LICENSE"
	},
	"architecture": {
		"64bit": {
			"url": "https://github.com/Scighost/Starward/releases/download/0.16.4/Starward_Portable_0.16.4_x64.7z",
			"hash": "ee2debd31802070e2491629ff88641c0738c405cd4a6a85fc4d87bf33452eb9f"
		},
		"arm64": {
			"url": "https://github.com/Scighost/Starward/releases/download/0.16.4/Starward_Portable_0.16.4_arm64.7z",
			"hash": "235a13fd6ecffd58d72b1002e00f609ee7f075ce1788be789bd297f3a254903d"
		}
	},
	"checkver": {
		"script": [
			"$rel_info = Invoke-RestMethod -Uri 'https://api.github.com/repos/Scighost/Starward/releases'",
			"$latest = $rel_info | Sort-Object {$_.published_at} | Select-Object -last 1",
			"$latest_x64 = $latest.assets | Where-Object {$_.name.EndsWith('x64.7z')} | Select-Object -first 1",
			"$latest_arm64 = $latest.assets | Where-Object {$_.name.EndsWith('arm64.7z')} | Select-Object -first 1",
			"Write-Output $latest.tag_name $latest_x64.digest $latest_arm64.digest"
		],
		"regex": "(?<version>[\\d.]+(?:-[\\w\\-\\d\\.]+)?)\\s(?<x64hash>[^\\s]+)?\\s(?<armhash>[^\\s]+)?"
	},
	"autoupdate": {
		"architecture": {
			"64bit": {
				"url": "https://github.com/Scighost/Starward/releases/download/$version/Starward_Portable_$version_x64.7z",
				"hash": "$matchX64hash"
			},
			"arm64": {
				"url": "https://github.com/Scighost/Starward/releases/download/$version/Starward_Portable_$version_arm64.7z",
				"hash": "$matchArmhash"
			}
		}
	},
	"extract_dir": "Starward",
	"shortcuts": [["Starward.exe", "Starward"]],
	"pre_install": "If (-not (Test-Path $dir\\config.ini)) {\"UserDataFolder=$dir\\data\" | Out-File $dir\\config.ini}",
	"persist": ["data", "config.ini"],
	"notes": "Setup wizard would be skipped because of preset value of user data by pre-install scripts."
}
