{
    "version": "1.3.2477",
    "description": "A local document search application",
    "homepage": "https://anytxt.net/",
    "license": "GPL-3.0-or-later",
    "architecture": {
        "64bit": {
            "url": "https://sourceforge.net/projects/anytxt/files/Anytxt_1.3.2477_Windows_X86_64.exe",
            "hash": "sha1:a156dbe6b77ebbbfe5dbc30441b7b8ecae05b1fd",
            "pre_install": [
                "Get-ChildItem \"$dir\\*,2.*\" -Recurse | Rename-Item -NewName { $_.FullName -replace ',2\\.', '.' }",
                "Get-ChildItem \"$dir\\*,1.*\" -Recurse | Remove-Item"
            ]
        },
        "32bit": {
            "url": "https://sourceforge.net/projects/anytxt/files/Anytxt_1.3.2477_Windows_X86_32.exe",
            "hash": "sha1:b2f7bfc0a3306dfcc96f0693f49dc21712c1a773",
            "pre_install": [
                "Get-ChildItem \"$dir\\*,1.*\" -Recurse | Rename-Item -NewName { $_.FullName -replace ',1\\.', '.' }",
                "Get-ChildItem \"$dir\\*,2.*\" -Recurse | Remove-Item"
            ]
        }
    },
    "innosetup": true,
    "bin": "ATGUI.exe",
    "shortcuts": [
        [
            "ATGUI.exe",
            "AnyTXT Searcher"
        ]
    ],
    "checkver": {
        "url": "https://anytxt.net/download/",
        "regex": "AnyTXT_Searcher\\.([\\d.]+)_Windows_X86_64\\.exe"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://sourceforge.net/projects/anytxt/files/AnyTXT_Searcher.$version_Windows_X86_64.exe"
            },
            "32bit": {
                "url": "https://sourceforge.net/projects/anytxt/files/AnyTXT_Searcher.$version_Windows_X86_32.exe"
            }
        },
        "hash": {
            "mode": "sourceforge"
        }
    }
}
