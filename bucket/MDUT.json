{
    "version": "3.1.0",
    "description": "MDUT - Multiple Database Utilization Tools",
    "homepage": "https://github.com/SafeGroceryStore/MDUT",
    "license": "UNKNOWN",
    "suggest": {
        "JRE": [
            "sec/oraclejre8"
        ]
    },
    "url": "https://github.com/SafeGroceryStore/MDUT/releases/download/v3.1.0/v3.1.0_Multiple_Database_Utilization_Tools_windows_amd64.zip",
    "hash": "sha256:43b8e941fb95998e0f0d2840a3c2e118a002c9b612cced631b4a0eeb4557e8dc",
    "pre_install": [
        "Get-ChildItem \"$dir\" '*_Multiple_Database_Utilization_Tools_*.jar' | Select-Object -First 1 | Rename-Item -NewName 'Multiple.Database.Utilization.Tools.jar'",
        "Set-Content \"$dir\\MDUT.bat\" '@pushd %~dp0",
        "@call oraclejre8",
        "@start javaw.exe -jar \"Multiple.Database.Utilization.Tools.jar\" %*",
        "@popd' -Encoding Ascii"
    ],
    "bin": "MDUT.bat",
    "shortcuts": [
        [
            "MDUT.bat",
            "MDUT"
        ]
    ],
    "persist": [
        "data.db",
        "config.yaml"
    ],
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/SafeGroceryStore/MDUT/releases/download/v$version/v$version_Multiple_Database_Utilization_Tools_windows_amd64.zip"
    },
    "notes": [
        "【工具类型】: 数据库工具",
        "【主要功能】: 多数据库利用工具，支持多种数据库的安全测试和操作",
        "【适用场景】: 数据库安全测试、渗透测试、安全审计",
        "【技术特点】: 基于Java开发，支持多种数据库协议，提供图形化界面"
    ]
}
