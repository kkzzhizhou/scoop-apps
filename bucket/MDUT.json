    "pre_install": [
        "Get-ChildItem \"$dir\" '*_Multiple_Database_Utilization_Tools_*.jar' | Select-Object -First 1 | Rename-Item -NewName 'Multiple.Database.Utilization.Tools.jar'",
        "Set-Content \"$dir\\MDUT.bat\" '@pushd %~dp0",
        "@call oraclejre8",
        "@start javaw.exe -jar \"Multiple.Database.Utilization.Tools.jar\" %*",
        "@popd' -Encoding Ascii"
