{
    "version": "2.1.0",
    "description": "The Syncthing relay server",
    "homepage": "https://syncthing.net/",
    "license": "MPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/syncthing/relaysrv/releases/download/v2.1.0/strelaysrv-windows-amd64-v2.1.0.zip",
            "hash": "c473fe9d908610f4f9f1e1222fcfc92c88b18abff772d03ea61dfaa9fe2e1d69",
            "extract_dir": "strelaysrv-windows-amd64-v2.1.0"
        },
        "32bit": {
            "url": "https://github.com/syncthing/relaysrv/releases/download/v2.1.0/strelaysrv-windows-386-v2.1.0.zip",
            "hash": "a1cc67ba57765f09f3badf1024f34c3a6f412f7c3806371da5945394684c9d30",
            "extract_dir": "strelaysrv-windows-386-v2.1.0"
        }
    },
    "bin": [
        [
            "strelaysrv.exe",
            "strelaysrv",
            "-keys \"$dir\""
        ]
    ],
    "persist": [
        "cert.pem",
        "key.pem"
    ],
    "pre_install": [
        "foreach ($name in @('cert.pem', 'key.pem')) {",
        "    if (!(Test-Path \"$persist_dir\\$name\")) {",
        "        New-Item -Force -Path \"$dir\" -Name $name | Out-Null",
        "    }",
        "}"
    ],
    "checkver": {
        "github": "https://github.com/syncthing/relaysrv"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/syncthing/relaysrv/releases/download/v$version/strelaysrv-windows-amd64-v$version.zip",
                "extract_dir": "strelaysrv-windows-amd64-v$version"
            },
            "32bit": {
                "url": "https://github.com/syncthing/relaysrv/releases/download/v$version/strelaysrv-windows-386-v$version.zip",
                "extract_dir": "strelaysrv-windows-386-v$version"
            }
        }
    }
}
