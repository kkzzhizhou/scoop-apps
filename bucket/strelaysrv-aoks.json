{
    "version": "2.1.1",
    "description": "The Syncthing relay server",
    "homepage": "https://syncthing.net/",
    "license": "MPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/syncthing/relaysrv/releases/download/v2.1.1/strelaysrv-windows-amd64-v2.1.1.zip",
            "hash": "657b89a33c329c7046513c4bee28f22cca833ae67116e232609349577ba55be2",
            "extract_dir": "strelaysrv-windows-amd64-v2.1.1"
        },
        "32bit": {
            "url": "https://github.com/syncthing/relaysrv/releases/download/v2.1.1/strelaysrv-windows-386-v2.1.1.zip",
            "hash": "2b150e38238cdf8ce1e9342f0732b40b0269d21ef0b5b9fb578dd78f24a19b8a",
            "extract_dir": "strelaysrv-windows-386-v2.1.1"
        }
    },
    "bin": [
        [
            "strelaysrv.exe",
            "strelaysrv",
            "-keys \"$dir\""
        ]
    ],
    "persist": [
        "cert.pem",
        "key.pem"
    ],
    "pre_install": [
        "foreach ($name in @('cert.pem', 'key.pem')) {",
        "    if (!(Test-Path \"$persist_dir\\$name\")) {",
        "        New-Item -Force -Path \"$dir\" -Name $name | Out-Null",
        "    }",
        "}"
    ],
    "checkver": {
        "github": "https://github.com/syncthing/relaysrv"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/syncthing/relaysrv/releases/download/v$version/strelaysrv-windows-amd64-v$version.zip",
                "extract_dir": "strelaysrv-windows-amd64-v$version"
            },
            "32bit": {
                "url": "https://github.com/syncthing/relaysrv/releases/download/v$version/strelaysrv-windows-386-v$version.zip",
                "extract_dir": "strelaysrv-windows-386-v$version"
            }
        }
    }
}
