{
    "version": "1.0.0",
    "description": "A PC port of Mario Kart 64",
    "homepage": "https://github.com/HarbourMasters/SpaghettiKart",
    "license": "Unlicense",
    "notes": [
        "ATTENTION: SpaghettiKart requires specific n64 rom(s) of Mario Kart 64 to function.",
        "Place the rom(s) in $persist_dir.",
        "Learn more at https://github.com/HarbourMasters/SpaghettiKart?tab=readme-ov-file#quick-start"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/HarbourMasters/SpaghettiKart/releases/download/1.0.0/spaghetti-windows.zip",
            "hash": "bf7bd7cdb5f412c7b370af92949B9431CE7503968631F8CACD607933FB32AFF3"
        }
    },
    "pre_install": [
        "$files = @('spaghettify.cfg.json', 'default.sav', 'imgui.ini')",
        "foreach ($file in $files) {",
        "    if (!(Test-Path \"$persist_dir\\$file\")) {",
        "        New-Item -ItemType File -ErrorAction SilentlyContinue \"$dir\\$file\" | Out-Null",
        "    }",
        "}"
    ],
    "post_install": [
        "$files = @('spaghettify.cfg.json', 'default.sav', 'imgui.ini')",
        "foreach ($file in $files) {",
        "    if (Test-Path \"$persist_dir\\$file.bak\") {",
        "        Copy-Item -Force \"$persist_dir\\$file.bak\" \"$dir\\$file\"",
        "    } else {",
        "        New-Item -ErrorAction SilentlyContinue -ItemType File \"$dir\\$file\" | Out-Null",
        "    }",
        "}"
    ],
    "bin": "Spaghettify.exe",
    "shortcuts": [
        [
            "Spaghettify.exe",
            "Mario Kart 64 [n64][mk64]"
        ]
    ],
    "persist": [
        "mods",
        "Save",
        "spaghettify.cfg.json",
        "default.sav",
        "imgui.ini"
    ],
    "uninstaller": {
        "script": [
            "$files = @('spaghettify.cfg.json', 'default.sav', 'imgui.ini')",
            "foreach ($file in $files) {",
            "    Copy-Item -Force \"$dir\\$file\" \"$persist_dir\\$file.bak\"",
            "}"
        ]
    },
    "checkver": {
        "github": "https://github.com/HarbourMasters/SpaghettiKart"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/HarbourMasters/SpaghettiKart/releases/download/$version/spaghetti-windows.zip"
            }
        }
    }
}
