{
    "version": "1.0.1390",
    "description": "ServerBox - server status & toolbox",
    "homepage": "https://serverbox.lpkt.cn/",
    "license": {
        "identifier": "GPL-3.0 license",
        "url": "https://github.com/lollipopkit/flutter_server_box#GPL-3.0-1-ov-file"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/lollipopkit/flutter_server_box/releases/download/v1.0.1390/ServerBox_v1.0.1390_windows_amd64.zip",
            "hash": "3287a7faf74004a391839460521ce6d74272fde9bab124900bfcd80dc37cebc5"
        }
    },
    "installer": {
        "script": [
            "# handle runtime cache",
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\appdata\" -Target \"$env:APPDATA\\userdata\\ServerBox\"",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\appdata\" -Target \"$env:APPDATA\\appdata\\tech.lolli\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "uninstaller": {
        "script": [
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\userdata\\ServerBox\"",
            "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\appdata\\tech.lolli\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "bin": "ServerBox.exe",
    "shortcuts": [
        [
            "ServerBox.exe",
            "ServerBox"
        ]
    ],
    "checkver": {
        "github": "https://api.github.com/repos/lollipopkit/flutter_server_box/releases",
        "jp": "$[0].assets[*].browser_download_url",
        "regex": "/releases/download/v([\\d.]+)/ServerBox_v([\\d.]+)_windows_amd64\\.zip"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/lollipopkit/flutter_server_box/releases/download/v$version/ServerBox_v$version_windows_amd64.zip"
            }
        }
    }
}
