{
    "version": "149.0.2",
    "description": "Firefox. Popular open source web browser.",
    "homepage": "https://www.mozilla.org/firefox/",
    "license": "MPL-2.0",
    "changelog": "https://www.mozilla.org/en-US/firefox/149.0.2/releasenotes/",
    "architecture": {
        "64bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/149.0.2/win64/en-US/Firefox%20Setup%20149.0.2.exe#/setup.exe",
            "hash": "sha512:fd0ea2b5e85800fa17d3803506a4a83405ccf06559beb275f7be1b6acfa4996358c9f36c7e34b57686ca5e804c6ab839969d153186dbd7370de2611316c45e24"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/149.0.2/win32/en-US/Firefox%20Setup%20149.0.2.exe#/setup.exe",
            "hash": "sha512:3f0c61087c262354e7a01aed69fbbccff72c7cf27bc7c8b2e474567f62b99284258707f8c6ce2b6afe230f1053dd43a18c8c2fede0ffb7a33e8954383dfc1bb2"
        }
    },
    "pre_download": "Assert-Administrator",
    "installer": {
        "script": [
            "$programname = \"Mozilla Firefox*\"",
            "$ProgramFiles = [Environment]::GetFolderPath(\"ProgramFiles\")",
            "$filepath = \"$ProgramFiles\\Mozilla Firefox\\firefox.exe\"",
            "if(((Test-Path -Path $filepath -PathType Leaf) -eq $false) -or ((Get-Command $filepath).Version -lt [System.Version]\"$version\"))",
            "{",
            "   &\"$dir\\setup.exe\" -ms | Out-Null",
            "   if(((Test-Path -Path $filepath -PathType Leaf) -eq $false) -or ((Get-Command $filepath).Version -lt [System.Version]\"$version\"))",
            "   {",
            "       exit 1",
            "   }",
            "}",
            "Remove-Item \"$dir\\setup.exe\" -Force"
        ]
    },
    "post_install": [
        "$CommonDesktopPath = [Environment]::GetFolderPath(\"CommonDesktopDirectory\")",
        "if (Test-Path \"$CommonDesktopPath\\Firefox.lnk\") {Remove-Item \"$CommonDesktopPath\\Firefox.lnk\" -Force}"
    ],
    "checkver": {
        "url": "https://www.mozilla.org/en-US/firefox/notes/",
        "regex": "\" data-latest-firefox=\"([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win64/en-US/Firefox%20Setup%20$version.exe#/setup.exe",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64/en-US/$basename"
                }
            },
            "32bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win32/en-US/Firefox%20Setup%20$version.exe#/setup.exe",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win32/en-US/$basename"
                }
            }
        },
        "changelog": "https://www.mozilla.org/en-US/firefox/$version/releasenotes/"
    }
}
