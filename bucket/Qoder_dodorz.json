{
    "version":  "1.6.0",
    "description":  "Agentic Coding Platform",
    "homepage":  "https://qoder.com/",
    "license":  "Proprietary",
    "architecture":  {
                         "64bit":  {
                                       "url":  "https://download.qoder.com/release/latest/QoderUserSetup-x64.exe",
                                       "hash":  "8f33309161394cd4a218b8bd3c900f695464562ecb0c627c6afb72edf8b071c0",
                                       "extract_dir":  "{code_GetDestDir}"
                                   }
                     },
    "innosetup":  true,
    "post_install":  [
                         "if (!(Test-Path \"$dir\\data\\extensions\") -and (Test-Path \"$env:USERPROFILE\\.qoder\\extensions\")) {",
                         "    info \u0027[Portable Mode] Copying extensions...\u0027",
                         "    Copy-Item \"$env:USERPROFILE\\.qoder\\extensions\" \"$dir\\data\" -Recurse",
                         "}",
                         "if (!(Test-Path \"$dir\\data\\user-data\") -and (Test-Path \"$env:AppData\\Qoder\")) {",
                         "    info \u0027[Portable Mode] Copying user data...\u0027",
                         "    Copy-Item \"$env:AppData\\Qoder\" \"$dir\\data\\user-data\" -Recurse",
                         "}",
                         "$extensions_file = \"$dir\\data\\extensions\\extensions.json\"",
                         "if ((Test-Path \"$extensions_file\")) {",
                         "    info \u0027Adjusting path in extensions file...\u0027",
                         "    (Get-Content \"$extensions_file\") -replace \u0027(?\u003c=qoder(/|\\\\\\\\)).*?(?=(/|\\\\\\\\)data(/|\\\\\\\\)extensions)\u0027, $version | Set-Content \"$extensions_file\"",
                         "}"
                     ],
    "bin":  [
                [
                    "bin/qoder.cmd",
                    "qoder",
                    "--user-data-dir=\"$dir\\data\\user-data\" --extensions-dir=\"$dir\\data\\extensions\""
                ]
            ],
    "shortcuts":  [
                      [
                          "Qoder.exe",
                          "Qoder",
                          "--user-data-dir=\"$dir\\data\\user-data\" --extensions-dir=\"$dir\\data\\extensions\""
                      ]
                  ],
    "persist":  "data",
    "autoupdate":  {
                       "architecture":  {
                                            "64bit":  {
                                                          "url":  "https://download.qoder.com/release/latest/QoderUserSetup-x64.exe"
                                                      }
                                        }
                   }
}
