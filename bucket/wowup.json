    "url": "https://github.com/WowUp/WowUp/releases/download/v2.23.0/WowUp-Setup-2.23.0.exe#/dl.7z",
    "hash": "sha512:edb9fd1d773febb468d7686e871120798b26ddbd37b4d617cbfdae4fa4adbb0662931ebcb951e36f872eb19502b6acca6282ebd07788a6fb00652f2a683854b2",
    "extract_dir": "$PLUGINSDIR",
    "installer": {
        "script": [
            "Remove-Item \"$dir\\*\" -Exclude 'app-64.7z'",
            "Expand-7zipArchive \"$dir\\app-64.7z\" \"$dir\" -Removal"
        ]
    },
    "shortcuts": [
        [
            "WowUp.exe",
            "WowUp"
        ]
    ],
    "checkver": {
        "github": "https://github.com/WowUp/WowUp"
    },
    "autoupdate": {
        "url": "https://github.com/WowUp/WowUp/releases/download/v$version/WowUp-Setup-$version.exe#/dl.7z",
        "hash": {
            "url": "$baseurl/latest.yml",
            "find": "sha512:\\s+(.*)"
        }
    }
}
