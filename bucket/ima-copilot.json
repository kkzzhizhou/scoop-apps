{
    "version": "143.0.7499.4339",
    "homepage": "https://ima.qq.com/",
    "license": "Freeware",
    "url": "https://app-dl.ima.qq.com/win/2.4.7_4145/ima.copilot_win_x64_1018_2.4.7_4145.exe#/dl.7z",
    "hash": "5892d6ed99dc5bc0e473bfd9767ef2db2a0677bffbfe94bc2d11191f9abd0676",
    "pre_install": [
        "Expand-7zipArchive \"$dir\\chrome.7z\" \"$dir\"",
        "Move-Item \"$dir\\Chrome-bin\\*\" \"$dir\""
    ],
    "post_install": [
        "Remove-Item \"$dir\\chrome.7z\" -Force -Recurse",
        "Remove-Item \"$dir\\Chrome-bin\" -Force -Recurse"
    ],
    "shortcuts": [
        [
            "ima.copilot.exe",
            "ima"
        ]
    ],
    "checkver": {
        "script": [
            ". \"$pwd\\bin\\utils.ps1\"",
            "$dl_info = get_installer_info 'Tencent/ima-copilot'",
            "\"ver:$($dl_info.PackageVersion);\"",
            "\"x64:$($dl_info.x64_exe.InstallerUrl);\""
        ],
        "regex": "ver:(?<version>.+?); x64:(?<x64>.+?);"
    },
    "autoupdate": {
        "url": "$matchX64#/dl.7z",
        "hash": {
            "url": "https://raw.githubusercontent.com/microsoft/winget-pkgs/master/manifests/t/Tencent/ima-copilot/$version/Tencent.ima-copilot.installer.yaml",
            "regex": "Architecture: x64[\\s\\S]+?InstallerSha256:\\s?(.+)"
        }
    }
}
