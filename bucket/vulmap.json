{
    "version": "0.9",
    "description": "Vulmap 是一款 web 漏洞扫描和验证工具, 可对 webapps 进行漏洞扫描, 并且具备漏洞验证功能",
    "notes": [
        "【工具类型】: 安全测试工具",
        "【主要功能】: Web漏洞扫描与验证工具，支持多种漏洞类型的检测和验证",
        "【适用场景】: Web安全测试、漏洞挖掘、渗透测试",
        "【技术特点】: Python开发，命令行工具，支持POC验证"
    ],
    "homepage": "https://github.com/zhzyker/vulmap",
    "license": "unknow",
    "suggest": {
        "python": "uv"
    },
    "url": "https://github.com/zhzyker/vulmap/archive/refs/tags/v0.9.zip",
    "hash": "0d88f770e1e39cdcf26635ee3f3f00a352c667c8aadc678ff7070bb19f313c7c",
    "extract_dir": "vulmap-0.9",
    "pre_install": [
        "Set-Content \"$dir\\vulmap.bat\" '@pushd %~dp0",
        "@uv run python \"vulmap.py\" %*",
        "@popd' -Encoding Ascii"
    ],
    "post_install": [
        "uv venv \"$dir\\.venv\"",
        "uv pip install -r $dir\\requirements.txt --python \"$dir\\.venv\\Scripts\\python.exe\""
    ],
    "bin": "vulmap.bat",
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/zhzyker/vulmap/archive/refs/tags/v$version.zip",
        "extract_dir": "vulmap-$version"
    }
}
