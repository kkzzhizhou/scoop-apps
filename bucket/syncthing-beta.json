{
    "version": "2.1.2-rc.1",
    "description": "Open Source Continuous File Synchronization.",
    "homepage": "https://syncthing.net/",
    "license": {
        "identifier": "MPL-2.0 license",
        "url": "https://github.com/syncthing/syncthing#MPL-2.0-1-ov-file"
    },
    "notes": "To start syncthing automatically, use a method described at https://docs.syncthing.net/users/autostart.html#windows",
    "architecture": {
        "64bit": {
            "url": "https://github.com/syncthing/syncthing/releases/download/v2.1.2-rc.1/syncthing-windows-amd64-v2.1.2-rc.1.zip",
            "hash": "d91afae2e670533eb508ca0a2d63f2a6e83f78d2c4bc5a6240c568ff4ecf388b",
            "extract_dir": "syncthing-windows-amd64-v2.1.2-rc.1"
        },
        "32bit": {
            "url": "https://github.com/syncthing/syncthing/releases/download/v2.1.2-rc.1/syncthing-windows-386-v2.1.2-rc.1.zip",
            "hash": "8cdcefc863ecfb47b6223226071b5146998feadc849402b3d41fc505cd5b1090",
            "extract_dir": "syncthing-windows-386-v2.1.2-rc.1"
        },
        "arm64": {
            "url": "https://github.com/syncthing/syncthing/releases/download/v2.1.2-rc.1/syncthing-windows-arm64-v2.1.2-rc.1.zip",
            "hash": "ae4a8e2dd777ea0596513e85f9c85abf8d988ecfb5a515212a3599594b48f082",
            "extract_dir": "syncthing-windows-arm64-v2.1.2-rc.1"
        }
    },
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\\config\") -and (Test-Path \"$env:LOCALAPPDATA\\Syncthing\")) {",
        "    info \"Copying old '$env:LOCALAPPDATA\\Syncthing' to '$persist_dir\\config'\"",
        "    ensure \"$dir\\config\" | Out-Null",
        "    Copy-Item \"$env:LOCALAPPDATA\\Syncthing\\*\" \"$dir\\config\" -Exclude 'LOCK' -Recurse -Force",
        "}"
    ],
    "bin": [
        [
            "syncthing.exe",
            "syncthing",
            "-home \"$dir\\config\""
        ]
    ],
    "persist": "config",
    "checkver": {
        "github": "https://api.github.com/repos/syncthing/syncthing/releases",
        "jp": "$[*].tag_name",
        "regex": "v(([\\d.]+)-([\\w.]+))"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/syncthing/syncthing/releases/download/v$version/syncthing-windows-amd64-v$version.zip",
                "extract_dir": "syncthing-windows-amd64-v$version"
            },
            "32bit": {
                "url": "https://github.com/syncthing/syncthing/releases/download/v$version/syncthing-windows-386-v$version.zip",
                "extract_dir": "syncthing-windows-386-v$version"
            },
            "arm64": {
                "url": "https://github.com/syncthing/syncthing/releases/download/v$version/syncthing-windows-arm64-v$version.zip",
                "extract_dir": "syncthing-windows-arm64-v$version"
            }
        },
        "hash": {
            "url": "$baseurl/sha256sum.txt.asc"
        }
    }
}
