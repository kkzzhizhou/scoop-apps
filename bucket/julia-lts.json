            "hash": "11ba52fd1384f82d09ea232eb1552b6694bb2083e6adfe3ae2f9e1e663ed8cf8",
            "extract_dir": "julia-1.10.11"
        },
        "32bit": {
            "url": "https://julialang-s3.julialang.org/bin/winnt/x86/1.10/julia-1.10.11-win32.zip",
            "hash": "13a82256a98eed2d30346d8434a222755f9ac47f89ab17b57b1c47a567a2855e",
            "extract_dir": "julia-1.10.11"
        }
    },
    "bin": "bin\\julia.exe",
    "checkver": {
        "url": "https://github.com/JuliaLang/www.julialang.org/raw/main/config.md",
        "regex": "(?m:^lts_release *= *\"([0-9.]+)\"$)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://julialang-s3.julialang.org/bin/winnt/x64/$majorVersion.$minorVersion/julia-$version-win64.zip",
                "extract_dir": "julia-$version"
            },
            "32bit": {
                "url": "https://julialang-s3.julialang.org/bin/winnt/x86/$majorVersion.$minorVersion/julia-$version-win32.zip",
                "extract_dir": "julia-$version"
            }
        },
        "hash": {
            "url": "https://julialang-s3.julialang.org/bin/checksums/julia-$version.sha256"
        }
    },
    "shortcuts": [
        [
            "bin\\julia.exe",
            "Julia"
        ]
    ]
}
