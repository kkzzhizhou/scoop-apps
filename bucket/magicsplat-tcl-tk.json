    },
    "architecture": {
        "64bit": {
            "url": "https://downloads.sourceforge.net/project/magicsplat/magicsplat-tcl/tcl-8.6.18-installer-1.18.0-x64.msi",
            "hash": "sha1:6e94085401d60f61c7e0d227bf34f17d7ec2c345",
            "extract_dir": "Tcl8.6"
        },
        "32bit": {
            "url": "https://downloads.sourceforge.net/project/magicsplat/magicsplat-tcl/tcl-8.6.18-installer-1.18.0-x86.msi",
            "hash": "sha1:eb9436e1004dc554fb469af641256589db73a025",
            "extract_dir": "Tcl8.6"
        }
    },
    "bin": [
        "bin\\tclsh.exe",
        "bin\\wish.exe"
    ],
    "shortcuts": [
        [
            "bin\\wish.exe",
            "Wish"
        ]
    ],
    "checkver": {
        "sourceforge": "magicsplat",
        "regex": "tcl-(?<major>[\\d]+)\\.(?<minor>[\\d]+)\\.(?<patch>[\\d]+)-installer-([\\d.]+)-x64.msi"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://downloads.sourceforge.net/project/magicsplat/magicsplat-tcl/tcl-$matchMajor.$matchMinor.$matchPatch-installer-$version-x64.msi",
                "extract_dir": "Tcl$matchMajor.$matchMinor"
            },
            "32bit": {
                "url": "https://downloads.sourceforge.net/project/magicsplat/magicsplat-tcl/tcl-$matchMajor.$matchMinor.$matchPatch-installer-$version-x86.msi",
                "extract_dir": "Tcl$matchMajor.$matchMinor"
            }
        }
    }
}
