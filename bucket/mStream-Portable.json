    "url": "https://github.com/IrosTheBeggar/mStream/releases/download/v6.4.3/mStream-Server-Setup-6.4.3.exe#/dl.7z",
    "hash": "sha512:f89499b946e5bef61b80b233be2ca22aa9d199b3ffeef1d54b7f56cf26242638df4efc3e154e808eb274de38afff6eb9624b3332cbf6103b5e61177956bcece7",
    "architecture": {
        "64bit": {
            "pre_install": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\""
        },
        "32bit": {
            "pre_install": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-32.7z\" \"$dir\""
        }
    },
    "post_install": "Remove-Item \"$dir\\`$PLUGINSDIR\", \"$dir\\Uninstall*\", \"$dir\\resources\\app-update.yml\"  -Force -Recurse",
    "bin": [
        [
            "mStream Server.exe",
            "mStream",
            "--user-data-dir=\"$dir\\User Data\""
        ]
    ],
    "shortcuts": [
        [
            "mStream Server.exe",
            "mStream",
            "--user-data-dir=\"$dir\\User Data\""
        ]
    ],
    "persist": "User Data",
    "checkver": {
        "url": "https://github.com/IrosTheBeggar/mStream/releases/latest/download/latest.yml",
        "regex": "version: ([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://github.com/IrosTheBeggar/mStream/releases/download/v$version/mStream-Server-Setup-$version.exe#/dl.7z",
        "hash": {
            "url": "$baseurl/latest.yml",
            "regex": "sha512:\\s*$base64"
        }
    }
}
