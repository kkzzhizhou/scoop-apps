        "    elseif ($Path -match '^\\$persist_dir(?<rest>[/\\\\].*)?$') {",
        "        $suffix = $matches['rest']",
        "        if ($suffix) {",
        "            $suffix = ($suffix -replace '^[/\\\\]+', '')",
        "            $suffix = $suffix.Replace('/', '\\\\')",
