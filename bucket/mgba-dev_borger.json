            "url": "https://s3.amazonaws.com/mgba/build/mGBA-build-2026-03-08-win64-9001-edb4bae0caa3a81f028dad336a5c1234caf971ac.7z",
            "hash": "92e2f07adacd0c949a93e2c6d11a162f033a004ddf3604f08ade08756c3ff7ff",
            "extract_dir": "mGBA-build-2026-03-08-win64-9001-edb4bae0caa3a81f028dad336a5c1234caf971ac"
        },
        "32bit": {
            "url": "https://s3.amazonaws.com/mgba/build/mGBA-build-2026-03-08-win32-9001-edb4bae0caa3a81f028dad336a5c1234caf971ac.7z",
            "hash": "a4eb59993113649c6bb956c97c8965b2beb86c83a0842d3b903790151b61ce0d",
            "extract_dir": "mGBA-build-2026-03-08-win32-9001-edb4bae0caa3a81f028dad336a5c1234caf971ac"
        }
    },
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\\qt.ini\")) {",
        "   New-Item \"$dir\\qt.ini\" -Type File | Out-Null",
        "}",
        "if (!(Test-Path \"$persist_dir\\config.ini\")) {",
        "   New-Item \"$dir\\config.ini\" -Type File | Out-Null",
        "   Set-Content \"$dir\\config.ini\" '[ports.qt]'",
        "   Add-Content \"$dir\\config.ini\" 'savestatePath=savestate'",
        "   Add-Content \"$dir\\config.ini\" 'patchPath=patch'",
        "   Add-Content \"$dir\\config.ini\" 'screenshotPath=screenshot'",
        "   Add-Content \"$dir\\config.ini\" 'cheatsPath=cheats'",
        "   Add-Content \"$dir\\config.ini\" 'savegamePath=savegame'",
        "   Add-Content \"$dir\\config.ini\" 'gba.bios=bios/gba_bios.bin'",
        "   Add-Content \"$dir\\config.ini\" 'gb.bios=bios/gb_bios.bin'",
        "   Add-Content \"$dir\\config.ini\" 'gbc.bios=bios/gbc_bios.bin'",
        "   Add-Content \"$dir\\config.ini\" 'sgb.bios=bios/sgb_bios.bin'",
        "}"
    ],
    "bin": [
        [
            "mGBA.exe",
            "mgba-dev"
        ],
        [
            "mgba-sdl.exe",
            "mgba-sdl-dev"
        ]
    ],
    "shortcuts": [
        [
            "mGBA.exe",
            "Nintendo Gane Boy Advance [gba][mgba] (dev)"
        ]
    ],
    "persist": [
        "bios",
        "cheats",
        "patch",
        "savegame",
        "savestate",
        "screenshot",
        "shaders",
        "qt.ini",
        "config.ini",
        "portable.ini"
    ],
    "checkver": {
        "url": "https://mgba.io/builds/1/",
        "regex": "build-(?<year>20\\d{2})-(?<month>\\d{2})-(?<day>\\d{2})-win32-(?<ver>[\\d]+)-(?<git>(?<shortgit>\\w{7})\\w{33})\\.7z",
        "replace": "${year}-${month}-${day}-${shortgit}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://s3.amazonaws.com/mgba/build/mGBA-build-$matchYear-$matchMonth-$matchDay-win64-$matchVer-$matchGit.7z",
                "extract_dir": "mGBA-build-$matchYear-$matchMonth-$matchDay-win64-$matchVer-$matchGit"
            },
            "32bit": {
                "url": "https://s3.amazonaws.com/mgba/build/mGBA-build-$matchYear-$matchMonth-$matchDay-win32-$matchVer-$matchGit.7z",
                "extract_dir": "mGBA-build-$matchYear-$matchMonth-$matchDay-win32-$matchVer-$matchGit"
            }
        }
    }
}
