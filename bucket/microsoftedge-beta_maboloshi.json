{
    "version": "148.0.3967.42",
    "description": "The chromium based Microsoft Edge browser (Beta Channel)",
    "homepage": "https://www.microsoft.com/en-us/edge",
    "license": "Freeware",
    "architecture": {
        "64bit": {
            "url": "https://dorado-api.deno.dev/edge?arch=64&channel=beta&version=148.0.3967.42&dl#/MicrosoftEdge-148.0.3967.42-x64.7z",
            "hash": "49bd9c8af440a09519b7b750e145ff545ff82eb3bd88f5372a2ffbb8eb4c01da"
        },
        "arm64": {
            "url": "https://dorado-api.deno.dev/edge?arch=arm64&channel=beta&version=148.0.3967.42&dl#/MicrosoftEdge-148.0.3967.42-arm64.7z",
            "hash": "16d04f1127768fe49015c8e59a88e1e2f9a737b08d13b8342dca8623344453bc"
        }
    },
    "installer": {
        "script": "Expand-7zipArchive -Path \"$dir\\MSEDGE.7z\" -ExtractDir \"Chrome-bin\\$version\" -Removal"
    },
    "shortcuts": [
        [
            "msedge.exe",
            "Microsoft Edge Beta",
            "--force-device-scale-factor=1.5"
        ]
    ],
    "post_install": [
        "$runtimeCache = \"$env:LocalAppData\\Microsoft\\Edge Beta\\User Data\"",
        "$runtimeCachePersist = \"$persist_dir\\User Data\"",
        "if (Test-Path $runtimeCachePersist) {",
        "    Remove-Item -Path $runtimeCache -Force -Recurse -ErrorAction SilentlyContinue",
        "} elseif (Test-Path $runtimeCache) {",
        "    Move-Item -Path $runtimeCache -Destination $runtimeCachePersist -Force",
        "}",
        "New-DirectoryJunction $runtimeCache $runtimeCachePersist | Out-Null"
    ],
    "post_uninstall": [
        "$runtimeCache = \"$env:LocalAppData\\Microsoft\\Edge Beta\\User Data\"",
        "Remove-Item -Path $runtimeCache -Force -Recurse -ErrorAction SilentlyContinue"
    ],
    "persist": "User Data",
    "checkver": {
        "url": "https://dorado-api.deno.dev/edge?arch=64&channel=beta",
        "jsonpath": "$.Version"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://dorado-api.deno.dev/edge?arch=64&channel=beta&version=$version&dl#/MicrosoftEdge-$version-x64.7z",
                "hash": {
                    "url": "https://dorado-api.deno.dev/edge?arch=64&channel=beta&version=$version",
                    "jsonpath": "$.Hashes.Sha256"
                }
            },
            "arm64": {
                "url": "https://dorado-api.deno.dev/edge?arch=arm64&channel=beta&version=$version&dl#/MicrosoftEdge-$version-arm64.7z",
                "hash": {
                    "url": "https://dorado-api.deno.dev/edge?arch=arm64&channel=beta&version=$version",
                    "jsonpath": "$.Hashes.Sha256"
                }
            }
        }
    }
}
