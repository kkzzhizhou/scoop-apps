        "GitExtensions.settings",
        "WindowPositions.xml",
        "Themes"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/gitextensions/gitextensions/releases",
        "regex": "download/v(?<version>.+?)/(?<file>.+?)\""
    },
    "autoupdate": {
