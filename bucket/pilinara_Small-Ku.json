{
	"version": "2.1.0.1-Himeko",
	"description": "An open-source, cross-platform Bilibili client featuring video playback, live streaming, and danmaku support.",
	"homepage": "https://github.com/Starfallan/PiliNara",
	"license": "GPL-3.0-only",
	"url": "https://github.com/Starfallan/PiliNara/releases/download/2.1.0.1-Himeko/PiliNara_windows_2.1.0+5524_x64_portable.zip",
	"hash": "8bb80b6120f205c751496bf241e790e8c092129a16a33525c19cdac6bd7bf4a9",
	"extract_dir": "PiliNara-Win",
	"shortcuts": [
		[
			"pilinara.exe",
			"PiliNara"
		]
	],
	"checkver": {
		"script": [
			"$releases = Invoke-RestMethod -Headers @{ 'User-Agent' = 'Scoop' } -Uri 'https://api.github.com/repos/Starfallan/PiliNara/releases'",
			"$release = ($releases | Where-Object { -not $_.prerelease })[0]",
			"$asset = ($release.assets | Where-Object { $_.name -like '*windows*portable.zip' })[0]",
			"Write-Output \"$($release.tag_name) $($asset.browser_download_url) $($asset.digest.Replace('sha256:', ''))\""
		],
		"regex": "(?<version>[^\\s]+)\\s(?<url>[^\\s]+)\\s(?<hash>[^\\s]+)"
	},
	"autoupdate": {
		"url": "$matchUrl",
		"hash": "$matchHash"
	}
}
