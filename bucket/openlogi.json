{
    "version": "0.6.22",
    "description": "⚡️A native, local-first alternative to Logitech Options+, written in Rust 🦀 — remap buttons, DPI, and SmartShift over HID++. No account, no telemetry.",
    "homepage": "https://openlogi.org/",
    "license": {
        "identifier": "MIT",
        "url": "https://github.com/AprilNEA/OpenLogi?tab=MIT-2-ov-file"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/AprilNEA/OpenLogi/releases/download/v0.6.22/OpenLogi-v0.6.22-windows-x86_64.msi",
            "hash": "f314fd19a01f5ba8cc7f80819534c2b8b7bc4ed3a9e429161ba02ac2b0041217"
        },
        "arm64": {
            "url": "https://github.com/AprilNEA/OpenLogi/releases/download/v0.6.22/OpenLogi-v0.6.22-windows-arm64.msi",
            "hash": "96a69954f0496738b0503f73acda3ab59f933e892056850790c6f7e05f55ac4d"
        }
    },
    "extract_dir": "LocalApp\\Programs\\OpenLogi",
    "installer": {
        "script": [
            "# handle runtime cache",
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\appdata\" -Target \"$env:USERPROFILE\\.local\"",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\userdata\" -Target \"$env:USERPROFILE\\.config\\openlogi\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "uninstaller": {
        "script": [
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Dismount-ExternalRuntimeData -Target \"$env:USERPROFILE\\.local\"",
            "Dismount-ExternalRuntimeData -Target \"$env:USERPROFILE\\.config\\openlogi\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "bin": "OpenLogi.exe",
    "shortcuts": [
        [
            "OpenLogi.exe",
            "OpenLogi"
        ]
    ],
    "checkver": {
        "github": "https://api.github.com/repos/AprilNEA/OpenLogi/releases",
        "jp": "$[0].tag_name",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/AprilNEA/OpenLogi/releases/download/v$version/OpenLogi-v$version-windows-x86_64.msi"
            },
            "arm64": {
                "url": "https://github.com/AprilNEA/OpenLogi/releases/download/v$version/OpenLogi-v$version-windows-arm64.msi"
            }
        }
    }
}
