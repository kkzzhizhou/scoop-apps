    "checkver": {
        "url": "https://jdk.java.net/",
        "regex": "JDK ([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://download.java.net/java/GA/jdk$version/458fda22e4c54d5ba572ab8d2b22eb83/8/GPL/openjdk-$version_windows-x64_bin.zip",
        "hash": {
            "url": "$url.sha256"
        },
        "extract_dir": "jdk-$version"
    },
    "notes": [
        "【工具类型】: 开发工具",
        "【主要功能】: OpenJDK官方正式版本，Java开发环境",
