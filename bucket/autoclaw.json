{
    "version": "1.11.2",
    "description": "支持 OpenClaw 一键安装、飞书集成与本地执行的桌面 AI 助手。",
    "homepage": "https://autoglm.zhipuai.cn/autoclaw/",
    "license": "Proprietary",
    "architecture": {
        "64bit": {
            "url": "https://autoglm.aminer.cn/autoclaw/updates/autoclaw-1.11.2-setup.exe#/dl.7z",
            "hash": "sha512:83aae7ac8e12574ff8759a953aaaf25674151afe19c1c4f875bfe907187c58bb8380d8f53684acf2b4d52adfb6f86fe98aaf2fff6d3d9faa82349f4dbd60929a",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\", \"$dir\\Uninstall*\" -Recurse -ErrorAction SilentlyContinue"
            ]
        }
    },
    "shortcuts": [
        [
            "AutoClaw.exe",
            "AutoClaw"
        ]
    ],
    "portableProfile": {
        "mappings": [
            {
                "label": "home-state",
                "source": "UserProfile/.openclaw-autoclaw",
                "target": "$persist_dir/home/openclaw-autoclaw",
                "strategy": "symlink",
                "ensureTarget": true
            },
            {
                "label": "roaming",
                "source": "AppData/AutoClaw",
                "target": "$persist_dir/roaming",
                "strategy": "symlink",
                "ensureTarget": true
            },
            {
                "label": "updater",
                "source": "LocalAppData/autoclaw-updater",
                "target": "$persist_dir/local/autoclaw-updater",
                "strategy": "symlink",
                "ensureTarget": true,
                "targetType": "file"
            }
        ],
        "options": {
            "log": true
        }
    },
    "checkver": {
        "url": "https://autoglm.aminer.cn/autoclaw/updates/latest.yml",
        "regex": "version:\\s*([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://autoglm.aminer.cn/autoclaw/updates/autoclaw-$version-setup.exe#/dl.7z",
                "hash": {
                    "url": "$baseurl/latest.yml",
                    "regex": "sha512:\\s+$base64"
                }
            }
        }
    }
}
