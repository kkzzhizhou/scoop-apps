    "checkver": {
        "script": [
            "$url = 'https://cursor.com/api/download?platform=win32-x64-user&releaseTrack=stable'",
            "$res = Invoke-WebRequest -Uri $url -MaximumRedirection 0 -UseBasicParsing",
            "$json = $res.Content | ConvertFrom-Json",
