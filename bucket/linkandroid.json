            "hash": "a768f8c4792d626890658ae067048e8092d585a9aa230a628d63161012a3b038",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\" -Force -Recurse"
            ]
        },
        "arm64": {
            "url": "https://github.com/modstart-lib/linkandroid/releases/download/v2.0.0/LinkAndroid-2.0.0-win-setup-arm64.exe#/dl.7z",
            "hash": "f0ba728a47be0ce935e6e12606b5a00c55a0f57158b5b9136826581c8d9482a1",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-arm64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\" -Force -Recurse"
            ]
        }
    },
    "installer": {
        "script": [
            "# handle runtime cache",
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\appdata\" -Target \"$env:APPDATA\\linkandroid\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "uninstaller": {
        "script": [
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\linkandroid\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "shortcuts": [
        [
            "LinkAndroid.exe",
            "LinkAndroid"
        ]
    ],
    "checkver": {
        "github": "https://api.github.com/repos/modstart-lib/linkandroid/releases/latest",
        "jp": "$.tag_name",
        "regex": "v([\\w.-]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/modstart-lib/linkandroid/releases/download/v$version/LinkAndroid-$version-win-setup-x64.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/modstart-lib/linkandroid/releases/download/v$version/LinkAndroid-$version-win-setup-arm64.exe#/dl.7z"
