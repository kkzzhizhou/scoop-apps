{
    "version": "12.18.4",
    "description": "Postman中文版 - API开发环境（中文包9.12.2，部分新功能界面可能未翻译）",
    "homepage": "https://github.com/hlmd/postman-cn",
    "license": {
        "identifier": "Freeware",
        "url": "https://www.getpostman.com/licenses/postman_eula"
    },
    "architecture": {
        "64bit": {
            "url": [
                "https://dl.pstmn.io/download/12.18.4/Postman%20v12.18.4%20(x64).exe#/dl.7z",
                "https://github.com/hlmd/Postman-cn/releases/download/9.12.2/app.zip"
            ],
            "hash": [
                "sha1:e4919219bf41c8e551959b3ba3d4357ffb41cc1d",
                "bb6e561a40b94bbef75ae5835a0b184847c4ead7f74e2fe5f12df810f7440496"
            ]
        }
    },
    "suggest": {
        "nodejs": "main/nodejs"
    },
    "installer": {
        "script": [
            "Expand-7zipArchive \"$dir\\Postman-$version-full.nupkg\" \"$dir\\postman\" -ExtractDir 'lib\\net45' -Removal",
            "@('background.gif', 'RELEASES', 'setupIcon.ico', 'Update.exe') | ForEach-Object { Remove-Item \"$dir\\$_\" -ErrorAction SilentlyContinue }"
        ]
    },
    "post_install": "if (Get-Command npx -ErrorAction SilentlyContinue) { npx --yes @electron/asar extract \"$dir\\postman\\resources\\app.asar\" \"$dir\\postman\\resources\\app\"; Remove-Item \"$dir\\postman\\resources\\app.asar\" -Force; Copy-Item \"$dir\\app\\*\" \"$dir\\postman\\resources\\app\\\" -Recurse -Force; Remove-Item \"$dir\\app\" -Recurse -Force; Write-Host 'Postman CN installed.' } else { Write-Warning 'Node.js/npx not found. Postman installed without Chinese pack. Install nodejs and reinstall for Chinese support.' }",
    "bin": "postman\\Postman.exe",
    "shortcuts": [
        [
            "postman\\Postman.exe",
            "Postman CN"
        ]
    ],
    "checkver": {
        "url": "https://dl.pstmn.io/changelog?channel=stable&platform=win64",
        "jsonpath": "$.changelog[0].name"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": [
                    "https://dl.pstmn.io/download/$version/Postman%20v$version%20(x64).exe#/dl.7z",
                    "https://github.com/hlmd/Postman-cn/releases/download/9.12.2/app.zip"
                ],
                "hash": {
                    "url": "https://dl.pstmn.io/RELEASES?platform=win64&from=$version",
                    "regex": "(?sm)$basename.*?$sha1"
                }
            }
        }
    },
    "notes": [
        "【工具类型】: 开发工具",
        "【主要功能】: Postman中文版，完整的API开发环境，支持API测试和调试",
        "【适用场景】: API开发、接口测试、开发调试",
        "【技术特点】: 基于Electron，图形化界面，支持64位",
        "【注意事项】: 中文包版本(9.12.2)较低，部分新功能界面可能未翻译；需Node.js环境支持中文包安装"
    ]
}
