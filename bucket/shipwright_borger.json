{
    "version": "9.2.3",
    "description": "A PC port of Legend of Zelda: Ocarina of Time",
    "homepage": "https://www.shipofharkinian.com",
    "license": "Unlicense",
    "notes": [
        "ATTENTION: Ship Of Harkinian requires specific n64 rom(s) of OoT to function.",
        "Place the rom(s) in $persist_dir.",
        "Learn more at http://ship.equipment and https://www.shipofharkinian.com/setup-guide"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/HarbourMasters/Shipwright/releases/download/9.2.3/SoH-Ackbar-Delta-Win64.zip",
            "hash": "cc7bd5ada1332be50013976fc3db3289cacde1df57e7e6cf73d4a1df81313e30"
        }
    },
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\\shipofharkinian.json\")) {",
        "    New-Item -ItemType File -ErrorAction SilentlyContinue \"$dir\\shipofharkinian.json\" | Out-Null",
        "}"
    ],
    "post_install": [
        "if (Test-Path \"$persist_dir\\shipofharkinian.json.bak\") {",
        "    Copy-Item -Force \"$persist_dir\\shipofharkinian.json.bak\" \"$dir\\shipofharkinian.json\"",
        "} else {",
        "    New-Item -ErrorAction SilentlyContinue -ItemType File \"$dir\\shipofharkinian.json\" | Out-Null",
        "}"
    ],
    "bin": "soh.exe",
    "shortcuts": [
        [
            "soh.exe",
            "The Legend of Zelda - Ocarina of Time [oot][soh]"
        ]
    ],
    "persist": [
        "mods",
        "Save",
        "shipofharkinian.json"
    ],
    "uninstaller": {
        "script": [
            "if (Test-Path \"$dir\\shipofharkinian.json\") {",
            "    Copy-Item -Force \"$dir\\shipofharkinian.json\" \"$persist_dir\\shipofharkinian.json.bak\"",
            "}"
        ]
    },
    "checkver": {
        "github": "https://github.com/HarbourMasters/Shipwright/",
        "regex": "(?<majorName>(\\w+))\\s(?<minorName>(\\w+))\\s(?<version>([\\d\\.]+))",
        "replace": "${version}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/HarbourMasters/Shipwright/releases/download/$version/SoH-$matchMajorname-$matchMinorname-Win64.zip"
            }
        }
    }
}
