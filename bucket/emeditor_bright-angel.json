{
    "version": "25.1.3",
    "description": "A fast, lightweight and extensible text editor for Windows. Useful for opening very large files.",
    "homepage": "https://www.emeditor.com/",
    "license": "Shareware",
    "url": "https://download.emeditor.info/emed64_25.1.3_portable.zip",
    "hash": "29d98b0ee077cfd7bea9942d286894bd26c5139fdb598bf7ddcfe4583849f3cf",
    "pre_install": [
        "$manifest.persist | ForEach-Object {",
        "    if ([io.path]::GetExtension($_)) {",
        "        if (!(Test-Path \"$persist_dir\\$_\")) { New-Item \"$dir\\$_\" | Out-Null }",
        "    }",
        "}"
    ],
    "notes": [
        "【工具类型】: 开发工具",
        "【主要功能】: 快速轻量级文本编辑器，支持打开超大文件",
        "【适用场景】: 文本编辑、代码编写、大文件处理",
        "【技术特点】: 高性能设计，支持插件扩展，可处理GB级文件"
    ],
    "bin": "EmEditor.exe",
    "shortcuts": [
        [
            "EmEditor.exe",
            "EmEditor"
        ]
    ],
    "persist": [
        "eeCommon.ini",
        "eeConfig.ini",
        "eeLM.ini",
        "eePlugins.ini",
        "AppData"
    ],
    "checkver": {
        "url": "https://www.emeditor.com/",
        "regex": "Version ([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://download.emeditor.com/emed64_$version_portable.zip"
    }
}
