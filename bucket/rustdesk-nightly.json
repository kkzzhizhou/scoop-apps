    "architecture": {
        "64bit": {
            "url": "https://github.com/rustdesk/rustdesk/releases/download/nightly/rustdesk-1.4.8-x86_64.exe#/RustDesk.exe",
            "hash": "6be8b5bccfdc18d1b4b50f8d3c05edec10f9148709d35d49e7b2c997367385e7"
        },
        "32bit": {
            "url": "https://github.com/rustdesk/rustdesk/releases/download/nightly/rustdesk-1.4.8-x86-sciter.exe#/RustDesk.exe",
            "hash": "6fdbbeca0654fc29fb4aa7b37807b7c9311582469124b79169584c2baf40a666"
        }
    },
    "shortcuts": [
        [
            "RustDesk.exe",
            "RustDesk"
        ]
    ],
    "checkver": {
        "github": "https://api.github.com/repos/rustdesk/rustdesk/releases/tags/nightly",
        "script": [
            "$api = $page | ConvertFrom-Json",
            "foreach ($name in $api.assets.name) { if ($name -clike '*-x86_64.exe') { $asset = $name; break } }",
            "$result = (Get-Date $api.assets[0].updated_at -UFormat %s), $asset -join ' '",
            "$output = @{'result' = \"$result\"} | ConvertTo-Json -Compress",
            "Write-Output $output"
        ],
        "jsonpath": "$.result",
        "regex": "\\A(\\d+) rustdesk-(?<release>[\\d.-]+)-x86_64.exe\\Z"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/rustdesk/rustdesk/releases/download/nightly/rustdesk-$matchRelease-x86_64.exe#/RustDesk.exe"
            },
            "32bit": {
                "url": "https://github.com/rustdesk/rustdesk/releases/download/nightly/rustdesk-$matchRelease-x86-sciter.exe#/RustDesk.exe"
            }
        }
    }
}
