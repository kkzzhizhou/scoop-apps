{
    "homepage": "https://www.openttd.org",
    "version": "15.3",
    "description": "OpenTTD is an open source simulation game based upon Transport Tycoon Deluxe.",
    "architecture": {
        "64bit": {
            "url": "https://cdn.openttd.org/openttd-releases/15.3/openttd-15.3-windows-win64.zip",
            "hash": "61c0a6a43d81008c7ff4330fb56351bbf66a980cdad041f1d0e08b51f2eeb34c",
            "extract_dir": "openttd-15.3-windows-win64"
        },
        "32bit": {
            "url": "https://cdn.openttd.org/openttd-releases/15.3/openttd-15.3-windows-win32.zip",
