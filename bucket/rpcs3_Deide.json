{
    "version": "0.0.40-18943",
    "homepage": "https://rpcs3.net/",
    "description": "Sony Playstation 3 Emulator",
    "license": {
        "identifier": "GPL-2.0",
        "url": "https://github.com/RPCS3/rpcs3/blob/master/LICENSE"
    },
    "url": "https://github.com/RPCS3/rpcs3-binaries-win/releases/download/build-ee01d1186ffe80042a5f61830a6407ac739d07df/rpcs3-v0.0.40-18943-ee01d118_win64_msvc.7z",
    "hash": "a35a1a13eae4acee135883b5f79ebd71e5908ccc9285130ee6aea06691772efb",
    "bin": "rpcs3.exe",
    "depends": "ps3-firmware",
    "suggest": {
        "Microsoft Visual C++ Runtime 2022": "extras/vcredist2022"
    },
    "shortcuts": [
        [
            "rpcs3.exe",
            "PS3"
        ]
    ],
    "persist": [
        "dev_flash",
        "dev_flash2",
        "dev_flash3",
        "dev_hdd0",
        "dev_hdd1",
        "dev_usb000",
        "cache",
        "config",
        "patches",
        "captures",
        "recordings",
        "savestates",
        "GuiConfigs",
        "config.yml",
        "games.yml"
    ],
    "installer": {
        "script": [
            "function create($Path, $Type, $Content) {",
            "   if (-not (Test-Path \"$path\")) {",
            "       New-Item \"$path\" -ItemType $type -Value ($content -join \"`n\") -Force | Out-Null",
            "       Write-Output \"Creating $path...\"",
            "   }",
            "}",
            "$conf = \"$persist_dir\\config.yml\"",
            "$games = \"$persist_dir\\games.yml\"",
            "$settings = \"$persist_dir\\GuiConfigs\\CurrentSettings.ini\"",
            "create $conf -Type File",
            "create $games -Type File",
            "create $settings -Type File -Content ('[Meta]', 'checkUpdateStart=false', \"`n[main_window]\", 'infoBoxEnabledWelcome=false')",
            "Copy-Item \"$dir/GuiConfigs/**\" -Exclude 'CurrentSettings.ini' -Destination \"$persist_dir/GuiConfigs/\" -Recurse -Force"
        ]
    },
    "checkver": {
        "url": "https://update.rpcs3.net/?api",
        "jsonpath": {
            "version": "$.latest_build.version",
            "download": "$.latest_build.windows.download",
            "hash": "$.latest_build.windows.checksum"
        }
    },
    "autoupdate": {
        "url": "$matchDownload",
        "hash": {
            "url": "$url.sha256"
        }
    }
}
