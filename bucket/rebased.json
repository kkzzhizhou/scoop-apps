{
    "version": "1.1.3",
    "description": "A git client based on the IntelliJ platform.",
    "homepage": "https://github.com/DetachHead/rebased",
    "license": {
        "identifier": "Apache-2.0",
        "url": "https://github.com/DetachHead/rebased/blob/master/LICENSE.txt"
    },
    "url": "https://github.com/DetachHead/rebased/releases/download/1.1.3/rebased.exe#/dl.7z",
    "hash": "280361b1b12dc00519f1b23263aea89225b56355e2b6a16a3f0e8898f213777e",
    "pre_install": "Remove-Item \"$dir\\`$PLUGINSDIR\" -Recurse -Force",
    "installer": {
        "script": [
            "if (!(Test-Path \"$persist_dir\\bin\\idea.properties\")) {",
            "    $current = (Split-Path $dir | Join-Path -ChildPath 'current') -replace '\\\\', '/'",
            "    $content = Get-Content \"$dir\\bin\\idea.properties\"",
            "    $content = $content -replace '^#\\s*(idea.config.path=).*$', \"`$1$current/profile/config\"",
            "    $content = $content -replace '^#\\s*(idea.system.path=).*$', \"`$1$current/profile/system\"",
            "    $content = $content -replace '^#\\s*(idea.plugins.path=).*$', '$1${idea.config.path}/plugins'",
            "    $content = $content -replace '^#\\s*(idea.log.path=).*$', '$1${idea.system.path}/log'",
            "    Set-Content -LiteralPath \"$dir\\bin\\idea.properties\" -Value $content -Encoding Ascii -Force",
            "}"
        ]
    },
    "bin": [
        [
            "bin\\idea64.exe",
            "rebased"
        ]
    ],
    "shortcuts": [
        [
            "bin\\idea64.exe",
            "Rebased"
        ]
    ],
    "persist": [
        "bin\\idea.properties",
        "bin\\idea64.exe.vmoptions",
        "profile"
    ],
    "checkver": {
        "github": "https://github.com/DetachHead/rebased",
        "regex": "releases/tag/([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://github.com/DetachHead/rebased/releases/download/$version/rebased.exe#/dl.7z"
    }
}
