{
    "version": "2.7.0",
    "description": "Chocolatey - the package manager for Windows",
    "homepage": "https://github.com/chocolatey/choco",
    "license": {
        "identifier": "Apache-2.0",
        "url": "https://github.com/chocolatey/choco?tab=License-1-ov-file#readme"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/chocolatey/choco/releases/download/2.7.0/chocolatey.v2.7.0.tar.gz",
            "hash": "b3c8b59704154c2e96de542fe6ef47bf4285b7ef93209afa23fdb9f5599be08f"
        }
    },
    "bin": "choco.exe",
    "env_add_path": "bin",
    "persist": [
        ".chocolatey",
        "bin",
        "config",
        "lib",
        "lib-bad",
        "lib-bkp",
        "logs"
    ],
    "checkver": {
        "github": "https://github.com/chocolatey/choco"
    },
    "autoupdate": {
        "url": "https://github.com/chocolatey/choco/releases/download/$version/chocolatey.v$version.tar.gz",
        "hash": {
            "mode": "extract",
            "url": "https://github.com/chocolatey/choco/releases/expanded_assets/$version",
            "regex": "chocolatey.*\\.tar\\.gz.*?sha256:$sha256"
        }
    }
}
