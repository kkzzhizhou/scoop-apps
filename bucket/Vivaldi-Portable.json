    "shortcuts": [
        [
            "Application\\vivaldi.exe",
            "Vivaldi"
        ]
    ],
    "persist": "User Data",
    "checkver": {
        "url": "https://vivaldi.com/download/",
        "regex": "Vivaldi\\.([\\d.]+)\\.exe"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://downloads.vivaldi.com/stable/Vivaldi.$version.x64.exe#/dl.7z"
            },
            "32bit": {
                "url": "https://downloads.vivaldi.com/stable/Vivaldi.$version.exe#/dl.7z"
