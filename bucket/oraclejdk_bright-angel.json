{
    "description": "Oracle Java Platform, Standard Edition Development Kit (JDK)",
    "homepage": "https://www.oracle.com/java/",
    "version": "26.0.2",
    "license": "https://www.oracle.com/downloads/licenses/no-fee-license.html",
    "architecture": {
        "64bit": {
            "url": "https://download.oracle.com/java/26/archive/jdk-26.0.2_windows-x64_bin.zip",
            "hash": "530c20885a96d97c5f982a96e2d9e6aa41956c414b4a7398c49df7fe3192e62d"
        }
    },
    "extract_dir": "jdk-26.0.2",
    "pre_install": [
        "Set-Content \"$dir\\oraclejdk.bat\" '@pushd %~dp0",
        "@set JAVA_HOME=%~dp0",
        "@set path=%JAVA_HOME%\\bin;%path%;",
        "@popd' -Encoding Ascii"
    ],
    "bin": "oraclejdk.bat",
    "checkver": {
        "url": "https://www.oracle.com/java/technologies/downloads",
        "useragent": "curl/7",
        "regex": "Java SE Development Kit ([\\d.]+) downloads"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.oracle.com/java/$majorVersion/archive/jdk-$version_windows-x64_bin.zip"
            }
        },
        "hash": {
            "url": "$url.sha256"
        },
        "extract_dir": "jdk-$version"
    },
    "notes": [
        "【工具类型】: 开发工具",
        "【主要功能】: Oracle JDK最新版本，Java开发工具包",
        "【适用场景】: Java开发、运行Java程序、开发调试",
        "【技术特点】: Oracle官方版本，支持64位，自动配置JAVA_HOME"
    ]
}
