{
    "version": "2.1.16",
    "license": "MIT",
    "description": "“中国蚁剑是一款跨平台的开源网站管理工具。AntSword is a cross-platform website management toolkit.",
    "homepage": "https://github.com/AntSwordProject/antSword",
    "checkver": "github",
    "url": "https://github.com/AntSwordProject/antSword/archive/refs/tags/2.1.16.zip#/antswordcore-2.1.16.src",
    "hash": "414b6b71eac3ed22bc5139fa41e46bcc0bd9067420206efb4b51db04cfde2a6c",
    "persist": "antData",
    "installer": {
        "script": [
            "$archive = Join-Path $dir $fname",
            "$tmp = Join-Path $dir '_tmp'",
            "New-Item -ItemType Directory -Force $tmp | Out-Null",
            "7z x $archive \"antSword-$version\\*\" \"-o$tmp\" -y -snld",
            "Move-Item \"$tmp\\antSword-$version\\*\" $dir -Force",
            "Remove-Item $tmp -Recurse -Force",
            "Remove-Item $archive -Force"
        ]
    },
    "autoupdate": {
        "url": "https://github.com/AntSwordProject/antSword/archive/refs/tags/$version.zip#/antswordcore-$version.src"
    }
}
