{
    "version": "4.15_BETA",
    "description": "A utility that helps format and create bootable USB flash drives (beta version).",
    "homepage": "https://rufus.ie/",
    "license": "GPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://github.com/pbatard/rufus/releases/download/v4.15_BETA/rufus-4.15_BETA.exe#/rufus.exe",
            "hash": "17a94859b28698d63a5ed0c90818bb78f108f5f5e475d5329980454b9c4d6e10"
        }
    },
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\\rufus.ini\")) {",
        "    Set-Content \"$dir\\rufus.ini\" 'UpdateCheckInterval = -1' -Encoding Ascii",
        "}"
    ],
    "bin": "rufus.exe",
    "shortcuts": [
        [
            "rufus.exe",
            "Rufus Beta"
        ]
    ],
    "persist": [
        "Rufus",
        "rufus.ini"
    ],
    "checkver": {
        "github": "https://api.github.com/repos/pbatard/rufus/releases?per_page=1",
        "jsonpath": "$[0].tag_name",
        "regex": "v([\\w._]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/pbatard/rufus/releases/download/v$version/rufus-$version.exe#/rufus.exe"
            }
        }
    }
