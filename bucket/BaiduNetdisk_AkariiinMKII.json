{
    "version": "8.6.3.101",
    "description": "Windows client for BaiduNetdisk",
    "homepage": "https://pan.baidu.com/",
    "license": "Freeware",
    "notes": [
        "For app still running issue in uninstallation and update, run the following command and try again:",
        "Get-Process -Name YunDetectService, kernelUpdate -ErrorAction SilentlyContinue | Stop-Process -Force"
    ],
    "depends": "Scoop4kariiin/Scoop4kariiinUtils",
    "url": "https://issuepcdn.baidupcs.com/issue/netdisk/yunguanjia/BaiduNetdisk_8.6.3.101.exe#dl.7z",
    "hash": "36204b3a74bcd4f99212f7f5e91e12152ec403d8546fc7cef7fa636b7a583140",
    "shortcuts": [
        [
            "BaiduNetdisk.exe",
            "BaiduNetdisk"
        ]
    ],
    "installer": {
        "script": [
            "Remove-Item \"$dir\\`$PLUGINSDIR\" -Force -Recurse",
            "Import-Module -Name Scoop4kariiinUtils -ErrorAction Stop",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\baidunetdisk\" -AppData",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\BaiduYunGuanjia\" -AppData",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\BaiduYunKernel\" -AppData",
            "Restore-PersistItem -AppDir \"$dir\" -PersistDir \"$persist_dir\" -Name \"AppSettingApp.dat\"",
            "Remove-Module -Name Scoop4kariiinUtils -ErrorAction SilentlyContinue"
        ]
    },
    "post_install": [
        "$ScriptsDir = Find-BucketDirectory -Root -Name $bucket | Join-Path -ChildPath \"scripts\\BaiduNetdisk\"",
        "$BNHPaths = Get-ChildItem -Path \"$dir\" -Filter \"baidunetdiskhost.exe\" -Recurse | Select-Object -ExpandProperty Target",
        "$BNUPaths = Get-ChildItem -Path \"$dir\" -Filter \"baidunetdiskunite.exe\" -Recurse | Select-Object -ExpandProperty Target",
        "if (Test-Path \"$ScriptsDir\\update-firewall-rules.ps1\") {",
        "    $Content = Get-Content \"$ScriptsDir\\update-firewall-rules.ps1\" -Encoding UTF8",
        "    $Content = $Content.Replace('$BNHPaths', \"$BNHPaths\")",
        "    $Content = $Content.Replace('$BNUPaths', \"$BNUPaths\")",
        "    $Content | Out-File -FilePath \"$dir\\update-firewall-rules.ps1\" -Encoding UTF8",
        "    Write-Host \"`nUpdating Windows firewall rules...\" -ForegroundColor Yellow",
        "    Write-Host \"Please approve permission request if UAC prompt pops up.\" -ForegroundColor Yellow",
        "    Start-Sleep -Seconds 1",
        "    gsudo \"$dir\\update-firewall-rules.ps1\"",
        "    if ($?) {",
        "        Write-Host \"Successfully updated Windows firewall rules!\" -ForegroundColor Green",
        "    } else {",
        "        Write-Host \"[ERROR] Failed updating Windows firewall rules!\" -ForegroundColor Red",
        "    }",
        "} else {",
        "    Write-Host \"Missing files, please re-add Scoop4kariiin bucket and re-install this app.\" -ForegroundColor Red",
        "}"
    ],
    "persist": [
        "users",
        [
            "module\\BrowserEngine\\users",
            "BrowserEngineUsers"
        ]
    ],
    "uninstaller": {
        "script": [
            "Get-Process -Name YunDetectService, kernelUpdate -ErrorAction SilentlyContinue | Stop-Process -Force",
            "Import-Module -Name Scoop4kariiinUtils -ErrorAction Stop",
            "Dismount-ExternalRuntimeData -Target \"baidunetdisk\" -AppData",
            "Dismount-ExternalRuntimeData -Target \"BaiduYunGuanjia\" -AppData",
            "Dismount-ExternalRuntimeData -Target \"BaiduYunKernel\" -AppData",
            "Backup-PersistItem -AppDir \"$dir\" -PersistDir \"$persist_dir\" -Name \"AppSettingApp.dat\"",
            "Remove-Module -Name Scoop4kariiinUtils -ErrorAction SilentlyContinue"
        ]
    },
    "checkver": {
        "url": "https://pan.baidu.com/disk/cmsdata?do=client",
        "regex": "Windows电脑客户端V([\\d.]+)\""
    },
    "autoupdate": {
        "url": "https://issuepcdn.baidupcs.com/issue/netdisk/yunguanjia/BaiduNetdisk_$version.exe#dl.7z"
    }
}
