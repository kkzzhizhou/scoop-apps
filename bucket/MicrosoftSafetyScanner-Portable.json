            "hash": "aeed7d799bd1fecb5f41cbd63ee7bd5e3dafee3676267d318a1fe683a7830b4a"
        },
        "32bit": {
            "url": "https://definitionupdates.microsoft.com/packages/content/msert.exe?packageType=Scanner&packageVersion=1.449.34.0&arch=x86",
