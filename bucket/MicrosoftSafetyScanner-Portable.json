            "hash": "04cecc387a9c3a965ef00a2d83b9e37ed38ac8f3a86eef9dd3fca79fe1a4d361"
        },
        "32bit": {
            "url": "https://definitionupdates.microsoft.com/packages/content/msert.exe?packageType=Scanner&packageVersion=1.447.128.0&arch=x86",
            "hash": "cb8eddf44d5dbcc6bed460d9b94223368e826f5ac4ad782af08c6ca934f668c0"
