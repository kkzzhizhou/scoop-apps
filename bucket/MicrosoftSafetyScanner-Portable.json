            "hash": "00722ea6caa21f52ec4254c04786c59e500e5163f871791e3b9afdf799741be6"
        },
        "32bit": {
            "url": "https://definitionupdates.microsoft.com/packages/content/msert.exe?packageType=Scanner&packageVersion=1.455.200.0&arch=x86",
