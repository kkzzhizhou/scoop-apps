    ],
    "url": "https://github.com/chrisant996/clink/releases/download/v1.9.29/clink.1.9.29.fc1e8d.zip",
    "hash": "4788b2c6b8cf9b3d070829bfef4ad4ee373c2d2097ebd05483bd2cec961a03bc",
    "bin": [
        [
            "clink.bat",
            "clink",
            "--profile $dir\\profile\\"
        ]
    ],
    "persist": "profile",
    "checkver": {
        "url": "https://github.com/chrisant996/clink/tags",
        "regex": "/releases/tag/v([\\d.]+)[\\s\\S\\w\\W]*?/clink/commit/(?<commit>[\\w]{6})"
    },
    "autoupdate": {
