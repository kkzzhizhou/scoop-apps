    "license": "GPL-3.0-only",
    "notes": [
        "Run 'clink inject' to start clink on the current cmd",
        "Run 'clink autorun install' to auto start clink"
    ],
    "url": "https://github.com/chrisant996/clink/releases/download/v1.9.23/clink.1.9.23.37616c.zip",
    "hash": "ef6102aea6f6350804c32428ce04ad82eb185b0387424f62fe0f6f1e8c19737d",
    "bin": [
        [
            "clink.bat",
            "clink",
            "--profile $dir\\profile\\"
        ]
    ],
    "persist": "profile",
    "checkver": {
        "url": "https://github.com/chrisant996/clink/tags",
        "regex": "/releases/tag/v([\\d.]+)[\\s\\S\\w\\W]*?/clink/commit/(?<commit>[\\w]{6})"
    },
    "autoupdate": {
