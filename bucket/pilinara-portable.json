{
    "version": "2.0.9.5404",
    "description": "基于PiliPlus做了一些自用修改",
    "homepage": "https://karing.app/",
    "license": {
        "identifier": "GPL-3.0 license",
        "url": "https://github.com/Starfallan/PiliNara#GPL-3.0-1-ov-file"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Starfallan/PiliNara/releases/download/2.0.9.1-Mydeimos/PiliNara_windows_2.0.9+5404_x64_portable.zip",
            "hash": "7425bb92913aeabbef3af90fb2ca29d0340f52bd9f657f8c01df39b930d0ccfb"
        }
    },
    "extract_dir": "PiliNara-Win",
    "installer": {
        "script": [
            "# handle runtime cache",
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\appdata\" -Target \"$env:APPDATA\\com.example\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "uninstaller": {
        "script": [
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\com.example\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "bin": "pilinara.exe",
    "shortcuts": [
        [
            "pilinara.exe",
            "PiliNara"
        ]
    ],
    "checkver": {
        "github": "https://api.github.com/repos/Starfallan/PiliNara/releases",
        "jp": "$[0].assets[*].browser_download_url",
        "regex": "/releases/download/(?<tag>[0-9A-Za-z.-]+)/PiliNara_windows_([\\d.]+)%2B([\\d]+)_x64",
        "replace": "${1}.${2}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Starfallan/PiliNara/releases/download/$matchTag/PiliNara_windows_$match1+$match2_x64_portable.zip"
            }
        }
    }
}
