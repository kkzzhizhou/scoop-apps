    "license": "GPL-2.0-or-later",
    "architecture": {
        "64bit": {
            "url": "https://ppsspp.org/files/1_20_3/ppsspp_win.zip",
            "hash": "fb95f2544e6120c035f78df4ed54c0b28ef4eb81fa95ac00a894a7fc50215f6d",
            "shortcuts": [
                [
                    "PPSSPPWindows64.exe",
                    "PPSSPP"
                ]
            ]
        },
        "32bit": {
            "url": "https://ppsspp.org/files/1_20_3/ppsspp_win.zip",
            "hash": "fb95f2544e6120c035f78df4ed54c0b28ef4eb81fa95ac00a894a7fc50215f6d",
            "shortcuts": [
                [
                    "PPSSPPWindows.exe",
                    "PPSSPP"
                ]
            ]
        },
        "arm64": {
            "url": "https://ppsspp.org/files/1_20_3/PPSSPPWindowsARM64.zip",
            "hash": "8eba60d882fd38a78b911c2d49a63be7e4adf4e7637193012d7e2cffb7fed320",
            "shortcuts": [
                [
                    "PPSSPPWindowsARM64.exe",
                    "PPSSPP"
                ]
            ]
        }
    },
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\")) {",
        "   New-item \"$persist_dir\" -ItemType Directory | Out-Null",
        "   New-item \"$persist_dir\\memstick\" -ItemType Directory | Out-Null",
        "}"
    ],
    "persist": [
        "assets",
        "demos",
        "memstick"
    ],
    "checkver": {
        "github": "https://github.com/hrydgard/ppsspp",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://ppsspp.org/files/$underscoreVersion/ppsspp_win.zip"
            },
            "32bit": {
                "url": "https://ppsspp.org/files/$underscoreVersion/ppsspp_win.zip"
            },
            "arm64": {
                "url": "https://ppsspp.org/files/$underscoreVersion/PPSSPPWindowsARM64.zip"
            }
        }
    }
}
