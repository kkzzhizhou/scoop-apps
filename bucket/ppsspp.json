    "license": "GPL-2.0-or-later",
    "architecture": {
        "64bit": {
            "url": "https://ppsspp.org/files/1_20_2/ppsspp_win.zip",
            "hash": "8e356fec7218000d5d6b64e0ae967f84aafbc8deb7af68f026634b8f289e5691",
            "shortcuts": [
                [
                    "PPSSPPWindows64.exe",
                    "PPSSPP"
                ]
            ]
        },
        "32bit": {
            "url": "https://ppsspp.org/files/1_20_2/ppsspp_win.zip",
            "hash": "8e356fec7218000d5d6b64e0ae967f84aafbc8deb7af68f026634b8f289e5691",
            "shortcuts": [
                [
                    "PPSSPPWindows.exe",
                    "PPSSPP"
                ]
            ]
        },
        "arm64": {
            "url": "https://ppsspp.org/files/1_20_2/PPSSPPWindowsARM64.zip",
            "hash": "7acbc4fd1e16f6e3779fe0fdeab44aab86f20e24c2dfee46ccbd1808d99fa87c",
            "shortcuts": [
                [
                    "PPSSPPWindowsARM64.exe",
                    "PPSSPP"
                ]
            ]
        }
    },
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\")) {",
        "   New-item \"$persist_dir\" -ItemType Directory | Out-Null",
        "   New-item \"$persist_dir\\memstick\" -ItemType Directory | Out-Null",
        "}"
    ],
    "persist": [
        "assets",
        "demos",
        "memstick"
    ],
    "checkver": {
        "github": "https://github.com/hrydgard/ppsspp",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://ppsspp.org/files/$underscoreVersion/ppsspp_win.zip"
            },
            "32bit": {
                "url": "https://ppsspp.org/files/$underscoreVersion/ppsspp_win.zip"
            },
            "arm64": {
                "url": "https://ppsspp.org/files/$underscoreVersion/PPSSPPWindowsARM64.zip"
            }
        }
    }
}
