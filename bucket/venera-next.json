{
    "version": "1.13.0",
    "description": "A cross-platform manga reader that supports local manga and online manga sources, available on Android, iOS, Windows, Linux, and macOS platforms",
    "homepage": "https://github.com/CyrilPeng/Venera-Next",
    "license": "GPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://github.com/CyrilPeng/Venera-Next/releases/download/v1.13.0/VeneraNext-1.13.0-windows.zip",
            "hash": "35b0258ece5aeaefb9bf2d1a287008e0358bd9183d0a9b48e901086060d3dcf7",
            "extract_dir": "VeneraNext-1.13.0-windows"
        }
    },
    "shortcuts": [
        [
            "VeneraNext.exe",
            "VeneraNext"
        ]
    ],
    "persist_external": [
        [
            "$env:AppData\\com.github.cyrilpeng",
            "data",
            "directory"
        ],
        [
            "$env:LocalAppData\\com.github.cyrilpeng",
            "cache",
            "directory"
        ]
    ],
    "post_install": [
        ". \"$(Find-BucketDirectory -Root -Name (coalesce $bucket 'muggle'))/scripts/persist-external.ps1\"",
        "Invoke-PersistExternalInstall -Manifest $manifest -PersistDir $persist_dir -Dir $dir"
    ],
    "pre_uninstall": [
        ". \"$(Find-BucketDirectory -Root -Name (coalesce $bucket 'muggle'))/scripts/persist-external.ps1\"",
        "Invoke-PersistExternalUninstall -Manifest $manifest -Dir $dir"
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/CyrilPeng/Venera-Next/releases/download/v$version/VeneraNext-$version-windows.zip",
                "extract_dir": "VeneraNext-$version-windows"
            }
        }
    }
}
