{
    "version": "1.3.3173",
    "description": "A local document search application",
    "homepage": "https://anytxt.net/",
    "license": "GPL-3.0-or-later",
    "architecture": {
        "64bit": {
            "url": "https://sourceforge.net/projects/anytxt/files/Anytxt_1.3.3173_Windows_X86_64.exe",
            "hash": "sha1:66ba4d1fe368661be9be3b9f93751d33af82a017",
            "pre_install": [
                "Get-ChildItem \"$dir\\*,2.*\" -Recurse | Rename-Item -NewName { $_.FullName -replace ',2\\.', '.' }",
                "Get-ChildItem \"$dir\\*,1.*\" -Recurse | Remove-Item"
            ]
        },
        "32bit": {
            "url": "https://sourceforge.net/projects/anytxt/files/Anytxt_1.3.3173_Windows_X86_32.exe",
            "hash": "sha1:f5183ae6450568eca92eb5047aa76cd73e3c3189",
            "pre_install": [
                "Get-ChildItem \"$dir\\*,1.*\" -Recurse | Rename-Item -NewName { $_.FullName -replace ',1\\.', '.' }",
                "Get-ChildItem \"$dir\\*,2.*\" -Recurse | Remove-Item"
            ]
        }
    },
    "innosetup": true,
    "bin": "ATGUI.exe",
    "shortcuts": [
        [
            "ATGUI.exe",
            "AnyTXT Searcher"
        ]
    ],
    "checkver": {
        "url": "https://anytxt.net/download/",
        "regex": "Anytxt_([\\d.]+)_Windows_X86_64\\.exe"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://sourceforge.net/projects/anytxt/files/Anytxt_$version_Windows_X86_64.exe"
            },
            "32bit": {
                "url": "https://sourceforge.net/projects/anytxt/files/Anytxt_$version_Windows_X86_32.exe"
            }
        },
        "hash": {
            "mode": "sourceforge"
        }
    }
}
