    "homepage": "https://docs.gitea.com/usage/actions/act-runner",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://gitea.com/gitea/act_runner/releases/download/v0.3.1/act_runner-0.3.1-windows-amd64.exe.xz",
            "hash": "3fb77cfd78b220f247c56c89e6434c1bab005f5ae48c039cf4040b804d4079de"
        }
    },
    "installer": {
        "script": "Get-Item \"$dir\\act_runner*.exe\" | Rename-Item -NewName 'gitea-runner.exe'"
