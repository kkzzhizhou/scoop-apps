    "bin": "gitea-runner.exe",
    "checkver": {
        "url": "https://gitea.com/api/v1/repos/gitea/act_runner/releases/latest",
        "jsonpath": "$.tag_name",
        "regex": "v([\\d\\.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://gitea.com/gitea/act_runner/releases/download/v$version/act_runner-$version-windows-amd64.exe.xz"
            }
        }
    }
