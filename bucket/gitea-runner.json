{
    "version": "0.5.0",
    "description": "A runner for Gitea based on act",
    "homepage": "https://docs.gitea.com/usage/actions/act-runner",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://gitea.com/gitea/act_runner/releases/download/v0.5.0/act_runner-0.5.0-windows-amd64.exe.xz",
            "hash": "48e6d534b3db25e5bbb8bb99a9d06831689a1c01d7174bef7dfef6900d0e5f94"
        }
    },
    "installer": {
        "script": "Get-Item \"$dir\\act_runner*.exe\" | Rename-Item -NewName 'gitea-runner.exe'"
    },
    "bin": "gitea-runner.exe",
    "checkver": {
        "url": "https://gitea.com/api/v1/repos/gitea/act_runner/releases/latest",
        "jsonpath": "$.tag_name",
        "regex": "v([\\d\\.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://gitea.com/gitea/act_runner/releases/download/v$version/act_runner-$version-windows-amd64.exe.xz"
            }
        }
    }
