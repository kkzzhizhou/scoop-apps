    "homepage": "https://docs.gitea.com/usage/actions/act-runner",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://gitea.com/gitea/act_runner/releases/download/v0.4.0/act_runner-0.4.0-windows-amd64.exe.xz",
            "hash": "d21e459588f6904e29cddd4cc08edc0a35c3f0d1b6fb62610c5b3c19075b6309"
        }
    },
    "installer": {
        "script": "Get-Item \"$dir\\act_runner*.exe\" | Rename-Item -NewName 'gitea-runner.exe'"
