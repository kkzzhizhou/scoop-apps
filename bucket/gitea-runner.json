    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://gitea.com/gitea/act_runner/releases/download/v0.6.0/act_runner-0.6.0-windows-amd64.exe.xz",
            "hash": "5b8ed38d1e122c430bf409e5f749b4c9a65563be94c84bc0f5d1eecddaf3925a"
        }
    },
    "installer": {
