    "hash": "a420ff143ee7a1559c1efc1c57947737c80d7330a1deac9161f35c6b6d8033f9",
    "architecture": {
        "64bit": {
            "installer": {
                "script": "Expand-7ZipArchive \"$dir\\app64.7z\" \"$dir\" -Removal"
            }
        }
    },
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\\config.ini\")) {",
        "    New-Item -Force -Path \"$persist_dir\\config.ini\" -ItemType File -Value \"[ConfigInfo]`nautoStart=0\" | Out-Null",
        "}"
    ],
    "post_install": "Remove-Item \"$dir\\`$PLUGINSDIR\",\"$dir\\app*.7z\",\"$dir\\uninst.exe\" -Force -Recurse",
    "pre_uninstall": [
        "if ($cmd -eq 'uninstall') {",
        "    if (!(is_admin)) {",
        "        Start-Process -Wait powershell.exe -ArgumentList \"-Command sc.exe delete ToDesk_Service\" -Verb RunAs -WindowStyle Hidden",
        "    } else {",
        "        sc.exe delete ToDesk_Service",
        "    }",
        "}"
    ],
    "shortcuts": [
        [
            "ToDesk.exe",
            "ToDesk"
        ]
    ],
    "persist": [
        "Logs",
        "config.ini"
    ],
    "checkver": {
        "url": "https://update.todesk.com/windows/uplog.html",
        "regex": "<div class=\"text\">([\\d.]+)</div>"
    },
    "autoupdate": {
        "url": "https://dl.todesk.com/windows/ToDesk_Setup.exe#/dl.7z"
    }
