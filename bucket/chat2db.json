{
    "version": "3.4.1",
    "description": "An intelligent and versatile general-purpose SQL client and reporting tool for databases which integrates ChatGPT capabilities.",
    "homepage": "https://github.com/OtterMind/Chat2DB",
    "license": "Apache-2.0",
    "url": "https://github.com/OtterMind/Chat2DB/releases/download/v3.4.1/Chat2DB-Setup-3.4.1.exe",
    "hash": "sha256:da7c6b2573cbaebd52128edeb987ecb93df48124775d8b77909afbf31c773a06",
    "installer": {
        "script": [
            "Expand-7zipArchive -Path \"$dir\\Chat2DB-Setup-$version.exe\" -Removal",
            "Expand-7zipArchive -Path \"$dir\\`$PLUGINSDIR\\app-64.7z\" -DestinationPath $dir"
        ]
    },
    "post_install": [
        "Remove-Item \"$dir\\`$PLUGINSDIR\" -Force -Recurse",
        "Remove-Item \"$dir\\`$R0\" -Force -Recurse"
    ],
    "bin": "chat2db.exe",
    "shortcuts": [
        [
            "chat2db.exe",
            "Chat2DB"
        ]
    ],
    "checkver": {
        "url": "https://github.com/OtterMind/Chat2DB/releases",
        "regex": "tag/v([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://github.com/OtterMind/Chat2DB/releases/download/v$version/Chat2DB-Setup-$version.exe"
    },
    "notes": [
        "【工具类型】: 开发工具",
        "【主要功能】: 智能SQL客户端和数据库报告工具，集成ChatGPT功能",
        "【适用场景】: 数据库管理、SQL查询、数据分析",
        "【技术特点】: 提供图形化界面，支持AI辅助查询"
    ]
}
