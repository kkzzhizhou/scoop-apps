{
    "version": "0.11.28",
    "description": "An extremely fast Python package installer and resolver, written in Rust.",
    "homepage": "https://github.com/astral-sh/uv",
    "license": "Apache-2.0|MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/astral-sh/uv/releases/download/0.11.28/uv-x86_64-pc-windows-msvc.zip",
            "hash": "0a23463216d09c6a72ff80ef5dc5a795f07dc1575cb84d24596c2f124a441b7b"
        },
        "32bit": {
            "url": "https://github.com/astral-sh/uv/releases/download/0.11.28/uv-i686-pc-windows-msvc.zip",
            "hash": "01975deb06072edfc1f18435c25737d8d378dc849b918cd580768ab3b7641e85"
        }
    },
    "bin": [
        "uv.exe",
        "uvx.exe"
    ],
    "persist": "data",
    "env_set": {
        "UV_INDEX_URL": "https://mirrors.aliyun.com/pypi/simple",
        "UV_CACHE_DIR": "$dir\\data\\cache",
