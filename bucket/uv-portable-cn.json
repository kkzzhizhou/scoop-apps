{
    "version": "0.11.16",
    "description": "An extremely fast Python package installer and resolver, written in Rust.",
    "homepage": "https://github.com/astral-sh/uv",
    "license": "Apache-2.0|MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/astral-sh/uv/releases/download/0.11.16/uv-x86_64-pc-windows-msvc.zip",
            "hash": "dd9d6d6554bfab265bfa98aa8e8a406c5c3a7b97582f93de1f4d48d9154a0395"
        },
        "32bit": {
            "url": "https://github.com/astral-sh/uv/releases/download/0.11.16/uv-i686-pc-windows-msvc.zip",
            "hash": "7417090298bf202395b9b3d6eefb9230332d8d6c94a5616e531148a0b041c8e2"
        }
    },
    "bin": [
        "uv.exe",
        "uvx.exe"
    ],
    "persist": "data",
    "env_set": {
        "UV_INDEX_URL": "https://mirrors.aliyun.com/pypi/simple",
        "UV_CACHE_DIR": "$dir\\data\\cache",
