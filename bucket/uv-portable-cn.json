{
    "version": "0.11.29",
    "description": "An extremely fast Python package installer and resolver, written in Rust.",
    "homepage": "https://github.com/astral-sh/uv",
    "license": "Apache-2.0|MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/astral-sh/uv/releases/download/0.11.29/uv-x86_64-pc-windows-msvc.zip",
            "hash": "a047d55651bc3e0ca24595b25ec4cfcb10f9dca9fb56514e661269b37d4fae68"
        },
        "32bit": {
            "url": "https://github.com/astral-sh/uv/releases/download/0.11.29/uv-i686-pc-windows-msvc.zip",
            "hash": "c173af6f6e125d65214b55d6b75fcf1a32d5e1c3a656938740fe0b2379cd4bcc"
        }
    },
    "bin": [
        "uv.exe",
        "uvx.exe"
    ],
    "persist": "data",
    "env_set": {
        "UV_INDEX_URL": "https://mirrors.aliyun.com/pypi/simple",
