{
    "version": "0.11.10",
    "description": "An extremely fast Python package installer and resolver, written in Rust.",
    "homepage": "https://github.com/astral-sh/uv",
    "license": "Apache-2.0|MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/astral-sh/uv/releases/download/0.11.10/uv-x86_64-pc-windows-msvc.zip",
            "hash": "7a0c424c7bc55a74751f13592235953ebbe182fa00355f7ae3fb7ab734a51638"
        },
        "32bit": {
            "url": "https://github.com/astral-sh/uv/releases/download/0.11.10/uv-i686-pc-windows-msvc.zip",
            "hash": "d56ad43d355d6c40fee4009d0fb7e6710416ce9b25bebf12a4127e51b3595b3c"
        }
    },
    "bin": [
        "uv.exe",
        "uvx.exe"
    ],
    "persist": "data",
    "env_set": {
        "UV_INDEX_URL": "https://mirrors.aliyun.com/pypi/simple",
        "UV_CACHE_DIR": "$dir\\data\\cache",
        "UV_TOOL_DIR": "$dir\\data\\tool",
        "UV_TOOL_BIN_DIR": "$dir\\data\\bin",
        "UV_PYTHON_INSTALL_DIR": "$dir\\data\\python"
    },
    "env_add_path": "data\\bin",
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/astral-sh/uv/releases/download/$version/uv-x86_64-pc-windows-msvc.zip"
            },
            "32bit": {
                "url": "https://github.com/astral-sh/uv/releases/download/$version/uv-i686-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "url": "$url.sha256"
        }
    }
}
