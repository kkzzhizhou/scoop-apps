{
	"version": "3.1.0",
	"description": "Tiny alternative Discord client with a smaller footprint, themes and plugins, multi-profile, and more!",
	"homepage": "https://github.com/SpikeHD/Orbolay",
	"license": {
		"identifier": "GPL-3.0",
		"url": "https://github.com/SpikeHD/Orbolay/blob/main/LICENSE"
	},
	"architecture": {
		"64bit": {
			"url": "https://github.com/SpikeHD/Orbolay/releases/download/v3.1.0/orbolay-x86_64-pc-windows-msvc.exe#/orbolay.exe",
			"hash": "a21be56148f83e04e10d16ce8eacea047b755e83642536de38af3f391fceae96"
		}
	},
	"checkver": {
		"script": [
			"$rel_info = Invoke-RestMethod -Uri 'https://api.github.com/repos/SpikeHD/Orbolay/releases'",
			"$latest = $rel_info | Sort-Object {$_.published_at} | Select-Object -last 1",
			"$latest_asset = $latest.assets | Where-Object {$_.name -eq 'orbolay-x86_64-pc-windows-msvc.exe'} | Select-Object -first 1",
			"Write-Output $latest.tag_name $latest_asset.digest"
		],
		"regex": "v(?<version>[\\d\\w\\.\\-]+)\\s(?<hash>[^\\s]+)?"
	},
	"autoupdate": {
		"architecture": {
			"64bit": {
				"url": "https://github.com/SpikeHD/Orbolay/releases/download/v$version/orbolay-x86_64-pc-windows-msvc.exe#/orbolay.exe",
				"hash": "$matchHash"
			}
		}
	},
	"shortcuts": [["orbolay.exe", "Orbolay"]]
}
