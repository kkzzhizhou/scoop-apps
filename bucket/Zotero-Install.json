{
    "version": "9.0.1",
    "description": "Zotero. Free, easy-to-use tool to help you collect, organize, cite, and share research",
    "homepage": "https://www.zotero.org/",
    "license": "Proprietary",
    "suggest": {
        "sudo": [
            "main/gsudo",
            "main/sudo"
        ]
    },
    "changelog": "https://www.zotero.org/support/changelog",
    "architecture": {
        "64bit": {
            "url": "https://download.zotero.org/client/release/9.0.1/Zotero-9.0.1_x64_setup.exe#/setup.exe",
            "hash": "531ce0b3ebdb4e25266d149bd88b835ce1bc0c801fc58385845c29c13a4d9314"
        },
        "32bit": {
            "url": "https://download.zotero.org/client/release/9.0.1/Zotero-9.0.1_win32_setup.exe#/setup.exe",
            "hash": "f7c8188c53838ba90cdd2148b273621a8e6b0809e8f5cc9ba4a9289e44dc6b0d"
        },
        "arm64": {
            "url": "https://download.zotero.org/client/release/9.0.1/Zotero-9.0.1_arm64_setup.exe#/setup.exe",
            "hash": "db105962993c950d2eab36c8928ef5865c6a7e556eca688ecfedd84df5e3f3c4"
        }
    },
    "pre_download": "Assert-Administrator",
    "pre_install": [
        "$processname = \"Zotero\"",
        "$process = Get-Process $processname -ErrorAction SilentlyContinue",
        "if ($process) {",
        "   $process.CloseMainWindow()",
        "   Start-Sleep -Seconds 5",
        "   if (!$process.HasExited) {",
        "       Start-Sleep -Seconds 25",
        "       $process | Stop-Process -Force",
        "   }",
        "}"
    ],
    "installer": {
        "script": [
            "$programname = \"programname*\"",
            "$ProgramFiles = [Environment]::GetFolderPath(\"ProgramFilesX86\")",
            "$filepath = \"$ProgramFiles\\Zotero\\Zotero.exe\"",
            "if(((Test-Path -Path $filepath -PathType Leaf) -eq $false) -or ((Get-Command $filepath).Version -lt [System.Version]\"$version\"))",
            "{",
            "   &\"$dir\\setup.exe\" /S | Out-Null",
            "   if(((Test-Path -Path $filepath -PathType Leaf) -eq $false) -or ((Get-Command $filepath).Version -lt [System.Version]\"$version\"))",
            "   {",
            "       exit 1",
            "   }",
            "}",
            "if (Test-Path -Path \"$dir\\setup.exe\") { Remove-Item \"$dir\\setup.exe\" -Force }"
        ]
    },
    "post_install": [
        "$programname = \"Zotero\"",
        "$CommonDesktopPath = [Environment]::GetFolderPath(\"CommonDesktopDirectory\")",
        "if (Test-Path \"$CommonDesktopPath\\$programname.lnk\") {Remove-Item \"$CommonDesktopPath\\$programname.lnk\" -Force}"
    ],
    "checkver": {
        "url": "https://www.zotero.org/download/",
        "regex": "win-x64\":\"([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.zotero.org/client/release/$version/Zotero-$version_x64_setup.exe#/setup.exe"
            },
            "32bit": {
                "url": "https://download.zotero.org/client/release/$version/Zotero-$version_win32_setup.exe#/setup.exe"
            },
            "arm64": {
                "url": "https://download.zotero.org/client/release/$version/Zotero-$version_arm64_setup.exe#/setup.exe"
            }
        }
    }
}
