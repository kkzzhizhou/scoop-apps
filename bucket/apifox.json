{
    "version": "2.8.32",
    "description": "Apifox 是 API 文档、API 调试、API Mock、API 自动化测试一体化协作平台，定位 Postman + Swagger + Mock + JMeter。",
    "homepage": "https://apifox.com",
    "notes": "https://github.com/ViCrack/scoop-bucket/blob/master/bucket/apifox.json",
    "license": "Freeware",
    "architecture": {
        "32bit": {
            "url": "https://file-assets.apifox.com/download/2.8.32/Apifox-windows-x86-2.8.32.exe#/dl.7z",
            "hash": "4cabdf83cb8986b7f5374af7e42262a314928617816c390af72621cf6cec28d8"
        },
        "64bit": {
            "url": "https://file-assets.apifox.com/download/2.8.32/Apifox-2.8.32.exe#/dl.7z",
            "hash": "c437ce8a25b831e5712df5f698b54583bd05e1598ff6a7ec8c2c5be162ad134a"
        }
    },
    "pre_install": [
        "Get-Item \"$dir\\`$PLUGINSDIR\\app*.7z\" | Expand-7zipArchive -DestinationPath \"$dir\"",
        "Remove-Item \"$dir\\`$*\", \"$dir\\Uninstall*\" -Force -Recurse"
    ],
    "shortcuts": [
        [
            "Apifox.exe",
            "Apifox",
            "--user-data-dir=\"$dir\\UserData\""
        ]
    ],
    "persist": "UserData",
    "checkver": {
        "url": "https://api.apifox.cn/api/v1/configs/client-updates/2.7.29/win64/latest.yml?",
        "regex": "version:\\s*([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "32bit": {
                "url": "https://file-assets.apifox.com/download/$version/Apifox-windows-x86-$version.exe#/dl.7z"
            },
            "64bit": {
                "url": "https://file-assets.apifox.com/download/$version/Apifox-$version.exe#/dl.7z"
            }
        }
    }
}
