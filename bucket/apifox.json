    "homepage": "https://apifox.com",
    "notes": "https://github.com/ViCrack/scoop-bucket/blob/master/bucket/apifox.json",
    "license": "Freeware",
    "architecture": {
        "32bit": {
            "url": "https://file-assets.apifox.com/download/2.8.34/Apifox-windows-x86-2.8.34.exe#/dl.7z",
            "hash": "9d47f846e74fe07605af57280f60861758bc56a78c163def8604247d55a57a04"
        },
        "64bit": {
            "url": "https://file-assets.apifox.com/download/2.8.34/Apifox-2.8.34.exe#/dl.7z",
            "hash": "ee3ee907a4e02ddeeec6845319f6111ad13c4c09fab47d7293e456bba1932c69"
        }
    },
    "pre_install": [
        "Get-Item \"$dir\\`$PLUGINSDIR\\app*.7z\" | Expand-7zipArchive -DestinationPath \"$dir\"",
        "Remove-Item \"$dir\\`$*\", \"$dir\\Uninstall*\" -Force -Recurse"
    ],
    "shortcuts": [
        [
            "Apifox.exe",
            "Apifox",
            "--user-data-dir=\"$dir\\UserData\""
        ]
    ],
    "persist": "UserData",
    "checkver": {
        "url": "https://api.apifox.cn/api/v1/configs/client-updates/2.7.29/win64/latest.yml?",
        "regex": "version:\\s*([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "32bit": {
                "url": "https://file-assets.apifox.com/download/$version/Apifox-windows-x86-$version.exe#/dl.7z"
            },
            "64bit": {
                "url": "https://file-assets.apifox.com/download/$version/Apifox-$version.exe#/dl.7z"
            }
        }
    }
