{
	"version": "2026.06.26-970fddc",
	"description": "Fast and multi-platform Spotify client with native GUI",
	"homepage": "https://github.com/jpochyla/psst",
	"license": {
		"identifier": "MIT",
		"url": "https://github.com/jpochyla/psst/blob/master/LICENSE.md"
	},
	"url": "https://github.com/jpochyla/psst/releases/download/rolling/Psst.exe#/psst.exe",
	"hash": "f4be1f3d98df42b23fbb3cc4eea1c1e40d66e7fb055579df394f3f6268f3351c",
	"checkver": {
		"script": [
			"$rel_info = Invoke-RestMethod -Uri 'https://api.github.com/repos/jpochyla/psst/releases'",
			"$latest_rel = $rel_info | Sort-Object {$_.published_at} | Select-Object -last 1",
			"$latest_exe = $latest_rel.assets | Where-Object {$_.name.EndsWith(\".exe\")} | Sort-Object {$_.published_at} | Select-Object -last 1",
			"Write-Output $latest_rel.name $latest_exe.browser_download_url $latest_exe.digest"
		],
		"regex": "\\((?<version>[\\w\\d.-]+)\\)\\s+(?<url>[^\\s]+)\\s(?<hash>[^\\s]+)?"
	},
	"autoupdate": {
		"url": "$matchUrl#/psst.exe",
		"hash": "$matchHash"
	},
	"shortcuts": [["psst.exe", "Psst"]]
}
