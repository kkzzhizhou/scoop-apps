{
    "version": "0.104.0",
    "description": "All-in-one repack for latest Microsoft Visual C++ Redistributable Runtimes, without the original setup bloat payload.",
    "homepage": "https://gitlab.com/stdout12/vcredist",
    "license": {
        "identifier": "Unlicense",
        "url": "https://gitlab.com/stdout12/vcredist/-/blob/HEAD/LICENSE"
    },
    "notes": "View command-line options and usage examples by executing: `vcredist-aio.exe /?`",
    "url": "https://gitlab.com/-/project/76069787/uploads/7ac239df097798761af40e0302fbd310/VisualCppRedist_AIO_x86_x64.exe#/vcredist-aio.exe",
    "hash": "bfde422ac0f3428c311c173bce42a7fb6699c628f05876633b3a0f8a94fcc332",
    "installer": {
        "script": [
            "if (-not (is_admin)) { error 'This package requires admin rights to install'; break }",
            "Start-Process -FilePath \"$dir\\$fname\" -ArgumentList @('/ai', '/gm2') -Verb RunAs -Wait"
        ]
    },
    "bin": "vcredist-aio.exe",
    "checkver": {
        "url": "https://gitlab.com/api/v4/projects/76069787/releases/permalink/latest",
        "jsonpath": "$..['name', 'description']",
        "regex": "\"v([\\d.]+)\",\"[^\"]+\\[.+?_x86_x64\\.exe\\]\\(/uploads/(?<hash>\\w+)/"
    },
    "autoupdate": {
        "url": "https://gitlab.com/-/project/76069787/uploads/$matchHash/VisualCppRedist_AIO_x86_x64.exe#/vcredist-aio.exe",
        "hash": {
            "url": "https://gitlab.com/api/v4/projects/76069787/releases/permalink/latest",
            "regex": "$basename.+?SHA-256:\\s*$sha256"
        }
    }
}
