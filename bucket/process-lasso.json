{
	"homepage": "https://bitsum.com/",
	"description": "Real-Time CPU Optimization and Automation",
	"version": "18.0.65+rel.03.04.2026.1129",
	"license": "Freemium",
	"url": "https://dl.bitsum.com/files/beta/processlassosetup64.exe#/dl.7z",
	"hash": "8286bff6e4adec10cf44b51b203c5396594438c578f45094d1a3d6f244261f49",
	"extract_to": "Process Lasso",
	"shortcuts": [["Process Lasso/ProcessLassoLauncher.exe", "Process Lasso"]],
	"persist": ["Process Lasso/config", "Process Lasso/logs"],
	"installer": {
		"script": "Remove-Item \"$dir/Process Lasso/`$PLUGINSDIR\" -Recurse"
	},
	"checkver": {
		"script": [
			"# Get stable version from changelog",
			"$changes = Invoke-WebRequest -Uri 'https://bitsum.com/changes/processlasso' -UseBasicParsing",
			"$version_pattern = '<strong>v?([\\d.]+)[^<]*?&#8211;\\s*([^<]+?)</strong>'",
			"$latest_vers = [regex]::Matches($changes.Content, $version_pattern)",
			"$latest_release = $latest_vers | Sort-Object { try { Get-Date $_.Groups[2].Value.Trim() } catch { [DateTime]::MinValue } } | Select-Object -last 1",
			"$stable_version = $latest_release.Groups[1].Value.Trim()",
			"",
			"# Get beta version from current_version_processlasso.txt",
			"$current_version_details = Invoke-WebRequest -Uri 'https://bitsum.com/current_version_processlasso.txt' -UseBasicParsing",
			"$content = $current_version_details.Content -split \"`r?`n\" | Where-Object {$_ -ne ''}",
			"$first_line = $content[0]",
			"$beta_match = $first_line | Select-String 'v([\\d.]+)'",
			"$beta_version = $null",
			"if ($beta_match) {",
			"    $beta_version = $beta_match.Matches.Groups[1].Value.Trim()",
			"}",
			"",
			"# Extract beta revision from lines like '(39)'",
			"$beta_revision = $null",
			"$revision_line = $content | Select-String \"^\\((\\d+)\\)\" -CaseSensitive | Select-Object -first 1",
			"if ($revision_line) {",
			"    $beta_revision = $revision_line.Matches.Groups[1].Value",
			"}",
			"",
			"# Extract date from last two lines of beta file",
			"$date_time_format = \"dd.MM.yyyy\"",
			"$release_date_time = $null",
			"$last_lines = $content[-2..-1] | Where-Object { $_ -ne $null }",
			"if ($last_lines.Count -eq 2) {",
			"    $full_date_string = \"$($last_lines[0].Trim()) $($last_lines[1].Trim())\"",
			"    try {",
			"        $release_date_time = Get-Date $full_date_string",
			"        if ($release_date_time.Hour -ne 0 -or $release_date_time.Minute -ne 0) {",
			"            $date_time_format = \"dd.MM.yyyy.HHmm\"",
			"        }",
			"    } catch {",
			"        $release_date_time = Get-Date",
			"    }",
			"} else {",
			"    $release_date_time = Get-Date",
			"}",
			"",
			"# Function to compare version numbers",
			"function Compare-Version($v1, $v2) {",
			"    if (-not $v1) { return -1 }",
			"    if (-not $v2) { return 1 }",
			"    $parts1 = $v1 -split '\\.'",
			"    $parts2 = $v2 -split '\\.'",
			"    $max = [Math]::Max($parts1.Length, $parts2.Length)",
			"    for ($i = 0; $i -lt $max; $i++) {",
			"        $n1 = if ($i -lt $parts1.Length) { [int]$parts1[$i] } else { 0 }",
			"        $n2 = if ($i -lt $parts2.Length) { [int]$parts2[$i] } else { 0 }",
			"        if ($n1 -gt $n2) { return 1 }",
			"        if ($n1 -lt $n2) { return -1 }",
			"    }",
			"    return 0",
			"}",
			"",
			"# Compare and select the latest version",
			"$base_version = $null",
			"$url_segment = \"\"",
			"$semver_suffix = \"\"",
			"$is_beta = $false",
			"",
			"if ($stable_version -and $beta_version) {",
			"    $comparison = Compare-Version $beta_version $stable_version",
			"    if ($comparison -gt 0) {",
			"        # Beta is newer",
			"        $base_version = $beta_version",
			"        $url_segment = 'beta/'",
			"        $is_beta = $true",
			"        if ($beta_revision) {",
			"            $semver_suffix = \".$beta_revision\"",
			"        }",
			"    } else {",
			"        # Stable is newer or equal",
			"        $base_version = $stable_version",
			"    }",
			"} elseif ($stable_version) {",
			"    $base_version = $stable_version",
			"} elseif ($beta_version) {",
			"    $base_version = $beta_version",
			"    $url_segment = 'beta/'",
			"    $is_beta = $true",
			"    if ($beta_revision) {",
			"        $semver_suffix = \".$beta_revision\"",
			"    }",
			"} else {",
			"    $base_version = \"unknown\"",
			"}",
			"",
			"# Only add +rel. metadata for beta versions",
			"if ($is_beta) {",
			"    $semver_metadata = \"+rel.$($release_date_time.ToString($date_time_format))\"",
			"    $semver = \"$base_version$semver_suffix$semver_metadata\"",
			"} else {",
			"    $semver = $base_version",
			"}",
			"Write-Output \"$url_segment $semver\""
		],
		"regex": "(?<url>[\\w/]*)\\s(?<version>[\\d\\w\\.\\-\\+]+)"
	},
	"autoupdate": {
		"url": "https://dl.bitsum.com/files/$matchUrlprocesslassosetup64.exe#/dl.7z"
	}
}
