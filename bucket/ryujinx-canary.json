{
    "version": "1.3.337",
    "description": "A simple, experimental Nintendo Switch emulator (canary version)",
    "homepage": "https://ryujinx.app/",
    "license": {
        "identifier": "MIT",
        "url": "https://git.ryujinx.app/ryubing/ryujinx/raw/branch/master/LICENSE.txt"
    },
    "notes": [
        "ATTENTION: Ryujinx requires Nintendo Switch firmware and a prod.keys file to function.",
        "Learn more at https://git.ryujinx.app/ryubing/ryujinx/wiki/FAQ-&-Troubleshooting"
    ],
    "architecture": {
        "64bit": {
            "url": "https://git.ryujinx.app/ryubing/canary/releases/download/1.3.337/ryujinx-canary-1.3.337-win_x64.zip",
            "hash": "69402eaac3c80db0108ae985fbc828802ab305a791b17aaf756a6276c9c00f42"
        },
        "arm64": {
            "url": "https://git.ryujinx.app/ryubing/canary/releases/download/1.3.337/ryujinx-canary-1.3.337-win_arm64.zip",
            "hash": "d029e6cab50c340fdb039d3b2f3a47390e7c267077f6610e33d94a26e5b63834"
        }
    },
    "extract_dir": "publish",
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\")) {",
        "   New-item \"$persist_dir\\portable\" -ItemType Directory | Out-Null",
        "   if (Test-Path \"$env:APPDATA\\Ryujinx\") {",
        "       Write-host \"Migrating AppData...\" -ForegroundColor yellow",
        "       Copy-Item -Path \"$env:APPDATA\\Ryujinx\\*\" -Destination \"$persist_dir\\portable\" -Recurse",
        "       Remove-Item -Path \"$env:APPDATA\\Ryujinx\" -Recurse",
        "   }",
        "}"
    ],
    "bin": [
        [
            "Ryujinx.exe",
            "ryujinx-canary"
        ]
    ],
    "shortcuts": [
        [
            "Ryujinx.exe",
            "Ryujinx (canary)"
        ]
    ],
    "persist": "portable",
    "checkver": {
        "url": "https://git.ryujinx.app/api/v1/repos/ryubing/canary/releases/latest",
        "jsonpath": "$.tag_name"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://git.ryujinx.app/ryubing/canary/releases/download/$version/ryujinx-canary-$version-win_x64.zip"
            },
            "arm64": {
                "url": "https://git.ryujinx.app/ryubing/canary/releases/download/$version/ryujinx-canary-$version-win_arm64.zip"
            }
        }
    }
}
