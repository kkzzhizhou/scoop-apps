            "hash": "99ce4e8dec49087f62ad3e157ea5345e03cd2b7e0fd29990dc312a8ab247d32b"
        },
        "arm64": {
            "url": "https://perplexity.ai/rest/browser/download?platform=win_arm64&channel=stable#/updater.exe",
            "hash": "1ca64db86be414d86f27ba580884b496509fab48001a9c5654636bd1b6b5717c"
        }
    },
    "extract_dir": "",
    "pre_install": [
        "$log = \"$dir\\install.log\"",
        "$ProgressPreference = 'SilentlyContinue'",

        "7z x \"$dir\\updater.exe\" -o\"$dir\\updater\" -y -bd *> $log",
        "$packed = Get-ChildItem \"$dir\\updater\" -Recurse -Include *.7z | Select-Object -First 1",
        "if (-not $packed) { throw 'No embedded .7z archive found' }",

        "7z x \"$($packed.FullName)\" -o\"$dir\\inner\" -y -bd *> $log",
        "$mini = Get-ChildItem \"$dir\\inner\" -Recurse -Filter mini_installer.exe | Select-Object -First 1",
        "if (-not $mini) { throw 'mini_installer.exe not found' }",

        "7z x \"$($mini.FullName)\" -o\"$dir\\mini\" -y -bd *> $log",
        "Expand-7zipArchive \"$dir\\mini\\chrome.7z\" -ExtractDir 'Chrome-bin' -DestinationPath \"$dir\" -Removal",

        "Remove-Item \"$dir\\chrome.exe\" -Force -ErrorAction SilentlyContinue"
    ],
    "post_install": [
        "Remove-Item \"$dir\\updater\",\"$dir\\inner\",\"$dir\\mini\" -Recurse -Force -ErrorAction SilentlyContinue",
        "Remove-Item \"$dir\\updater.exe\",\"$dir\\updater.bin\",\"$dir\\updater.7z\" -Force -ErrorAction SilentlyContinue"
    ],
    "bin": [
        [
            "comet.exe",
            "comet",
            "--user-data-dir=\"$dir\\User Data\""
        ]
    ],
    "shortcuts": [
        [
            "comet.exe",
            "Comet",
            "--user-data-dir=\"$dir\\User Data\""
        ]
    ],
    "persist": "User Data",
    "checkver": {
        "url": "https://api.github.com/repositories/197275551/contents/manifests/p/Perplexity/Comet",
        "jsonpath": "$..name",
        "regex": "([\\d.]+)"
    },
    "autoupdate": {
