{
    "version": "2026-05-18T12.15.10",
    "description": "fridaUiTools是一个界面化整理脚本的工具。",
    "notes": [
        "【工具类型】: 逆向工程工具",
        "【主要功能】: fridaUiTools是一个界面化整理脚本的工具。",
        "【适用场景】: 移动应用逆向分析、Frida脚本管理与执行",
        "【技术特点】: 基于Frida框架，支持动态插桩"
    ],
    "homepage": "https://github.com/dqzg12300/fridaUiTools",
    "license": "UNKNOWN",
    "suggest": {
        "python": "uv"
    },
    "url": "https://github.com/dqzg12300/fridaUiTools/archive/refs/heads/master.zip",
    "hash": "",
    "pre_install": [
        "Set-Content \"$dir\\fridaUiTools.bat\" '@pushd %~dp0",
        "@uv run python \"kmainForm.py\" %*",
        "@popd' -Encoding Ascii"
    ],
    "post_install": [
        "uv venv \"$dir\\.venv\"",
        "uv pip install -r $dir\\requirements.txt --python \"$dir\\.venv\\Scripts\\python.exe\""
    ],
    "extract_dir": "fridaUiTools-master",
    "bin": "fridaUiTools.bat",
    "checkver": {
        "url": "https://api.github.com/repos/dqzg12300/fridaUiTools/commits",
        "regex": "([\\d-]+T)(\\d+):(\\d+):(\\d+)",
        "replace": "$1$2.$3.$4"
    },
    "autoupdate": {
        "url": "https://github.com/dqzg12300/fridaUiTools/archive/refs/heads/master.zip"
    }
}
