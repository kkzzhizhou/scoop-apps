{
    "version": "0.6.11",
    "description": "TeXworks is a LaTeX editor with integrated PDF viewer and a clean, simple interface.",
    "homepage": "http://tug.org/texworks/",
    "url": "https://github.com/TeXworks/texworks/releases/download/release-0.6.11/TeXworks-win10-0.6.11-202602100835-git_7951fd8.zip",
    "hash": "3a929a495647e5b3a6e5fc1e8f127f3702601e0526f954945debd7c4d2ba7b6b",
    "pre_install": [
        "if(!(Test-Path \"$dir/texworks-setup.ini\")) {",
        "Add-Content \"$dir/texworks-setup.ini\" \"inipath = ./setting/`r`libpath = ./setting/\"",
        "}"
    ],
    "bin": "TeXworks.exe",
    "shortcuts": [
        [
            "TeXworks.exe",
            "TeXworks"
        ]
    ],
    "persist": [
        "setting",
        "texworks-setup.ini"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/TeXworks/texworks/releases/latest",
        "regex": "TeXworks-win10-([\\d.]+)-(?<date>[\\d]+)-git_(?<commit>[\\w]{7}).zip"
    },
    "autoupdate": {
        "url": "https://github.com/TeXworks/texworks/releases/download/release-$version/TeXworks-win10-$version-$matchDate-git_$matchCommit.zip",
        "hash": {
            "url": "https://github.com/TeXworks/texworks/releases/tag/release-0.6.8",
            "regex": "(?sm)TeXworks-win10-$version-$matchDate-git_$matchCommit.zip.*?$sha256"
        }
    }
}
