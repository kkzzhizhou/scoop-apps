{
	"version": "v7-preview.2",
	"description": "CUDA on AMD GPUs.",
	"homepage": "https://github.com/vosen/ZLUDA",
	"license": {
		"identifier": "Apache-2.0",
		"url": "https://github.com/vosen/ZLUDA/blob/master/LICENSE-APACHE"
	},
	"url": "https://github.com/vosen/ZLUDA/releases/download/v7-preview.2/zluda-windows-9c8d00c.zip",
	"hash": "045da24d07d03df69b8a0ee2d418de4f1ec0d13ef104e16095054dddbd5a6746",
	"extract_dir": "zluda",
	"bin": ["zluda.exe", "zluda_precompile.exe", "ptxas.exe"],
	"checkver": {
		"script": [
			"$rel_list = Invoke-RestMethod -Uri 'https://api.github.com/repos/vosen/ZLUDA/releases'",
			"$rel = $rel_list | Sort-Object {$_.published_at} | Select-Object -last 1",
			"$asset = $rel.assets | Where-Object { $_.name -match 'windows' } | Select-Object -first 1",
			"Write-Output $rel.tag_name $asset.browser_download_url $asset.digest"
		],
		"regex": "(?<version>[\\w\\d.-]+)\\s(?<url>[^\\s]+)\\s(?<hash>[^\\s]+)?"
	},
	"autoupdate": {
		"url": "$matchUrl",
		"hash": "$matchHash"
	}
}
