{
    "homepage": "https://eden-emu.dev",
    "version": "0.2.1",
    "description": "Nintendo Switch Emulator, a fork of Yuzu",
    "license": {
        "identifier": "GPL-3.0",
        "url": "https://git.eden-emu.dev/eden-emu/eden/src/branch/master/LICENSE.txt"
    },
    "suggest": {
        "Microsoft Visual C++ Runtime 2022": "extras/vcredist2022"
    },
    "url": "https://stable.eden-emu.dev/v0.2.1/Eden-Windows-v0.2.1-amd64-msvc-standard.zip",
    "hash": "ff498e5da9630216926ac3cbe9fb493b14930665c728a40a8f5b59507fdd7ebf",
    "pre_install": "mkdir $dir/user | Out-Null",
    "bin": "eden.exe",
    "shortcuts": [
        [
            "eden.exe",
            "Nintendo Switch"
        ]
    ],
    "persist": "user",
    "checkver": {
        "url": "https://git.eden-emu.dev/api/v1/repos/eden-emu/eden/releases",
        "jsonpath": {
            "version": "$.[0].name",
            "download": "$.[0].assets[?(@.name =~ /Windows.+amd64-msvc/i)].browser_download_url"
        },
        "regex": "Eden v([\\d\\.\\-rc]+)"
    },
    "autoupdate": {
        "url": "$matchDownload"
    }
}
