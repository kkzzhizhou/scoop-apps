{
    "version": "149.0.2",
    "description": "Popular open source web browser",
    "homepage": "https://www.mozilla.org/firefox/",
    "license": "MPL-2.0",
    "notes": [
        "To set 'Scoop' as the default profile, or profiles/settings was lost after update:",
        "  - Run 'Firefox Profile Manager', choose 'Scoop' or previously using profile then click 'Start Firefox'.",
        "  - Visit 'about:profiles' page in Firefox to check the current default profile.",
        "For details: https://support.mozilla.org/en-US/kb/profile-manager-create-remove-switch-firefox-profiles"
    ],
    "architecture": {
        "64bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/149.0.2/win64/en-US/Firefox%20Setup%20149.0.2.exe#/dl.7z",
            "hash": "sha512:fd0ea2b5e85800fa17d3803506a4a83405ccf06559beb275f7be1b6acfa4996358c9f36c7e34b57686ca5e804c6ab839969d153186dbd7370de2611316c45e24"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/149.0.2/win32/en-US/Firefox%20Setup%20149.0.2.exe#/dl.7z",
            "hash": "sha512:3f0c61087c262354e7a01aed69fbbccff72c7cf27bc7c8b2e474567f62b99284258707f8c6ce2b6afe230f1053dd43a18c8c2fede0ffb7a33e8954383dfc1bb2"
        }
    },
    "extract_dir": "core",
    "post_install": [
        "firefox -CreateProfile \"Scoop $persist_dir\\profile\"",
        "$Addition = \"$persist_dir\\addition\"",
        "if (Test-Path $Addition) {",
        "  info 'Copying additional items...'",
        "  Copy-Item -Path $Addition\\* -Destination $dir -Force -Recurse -ErrorAction SilentlyContinue",
        "}"
    ],
    "bin": "firefox.exe",
    "shortcuts": [
        [
            "firefox.exe",
            "Firefox"
        ],
        [
            "firefox.exe",
            "Firefox Profile Manager",
            "-P"
        ]
    ],
    "persist": [
        "profile",
        "distribution"
    ],
    "checkver": {
        "url": "https://product-details.mozilla.org/1.0/firefox_versions.json",
        "jsonpath": "$.LATEST_FIREFOX_VERSION"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win64/en-US/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64/en-US/$basename"
                }
            },
            "32bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win32/en-US/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win32/en-US/$basename"
                }
            }
        }
    }
}
