{
    "version": "1.14.0",
    "description": "Featuring powerful AI capabilities and supporting various e-book formats, it makes reading smarter and more focused.",
    "homepage": "https://github.com/Anxcye/anx-reader",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/Anxcye/anx-reader/releases/download/v1.14.0/Anx-Reader-windows-1.14.0.zip",
            "hash": "052bc63717f912b6962f3b98f11f86eea3337223d54ca9a18b48be7aa0051c86"
        }
    },
    "shortcuts": [
        [
            "anx_reader.exe",
            "Anx Reader"
        ]
    ],
    "persist_external": [
        [ "$env:APPDATA\\com.anxcye", "data", "directory" ],
        [ "$env:LOCALAPPDATA\\com.anxcye", "cache", "directory" ]
    ],
    "post_install": [
        ". \"$(Find-BucketDirectory -Root -Name (coalesce $bucket 'muggle'))/scripts/persist-external.ps1\"",
        "Invoke-PersistExternalInstall -Manifest $manifest -PersistDir $persist_dir -Dir $dir"
    ],
    "pre_uninstall": [
        ". \"$(Find-BucketDirectory -Root -Name (coalesce $bucket 'muggle'))/scripts/persist-external.ps1\"",
        "Invoke-PersistExternalUninstall -Manifest $manifest -Dir $dir"
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Anxcye/anx-reader/releases/download/v$version/Anx-Reader-windows-$version.zip"
            }
        }
    }
}
