{
    "version": "0.0.1",
    "description": "Fl Stduio patch for lifetime works",
    "homepage": "https://github.com/WeritoP/FL-STUDIO-PATCHER",
    "license": "Unknown",
    "architecture": {
        "64bit": {
            "url": "https://github.com/WeritoP/FL-STUDIO-PATCHER/releases/download/0.0.1/FL.Studio.Patcher_pass_123.zip#dl.zip_",
            "hash": "5350874221d1cc7d16568d65eb6d2d248578b891478c3dc4e6943e96c33587c1"
        }
    },
    "pre_install": [
        "$7z=(Get-ChildItem $dir\\$matchFile).Name",
        "7z x -p123 $dir\\$7z $('-o' + $dir) | Out-Null",
        "Move-Item \"$dir\\FL Studio Patcher\\*\"  \"$dir\" -Force -ErrorAction SilentlyContinue",
        "Rename-Item \"$dir\\FL_StudioPather*.exe\" \"FL-StudioPather.exe\" -Force",
        "Remove-Item \"$dir\\*dl.zip_\", \"$dir\\FL Studio Patcher\" -Force -ErrorAction SilentlyContinue"
    ],
    "bin": "FL-StudioPather.exe",
    "shortcuts": [
        [
            "FL-StudioPather.exe",
            "FL-StudioPather"
        ]
    ],
    "checkver": {
        "github": "https://api.github.com/repos/WeritoP/FL-STUDIO-PATCHER/releases",
        "jp": "$[0].assets[*].browser_download_url",
        "regex": "/releases/download/([\\d.]+)/(?<file>FL.*?\\.zip)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/WeritoP/FL-STUDIO-PATCHER/releases/download/$version/$matchFile#dl.zip_"
            }
        }
    }
}
