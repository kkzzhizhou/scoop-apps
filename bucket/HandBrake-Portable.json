{
    "version": "1.11.1",
    "description": "HandBrake. A tool for converting video from nearly any format to a selection of modern, widely supported codecs.",
    "homepage": "https://handbrake.fr",
    "license": "GPL-2.0-only",
    "architecture": {
        "64bit": {
            "url": "https://github.com/HandBrake/HandBrake/releases/download/1.11.1/HandBrake-1.11.1-x86_64-Win_GUI.zip",
            "hash": "2755446dd27a5276bbf6f32e78af44dba0c36a0d801e00bf2f4374fd21e2f5a7"
        }
    },
    "post_install": "Move-Item \"$dir\\HandBrake\\portable.ini.template\" \"$dir\\HandBrake\\portable.ini\"",
    "shortcuts": [
        [
            "HandBrake\\HandBrake.exe",
            "HandBrake"
        ]
    ],
    "persist": [
        "tmp",
        "storage"
    ],
