        },
        "32bit": {
            "url": [
                "https://archive.mozilla.org/pub/firefox/releases/152.0.6/win32/it/Firefox%20Setup%20152.0.6.exe#/dl.7z",
                "https://raw.githubusercontent.com/starise/scoop-confetti/master/scripts/firefox-policies.json#/policies.json"
