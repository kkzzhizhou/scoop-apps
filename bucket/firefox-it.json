            ],
            "hash": [
                "sha512:861f9d07280d70f3f13c461b14411979753a504ecb5576a4ec31cd5c4798e016eff904ea83a01682a37e7787894001cc742cbe5d02f8b262329775cf42d3d48e",
                "cb75fbc7489904edf08041213b70c67c8dad3f54fdecdadd623fdb0f44cbaef6"
            ]
        },
        "32bit": {
            "url": [
                "https://archive.mozilla.org/pub/firefox/releases/153.0/win32/it/Firefox%20Setup%20153.0.exe#/dl.7z",
                "https://raw.githubusercontent.com/starise/scoop-confetti/master/scripts/firefox-policies.json#/policies.json"
