    "architecture": {
        "64bit": {
            "url": "https://github.com/johannesjo/super-productivity/releases/download/v18.1.0/Super-Productivity-Setup-x64.exe#/dl.7z",
            "hash": "sha512:2a91123eebf771e3626a436195de679d2595c8d3afeeb0c75a5536e209c0f2a2acd0b4d4fc4e0c25e8757e1f0d66e93a315a365c333a17aac83f2749073a23a7",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\", \"$dir\\Uninst*\" -Force -Recurse"
            ]
        },
        "arm64": {
            "url": "https://github.com/johannesjo/super-productivity/releases/download/v18.1.0/Super-Productivity-Setup-arm64.exe#/dl.7z",
            "hash": "sha512:69463ccb1db7cc8ac0967ba1959473bc6e98d52bee16463a843e3e40bbde100bc80454662320240529ab2fa48158d99f4a640dd3ea9ddeb145cf9b12d80ebd1d",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-arm64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\", \"$dir\\Uninst*\" -Force -Recurse"
            ]
        }
    },
    "shortcuts": [
        [
            "Super Productivity.exe",
            "Super Productivity"
        ]
    ],
    "post_install": [
        "Remove-Item \"$dir\\`$PLUGINSDIR\" -Force -Recurse",
        "if (!(Test-Path \"$persist_dir\")) {",
        "    ensure \"$persist_dir\" | Out-Null",
        "}",
        "if (!(Test-Path \"$persist_dir\\data\")) {",
        "    ensure \"$persist_dir\\data\" | Out-Null",
        "}",
        "New-Item $env:AppData\\superProductivity -ItemType Junction -Target \"$persist_dir\\data\" | Out-Null"
    ],
    "pre_uninstall": [
        "if (Test-Path \"$Env:AppData\\superProductivity\\*\") {",
        "    Remove-Item $env:APPDATA\\superProductivity -Force -Recurse",
        "}"
    ],
    "checkver": {
        "github": "https://github.com/johannesjo/super-productivity"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/johannesjo/super-productivity/releases/download/v$version/Super-Productivity-Setup-x64.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/johannesjo/super-productivity/releases/download/v$version/Super-Productivity-Setup-arm64.exe#/dl.7z"
            }
        },
        "hash": {
            "url": "$baseurl/latest.yml",
            "regex": "(?sm)$basename.*?sha512:\\s+$base64"
        }
    }
}
