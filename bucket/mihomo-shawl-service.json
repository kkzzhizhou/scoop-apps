{
    "version": "1.9.0",
    "description": "A Windows service wrapper for arbitrary commands (using Shawl) to host Mihomo as a Windows service.",
    "homepage": "https://github.com/mtkennerly/shawl",
    "license": "MIT",
    "depends": "muggle/mihomo",
    "architecture": {
        "64bit": {
            "url": "https://github.com/mtkennerly/shawl/releases/download/v1.9.0/shawl-v1.9.0-win64.zip",
            "hash": "f883c5d09c9beae2efaeabd8513e7d3f57cd1d0864cec3df4f4a7b6ee904351c"
        },
        "32bit": {
            "url": "https://github.com/mtkennerly/shawl/releases/download/v1.9.0/shawl-v1.9.0-win32.zip",
            "hash": "981608dd6530a688208a9d6b0669ce8c75d12f844e7ecbbdcf19266cdfb6803b"
        }
    },
    "pre_install": [
        "Rename-Item \"$dir\\shawl.exe\" -NewName 'mihomo-service.exe'"
    ],
    "post_install": [
        "$isAdmin = ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)",
        "$mihomoDir = \"$(appdir mihomo $global)\\current\"",
        "$servicePath = \"$dir\\mihomo-service.exe\"",
        "$logDir = \"$dir\\logs\"",
        "$argsList = @(",
        "    'add',",
        "    '--name', 'mihomo-shawl',",
        "    '--cwd', \"$mihomoDir\",",
        "    '--log-dir', \"$logDir\",",
        "    '--log-rotate', 'bytes=10485760',",
        "    '--log-retain', '8',",
        "    '--stop-timeout', '5000',",
        "    '--',",
        "    \"$mihomoDir\\mihomo.exe\",",
        "    '-d', '.',",
        "    '-f', 'config\\config.yaml'",
        ")",
        "if ($isAdmin) {",
        "    sc.exe delete mihomo-shawl | Out-Null",
        "    & \"$servicePath\" $argsList | Out-Null",
        "    sc.exe config mihomo-shawl start= auto | Out-Null",
        "    Write-Host 'Mihomo Windows service registered successfully.' -ForegroundColor Green",
        "} else {",
        "    Write-Host 'Not running as Administrator. Requesting UAC elevation to register Windows service...' -ForegroundColor Yellow",
        "    $cmdString = \"sc.exe delete mihomo-shawl | Out-Null; & '$servicePath' \" + ($argsList | ForEach-Object { \"'$_'\" }) -join ' ' + \"; sc.exe config mihomo-shawl start= auto | Out-Null\"",
        "    try {",
        "        Start-Process powershell -ArgumentList '-NoProfile', '-WindowStyle', 'Hidden', '-Command', $cmdString -Verb RunAs -Wait -ErrorAction Stop",
        "        Write-Host 'Mihomo Windows service registered successfully.' -ForegroundColor Green",
        "    } catch {",
        "        Write-Warning 'UAC elevation denied. Service was not registered.'",
        "    }",
        "}"
    ],
    "uninstaller": {
        "script": [
            "$isAdmin = ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)",
            "$serviceName = 'mihomo-shawl'",
            "$service = Get-Service -Name $serviceName -ErrorAction SilentlyContinue",
            "if ($service) {",
            "    if ($isAdmin) {",
            "        if ($service.Status -eq 'Running') {",
            "            Write-Host \"Stopping '$serviceName' service...\" -ForegroundColor Yellow",
            "            net.exe stop $serviceName | Out-Null",
            "        }",
            "        Write-Host \"Uninstalling '$serviceName' service...\" -ForegroundColor Yellow",
            "        sc.exe delete $serviceName | Out-Null",
            "    } else {",
            "        Write-Host 'Not running as Administrator. Requesting UAC elevation to stop and uninstall service...' -ForegroundColor Yellow",
            "        $elevatedCmds = @()",
            "        if ($service.Status -eq 'Running') {",
            "            $elevatedCmds += \"net.exe stop '$serviceName'\"",
            "        }",
            "        $elevatedCmds += \"sc.exe delete '$serviceName'\"",
            "        $cmdString = $elevatedCmds -join '; '",
            "        try {",
            "            Start-Process powershell -ArgumentList '-NoProfile', '-WindowStyle', 'Hidden', '-Command', $cmdString -Verb RunAs -Wait -ErrorAction Stop",
            "        } catch {",
            "            Write-Warning 'UAC elevation denied. Failed to stop and uninstall service.'",
            "        }",
            "    }",
            "}"
        ]
    },
    "persist": "logs",
    "notes": "Ensure 'config.yaml' is placed in 'mihomo/config'.\n\n=== SERVICE CONTROL COMMANDS ===\n\nStart Service:\nsudo sc.exe start mihomo-shawl\n\nStop Service:\nsudo sc.exe stop mihomo-shawl\n\nEnable Auto-Start (on boot):\nsudo sc.exe config mihomo-shawl start= auto\n\nDisable Auto-Start (manual start):\nsudo sc.exe config mihomo-shawl start= demand",
    "checkver": {
        "github": "https://github.com/mtkennerly/shawl"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/mtkennerly/shawl/releases/download/v$version/shawl-v$version-win64.zip"
            },
            "32bit": {
                "url": "https://github.com/mtkennerly/shawl/releases/download/v$version/shawl-v$version-win32.zip"
            }
        }
    }
}
