{
    "version": "1.9.2",
    "description": "🩵 A free, open-source app store for developers' releases on GitHub, Codeberg & Forgejo — browse, discover, and install apps with one click. Formerly GitHub Store.",
    "homepage": "https://www.github-store.org/",
    "license": {
        "identifier": "Apache-2.0 license",
        "url": "https://github.com/kurikomi-labs/komi-store#Apache-2.0-1-ov-file"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/kurikomi-labs/komi-store/releases/download/v1.9.2/Komi-Store-1.9.2.msi",
            "hash": "a24c459fae44481643cdcf2995d11550aca2f1bceaca798a9a9859c829649fc1"
        }
    },
    "innosetup": true,
    "pre_install": [
        "Copy-Item \"$dir\\Komi-Store\\*\" \"$dir\" -Force -Recurse",
        "Remove-Item \"$dir\\Komi-Store\" -Force -Recurse"
    ],
    "installer": {
        "script": [
            "# handle runtime cache",
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\appdata\" -Target \"$env:LOCALAPPDATA\\GitHub-Store\"",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\userdata\" -Target \"$env:APPDATA\\GitHub-Store\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "uninstaller": {
        "script": [
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Dismount-ExternalRuntimeData -Target \"$env:LOCALAPPDATA\\GitHub-Store\"",
            "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\GitHub-Store\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "bin": "Komi-Store.exe",
    "shortcuts": [
        [
            "Komi-Store.exe",
            "Komi Store"
        ]
    ],
    "checkver": {
        "github": "https://api.github.com/repos/kurikomi-labs/komi-store/releases",
        "jp": "$[0].assets[*].browser_download_url",
        "regex": "/releases/download/v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/kurikomi-labs/komi-store/releases/download/v$version/Komi-Store-$version.msi"
            }
        }
    }
}
