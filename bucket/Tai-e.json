{
    "version": "0.5.4",
    "description": "An easy-to-learn/use static analysis framework for Java",
    "notes": [
        "【工具类型】: 开发工具",
        "【主要功能】: Java静态分析框架，易于学习和使用",
        "【适用场景】: 代码分析、安全审计、程序分析",
        "【技术特点】: Java开发，命令行工具，需要JRE环境"
    ],
    "homepage": "https://github.com/pascal-lab/Tai-e",
    "license": "Apache-2.0",
    "suggest": {
        "JRE": "sec/oraclejre8"
    },
    "url": "https://github.com/pascal-lab/Tai-e/releases/download/v0.5.4/tai-e-all-0.5.4.jar#/tai-e.jar",
    "pre_install": [
        "Set-Content \"$dir\\tai-e.bat\" '@pushd %~dp0",
        "@call oraclejre8",
        "@cmd /c java.exe -jar \"tai-e.jar\" %*",
        "@popd' -Encoding Ascii"
    ],
    "bin": "tai-e.bat",
    "shortcuts": [
        [
            "tai-e.bat",
            "Tai-e"
        ]
    ],
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/pascal-lab/Tai-e/releases/download/v$version/tai-e-all-$version.jar#/tai-e.jar"
    }
}
