            "hash": "687438271bb0d489855e09f978bfedfe859bdb26fd8a91e67bd1b728ad24f4fa"
        },
        "arm64": {
            "url": "https://releases.warp.dev/stable/v0.2026.07.08.17.54.stable_02/WarpSetup-arm64.exe",
