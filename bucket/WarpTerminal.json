            "hash": "ce93c7198bd2e2031d1fd2fbdc194040844d77737063faadd7886cbde84a1390"
        },
        "arm64": {
            "url": "https://releases.warp.dev/stable/v0.2026.04.27.15.32.stable_02/WarpSetup-arm64.exe",
