    },
    "depends": "Scoop4kariiin/Scoop4kariiinUtils",
    "architecture": {
        "64bit": {
            "url": "https://releases.warp.dev/stable/v0.2026.06.17.09.49.stable_01/WarpSetup.exe",
            "hash": "f1259f413b6275df289e0caf99d6fa341a3b57501a669c237298c9ba4542fbf7"
        },
        "arm64": {
            "url": "https://releases.warp.dev/stable/v0.2026.06.17.09.49.stable_01/WarpSetup-arm64.exe",
            "hash": "3958795ad01ec66d392f33ef60b434b60e3c3ed921a3407f79b02c618200bfb3"
        }
    },
    "innosetup": true,
    "installer": {
        "script": [
            "Import-Module -Name Scoop4kariiinUtils -ErrorAction Stop",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\warp\" -LocalAppData",
            "Remove-Module -Name Scoop4kariiinUtils -ErrorAction SilentlyContinue"
        ]
    },
    "shortcuts": [
        [
            "warp.exe",
            "Warp"
        ]
    ],
    "uninstaller": {
        "script": [
            "Import-Module -Name Scoop4kariiinUtils -ErrorAction Stop",
            "Dismount-ExternalRuntimeData -Target \"warp\" -LocalAppData",
            "Remove-Module -Name Scoop4kariiinUtils -ErrorAction SilentlyContinue"
        ]
    },
    "checkver": {
        "script": "[System.Net.HttpWebRequest]::Create('https://app.warp.dev/download?package=exe_x86_64').GetResponse().ResponseUri.AbsoluteUri",
        "regex": "/v([\\d.]+stable_\\d+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://releases.warp.dev/stable/v$version/WarpSetup.exe"
            },
            "arm64": {
                "url": "https://releases.warp.dev/stable/v$version/WarpSetup-arm64.exe"
            }
        }
    }
}
