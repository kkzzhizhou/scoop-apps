{
    "version": "11.13.2",
    "homepage": "https://evernote.com/",
    "license": "Freeware",
    "url": "https://win.desktop.evernote.com/builds/Evernote-11.13.2-win-ddl-stage-20260417082602-e1b1f4983c32f618805c4b4caee7de99656fd14d-setup.exe#/dl.7z",
    "hash": "sha512:b1143b445d2167a66663b376548397b615315f6bd8ba5f7d3cfd003fd19b090f727e8acfa40e84b60b8c6a342152a5901c177555c22f8d06a2ce15a11b3c35ec",
    "installer": {
        "script": [
            "Remove-Item \"$dir\\`$R0\", \"$dir\\resources\" -Force -Recurse",
            "if ($architecture -eq '64bit') {",
            "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
            "} elseif ($architecture -eq '32bit') {",
            "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-32.7z\" \"$dir\"",
            "}",
            "Remove-Item \"$dir\\`$PLUGINSDIR\" -Force -Recurse"
        ]
    },
    "shortcuts": [
        [
            "Evernote.exe",
            "Evernote"
        ]
    ],
    "checkver": {
        "url": "https://public.evernote.com/ddl-updater/updater/win/public/latest.yml",
        "regex": "Evernote-([\\d.]+)-(?<build>.+).exe"
    },
    "autoupdate": {
        "url": "https://win.desktop.evernote.com/builds/Evernote-$version-$matchBuild.exe#/dl.7z",
        "hash": {
            "url": "https://public.evernote.com/ddl-updater/updater/win/public/latest.yml",
            "regex": "sha512: $base64"
        }
    }
}
