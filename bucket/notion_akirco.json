{
    "version": "7.9.0",
    "description": "The all-in-one workspace for your notes, tasks, wikis, and databases.",
    "homepage": "https://www.notion.so",
    "license": "Proprietary",
    "notes": "Your Notion data are storaged in '%LOCALAPPDATA%\\Notion'.",
    "url": "https://desktop-release.notion-static.com/Notion%20Setup%207.9.0.exe#/dl.7z",
    "hash": "sha512:6dc17aa960cc142fbabd4d682f61ed1e60861eedc0843896746eac2ef2b441e0f0a30dbc53500267b9ce5a6c499651a6333eef46cc8d120469f5281c2f0866ba",
    "extract_dir": "$PLUGINSDIR",
    "installer": {
        "script": [
            "Remove-Item \"$dir\\*\" -Exclude \"app-64.7z\"",
            "Expand-7zipArchive \"$dir\\app-64.7z\" \"$dir\"",
            "Remove-Item \"$dir\\app-64.7z\""
        ]
    },
    "shortcuts": [
        [
            "Notion.exe",
            "Notion"
        ]
    ],
    "checkver": {
        "url": "https://desktop-release.notion-static.com/latest.yml",
        "regex": "version:\\s+([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://desktop-release.notion-static.com/Notion%20Setup%20$version.exe#/dl.7z",
        "hash": {
            "url": "$baseurl/latest.yml",
            "regex": "sha512:\\s+$base64"
        }
    }
}
