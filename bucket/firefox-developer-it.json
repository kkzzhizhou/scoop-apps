            "firefox.exe",
            "Firefox Developer Edition"
        ]
    ],
    "checkver": {
        "url": "https://product-details.mozilla.org/1.0/firefox_versions.json",
        "jsonpath": "$.FIREFOX_DEVEDITION"
    },
    "autoupdate": {
