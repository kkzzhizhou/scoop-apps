{
    "version": "4.2.11",
    "description": "A comic app built with Flutter, supporting multiple comic sources.",
    "homepage": "https://github.com/Pacalini/PicaComic",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/Pacalini/PicaComic/releases/download/v4.2.11/PicaComic-4.2.11-windows.zip",
            "hash": "a31d73e331d515b5f69e071d90f40c404a01cd0fc18118eba1c7128a81827107"
        }
    },
    "post_install": [
        "& \"$(Find-BucketDirectory -Root -Name (coalesce $bucket 'muggle'))/scripts/DoradoHelper.ps1\" -Action Mount -PersistDir \"$persist_dir\" -Target \"$env:APPDATA/com.github.pacalini\"",
        "& \"$(Find-BucketDirectory -Root -Name (coalesce $bucket 'muggle'))/scripts/DoradoHelper.ps1\" -Action Mount -Source \"$persist_dir/cache\" -Target \"$env:LOCALAPPDATA/com.github.pacalini\""
    ],
    "pre_uninstall": [
        "& \"$(Find-BucketDirectory -Root -Name (coalesce $bucket 'muggle'))/scripts/DoradoHelper.ps1\" -Action Dismount -Target \"$env:APPDATA/com.github.pacalini\"",
        "& \"$(Find-BucketDirectory -Root -Name (coalesce $bucket 'muggle'))/scripts/DoradoHelper.ps1\" -Action Dismount -Target \"$env:LOCALAPPDATA/com.github.pacalini\""
    ],
    "shortcuts": [
        [
            "pica_comic.exe",
            "Pica Comic"
        ]
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Pacalini/PicaComic/releases/download/v$version/PicaComic-$version-windows.zip"
            }
        }
    }
}
