{
    "version": "4.2.11",
    "description": "A comic app built with Flutter, supporting multiple comic sources.",
    "homepage": "https://github.com/Pacalini/PicaComic",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/Pacalini/PicaComic/releases/download/v4.2.11/PicaComic-4.2.11-windows.zip",
            "hash": "a31d73e331d515b5f69e071d90f40c404a01cd0fc18118eba1c7128a81827107"
        }
    },
    "persist_external": [
        [
            "$env:AppData\\com.github.pacalini",
            "data",
            "directory"
        ],
        [
            "$env:LocalAppData\\com.github.pacalini",
            "cache",
            "directory"
        ]
    ],
    "post_install": [
        ". \"$(Find-BucketDirectory -Root -Name (coalesce $bucket 'muggle'))/scripts/persist-external.ps1\"",
        "Invoke-PersistExternalInstall -Manifest $manifest -PersistDir $persist_dir -Dir $dir"
    ],
    "pre_uninstall": [
        ". \"$(Find-BucketDirectory -Root -Name (coalesce $bucket 'muggle'))/scripts/persist-external.ps1\"",
        "Invoke-PersistExternalUninstall -Manifest $manifest -Dir $dir"
    ],
    "shortcuts": [
        [
            "pica_comic.exe",
            "Pica Comic"
        ]
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Pacalini/PicaComic/releases/download/v$version/PicaComic-$version-windows.zip"
            }
        }
    }
}
