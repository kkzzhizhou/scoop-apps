    "portableProfile": {
        "mappings": [
            {
                "label": "roaming",
                "source": "AppData/QQ",
                "target": "$persist_dir/roaming",
                "strategy": "symlink",
                "ensureTarget": true
            },
            {
                "label": "qqex",
                "source": "AppData/QQEX",
                "target": "$persist_dir/qqex",
                "strategy": "symlink",
                "ensureTarget": true
            },
            {
                "label": "tencent-qqnt",
                "source": "AppData/Tencent/QQNT",
                "target": "$persist_dir/tencent-qqnt",
                "strategy": "symlink",
                "ensureTarget": true
            },
            {
                "label": "chat-updater",
                "source": "LocalAppData/qq-chat-updater",
                "target": "$persist_dir/updater-blocker",
                "strategy": "symlink",
                "ensureTarget": true,
                "targetType": "file"
            },
            {
                "label": "play-updater",
                "source": "LocalAppData/qq-play-updater",
                "target": "$persist_dir/updater-blocker",
                "strategy": "symlink",
                "ensureTarget": true,
                "targetType": "file"
            }
        ],
        "options": {
            "log": true
        }
    },
    "checkver": {
        "script": [
            "# Please keep this script. An empty Accept-Encoding header can cause the CDN to deliver expired cache.",
            "# See : https://github.com/ScoopInstaller/Extras/issues/15916",
            "$headers = @{ 'Accept-Encoding' = 'gzip' }",
            "$url = 'https://cdn-go.cn/qq-web/im.qq.com_new/latest/rainbow/windowsConfig.js'",
            "$response = Invoke-WebRequest -Uri $url -UseBasicParsing -Headers $headers",
            "Write-Output $response.Content"
        ],
        "regex": "(?<url>https://qqdl\\.gtimg\\.cn/qqfile/QQNT/([\\d\\.]+)/release/([0-9a-f]+)/QQ_([\\d\\.]+)_([\\d]+)_x86_01\\.exe)",
        "replace": "${3}.${4}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://qqdl.gtimg.cn/qqfile/QQNT/$match1/release/$match2/QQ_$match3_$match4_x64_01.exe#/dl.7z"
            },
            "32bit": {
                "url": "https://qqdl.gtimg.cn/qqfile/QQNT/$match1/release/$match2/QQ_$match3_$match4_x86_01.exe#/dl.7z"
