{
    "homepage": "https://ryujinx.app",
    "version": "1.3.3",
    "description": "Nintendo Switch Emulator written in C# (Ryubing continuation)",
    "license": {
        "identifier": "MIT",
        "url": "https://git.ryujinx.app/projects/Ryubing/src/branch/master/LICENSE.txt"
    },
    "pre_install": [
        "function create($path, $type, $content) {",
        "   if (-not (Test-Path \"$path\")) {",
        "       New-Item \"$path\" -ItemType $type -Value $content | Out-Null",
        "       Write-Output \"Creating $path...\"",
        "   }",
        "}",
        "create $dir/portable Directory"
    ],
    "persist": "portable",
    "extract_dir": "publish",
    "architecture": {
        "64bit": {
            "url": "https://git.ryujinx.app/projects/Ryubing/releases/download/1.3.3/ryujinx-1.3.3-win_x64.zip",
            "hash": "baa93f48b012eefeca339a78a39844599ccd194c109093f354a4b9d1e03a056e",
            "bin": "Ryujinx.exe",
            "shortcuts": [
                [
                    "Ryujinx.exe",
                    "Nintendo Switch (Ryujinx)"
                ]
            ]
        }
    },
    "checkver": {
        "url": "https://git.ryujinx.app/api/v1/repos/projects/Ryubing/releases/latest",
        "jsonpath": {
            "version": "$.tag_name",
            "download": "$.assets[?(@.name =~ /win_x64/i)].browser_download_url"
        }
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchDownload"
            }
        }
    }
}
