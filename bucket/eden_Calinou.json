{
    "version": "0.2.0",
    "description": "Open source Nintendo Switch emulator (forked from yuzu)",
    "homepage": "https://eden-emu.dev/",
    "license": {
        "identifier": "GPL-3.0-or-later",
        "url": "https://git.eden-emu.dev/eden-emu/eden/raw/branch/master/LICENSE.txt"
    },
    "architecture": {
        "64bit": {
            "url": "https://stable.eden-emu.dev/v0.2.0/Eden-Windows-v0.2.0-amd64-msvc-standard.zip",
            "hash": "e32628034e8fd9653f110f73fd4f184659e05ec53da1b233f7f33d2fb65ef242"
        },
        "arm64": {
            "url": "https://stable.eden-emu.dev/v0.2.0/Eden-Windows-v0.2.0-arm64-clang-standard.zip",
            "hash": "d6f78add427f52877d2e7ab65d86889170a50a50035f853eb7e65e58575f3c0d"
        }
    },
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\")) {",
        "   New-item \"$persist_dir\" -ItemType Directory | Out-Null",
        "   New-item \"$persist_dir\\user\" -ItemType Directory | Out-Null",
        "   if (Test-Path \"$env:APPDATA\\eden\") {",
        "       Write-host \"Migrating AppData...\" -ForegroundColor yellow",
        "       Copy-Item -Path \"$env:APPDATA\\eden\\*\" -Destination \"$persist_dir\\user\" -Recurse",
        "       Remove-Item -Path \"$env:APPDATA\\eden\" -Recurse",
        "   }",
        "}"
    ],
    "bin": "eden.exe",
    "shortcuts": [
        [
            "eden.exe",
            "Eden"
        ]
    ],
    "persist": "user",
    "checkver": {
        "url": "https://git.eden-emu.dev/api/v1/repos/eden-emu/eden/releases/latest",
        "jsonpath": "$.tag_name",
        "regex": "v([\\d]+(?:\\.[\\d]+)+(?:-[A-Za-z\\d.-]+)?)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://stable.eden-emu.dev/v$version/Eden-Windows-v$version-amd64-msvc-standard.zip"
            },
            "arm64": {
                "url": "https://stable.eden-emu.dev/v$version/Eden-Windows-v$version-arm64-clang-standard.zip"
            }
        }
    }
}
