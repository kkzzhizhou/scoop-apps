{
    "version": "151.0.3",
    "description": "Firefox 浏览器的无 EME 版本，默认禁用 DRM 支持",
    "homepage": "https://www.mozilla.org/zh-CN/firefox/",
    "license": "MPL-2.0",
    "notes": [
        "To set profile 'Scoop' as *DEFAULT*, or profiles/settings was lost after update:",
        "  - Run 'Firefox Profile Manager', choose 'Scoop' then click 'Start Firefox'.",
        "  - Visit 'about:profiles' page in Firefox to check *DEFAULT* profile.",
        "For details: https://support.mozilla.org/zh-CN/kb/profile-manager-create-remove-switch-firefox-profiles"
    ],
    "architecture": {
        "64bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/151.0.3/win64-EME-free/zh-CN/Firefox%20Setup%20151.0.3.exe#/dl.7z",
            "hash": "sha512:4949f7f2c9f88c8b9abf452b2938c16e0b663af2dcf48914c60641043e1a9203d78b218b7990ec9f23f7eead0ef4991221049e47f94680c272807ce1c267e438"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/151.0.3/win32-EME-free/zh-CN/Firefox%20Setup%20151.0.3.exe#/dl.7z",
            "hash": "sha512:1b2cf3a9108363e8eb698ba78e10db587fa952ad214c87260762c0f2db9c6eb786f61e892618a93c66a417521f3431ea94d9345e357103d4993b9516565b3d38"
        }
    },
    "extract_dir": "core",
    "post_install": [
        "firefox -CreateProfile \"Scoop $persist_dir\\profile\"",
        "$Addition = \"$persist_dir\\addition\"",
        "if (Test-Path $Addition) {",
        "  info 'Copying additional items...'",
        "  Copy-Item -Path $Addition\\* -Destination $dir -Force -Recurse -ErrorAction SilentlyContinue",
        "}"
    ],
    "bin": "firefox.exe",
    "shortcuts": [
        [
            "firefox.exe",
            "Firefox"
        ],
        [
            "firefox.exe",
            "Firefox Profile Manager",
            "-P"
        ]
    ],
    "persist": [
        "distribution",
        "profile"
    ],
    "checkver": {
        "url": "https://aus5.mozilla.org/update/6/Firefox/99.0/_/WINNT_x86_64-msvc-x64/zh-CN/release/_/_/_/_/update.xml",
        "xpath": "/updates/update/@appVersion"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win64-EME-free/zh-CN/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64-EME-free/zh-CN/$basename"
                }
            },
            "32bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win32-EME-free/zh-CN/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win32-EME-free/zh-CN/$basename"
                }
            }
        }
    }
}
