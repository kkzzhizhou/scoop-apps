{
    "homepage": "https://github.com/HarbourMasters/SpaghettiKart",
    "version": "1.0.0",
    "description": "Mario Kart 64 Decompilation via Ultraship",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/HarbourMasters/SpaghettiKart/releases/download/1.0.0/spaghetti-windows.zip",
            "hash": "bf7bd7cdb5f412c7b370af92949b9431ce7503968631f8cacd607933fb32aff3",
            "shortcuts": [
                [
                    "Spaghettify.exe",
                    "Mario Kart - 64 (ultraship)"
                ]
            ]
        }
    },
    "pre_install": [
        "function create($path, $type, $content) {",
        "   if (-not (Test-Path \"$path\")) {",
        "       New-Item \"$path\" -ItemType $type -Value $content | Out-Null",
        "       Write-Output \"Creating $path...\"",
        "   }",
        "}",
        "create $dir/spaghettify.cfg.json File",
        "create $dir/default.sav File"
    ],
    "persist": [
        "logs",
        "mods",
        "roms",
        "spaghettify.cfg.json",
        "default.sav"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/HarbourMasters/SpaghettiKart/releases",
        "jsonpath": {
            "version": "$.[0].name",
            "download": "$.[0].assets[?(@.name =~ /.+Windows\\.zip$/i)].browser_download_url"
        },
        "regex": "([\\d\\.]+\\d+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchDownload"
            }
        }
    }
}
