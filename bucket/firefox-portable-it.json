{
    "version": "152.0.2",
    "description": "Mozilla Firefox (Portable): open source web browser. Custom policies.json file. Italian Language Pack.",
    "homepage": "https://www.mozilla.org/it/firefox/",
    "license": "MPL-2.0",
    "architecture": {
        "64bit": {
            "url": [
                "https://archive.mozilla.org/pub/firefox/releases/152.0.2/win64/it/Firefox%20Setup%20152.0.2.exe#/dl.7z",
                "https://raw.githubusercontent.com/starise/scoop-confetti/master/scripts/firefox-policies.json#/policies.json"
            ],
            "hash": [
                "sha512:4c75570a311fb82923520a425486497b84512b1d10e2027046dec8387a8b2e0017ff909209b67bf84409c8e0f0b28098f7359ecb274b5d5478d5832e5a962624",
                "cb75fbc7489904edf08041213b70c67c8dad3f54fdecdadd623fdb0f44cbaef6"
            ]
        },
        "32bit": {
            "url": [
                "https://archive.mozilla.org/pub/firefox/releases/152.0.2/win32/it/Firefox%20Setup%20152.0.2.exe#/dl.7z",
                "https://raw.githubusercontent.com/starise/scoop-confetti/master/scripts/firefox-policies.json#/policies.json"
            ],
            "hash": [
                "sha512:3ca42d0c173a094f81ac24e4ee1952858ff716f88fbc1f0af85510f9e4d80a5ee88e2908375cb66ee7542a348a61580804995e3c732d5957de55056d303e54db",
                "cb75fbc7489904edf08041213b70c67c8dad3f54fdecdadd623fdb0f44cbaef6"
            ]
        }
    },
    "extract_dir": "core",
    "pre_install": [
        "if(!(Test-Path \"$persist_dir\\distribution\")) {",
        "  New-Item \"$persist_dir\\distribution\" -Type Directory -Force | Out-Null",
        "  Move-Item \"$dir\\policies.json\" \"$persist_dir\\distribution\\policies.json\"",
        "}"
    ],
    "persist": [
        "distribution",
        "profile"
    ],
    "bin": [
        [
            "firefox.exe",
            "firefox",
            "-profile \"$dir\\profile\""
        ]
    ],
    "shortcuts": [
        [
            "firefox.exe",
            "Mozilla Firefox",
            "-profile \"$dir\\profile\""
        ]
    ],
    "checkver": {
        "url": "https://product-details.mozilla.org/1.0/firefox_versions.json",
        "jsonpath": "$.LATEST_FIREFOX_VERSION"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win64/it/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64/it/$basename"
                }
            },
            "32bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win32/it/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win32/it/$basename"
                }
            }
        }
    }
}
