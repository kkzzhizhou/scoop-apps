            "hash": "cbd724ba47dde45e5d972d5f0e8d85e41237d1b9bf8910260d60946cda6326da"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/hnmbwbi7t5wysf2x3lbydvi5jm_150.0.7839.0/150.0.7839.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "30d27a67f81b6d5bb8344e7a01e66100f388f18e3a87d553bf47ff0b9be8e8b0"
