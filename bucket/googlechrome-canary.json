            "hash": "593012cbb5e75958153b67f85d9b5e5870f362375370a89d03bc8598569d9853"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/j3wlunrki5u5rgmmla45ubby2q_149.0.7780.0/149.0.7780.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "f5f6d78b38d2f613d8a1c4c335ddf4cc89b3b8f973facc64361944d4d4dac768"
