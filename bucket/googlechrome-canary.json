            "hash": "155ede3e1fc9dc09b399f8e0d7ad684dabfb0e8ffb7e4c8af7cca3268d10909b"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/mpioum3yo6mrn62rrlku52gllq_148.0.7740.0/148.0.7740.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "d16f4b583e12ca35b4633c594a90173452b9dc8478ad03ecbc3a9fc837bf0e21"
