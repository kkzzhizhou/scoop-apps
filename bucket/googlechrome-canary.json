            "hash": "aaf983c5255955ed99acf3f5f262d29c8555a93b5ac183406bfb91ca9104c1d0"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/hjwihs4ny7jg5nq4s3dgnixkfm_150.0.7870.0/150.0.7870.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "9d3e59cca1d38d1e522733d90774d200a906c829f3d910b7603f3a5f017e5a2a"
