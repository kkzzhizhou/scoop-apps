            "hash": "60dccdad15d3543585362a4f8b078a23d20477996b877bc0becd2bfdec9efced"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/lonzgrnlis36o4dzljh2k5dv5u_150.0.7860.0/150.0.7860.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "617758ddd421d60dc9038092f928abbde4f155f64e8d3e58844390d282ef239b"
