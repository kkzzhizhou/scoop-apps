            "url": "https://dl.google.com/release2/chrome/pptemxgs4o7jatkmanghap5cau_151.0.7893.0/151.0.7893.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "bca72ad7361fee9764294c08df1d0073c98109a07f907970d48bda32419c5b48"
