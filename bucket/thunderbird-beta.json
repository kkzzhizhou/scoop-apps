            "hash": "sha512:5345237a53c0d6ece1528ecfe0621b970714ce10e508fb20377fcc57f8256a23d7ea67d7295452860c6f2e14b256cde2f150342f02f3f88465e0414ee6c1c7a9"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/thunderbird/releases/154.0b1/win32/en-US/Thunderbird%20Setup%20154.0b1.exe#/dl.7z",
            "hash": "sha512:58cd7a2eef5e732768b24d559d6d7faa0bdfb37a8b828de5035368f368e3e3b9506bece9c29de049b78051f2c8cb446db7783839db8f3e37eec105dd1094809b"
