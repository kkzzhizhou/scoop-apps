            "hash": "sha512:14277f150b65ad9b6efaa8ff06a06fcb053fb4cef31ba69ec4838c60a0b7e2113823254f9ff1a1731c71e0a14bf205a3ff4b97ce50549125cddbf2f5430e689d"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/thunderbird/releases/153.0b1/win32/en-US/Thunderbird%20Setup%20153.0b1.exe#/dl.7z",
            "hash": "sha512:cd7dc5725a6d8c37203a78fa92f6f08bf43093a8628d0199d38e74b598f42239a838c0c824fdf17d01c605d4167f8bdab4a9753bd162f5267e3c2fa214a6bca2"
