        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/thunderbird/releases/153.0b8/win32/en-US/Thunderbird%20Setup%20153.0b8.exe#/dl.7z",
            "hash": "sha512:25333ffcbf2624622e89b513acc33a0cfd1a650c10f77cb638c5d76537267feca5f1c7b9fd46ae0b271b55800c2a8713ae0495354438a990b2adb8197884fdf3"
