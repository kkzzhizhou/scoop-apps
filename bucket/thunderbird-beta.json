            "hash": "sha512:8d84094ff9616c49981bbae3097d719f639c75da3bc86acb11fab06955c365999d26bc09e05b36c862de9740fc54a8fc582782ab917743c6fc244bca91be960c"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/thunderbird/releases/152.0b4/win32/en-US/Thunderbird%20Setup%20152.0b4.exe#/dl.7z",
            "hash": "sha512:aaa676fbb5e9ccc69d3e132206683bc4de99b07d7ada32c557feaf1c6464f84b3b72ec38dc7ea8a0f371cfbaed0a8cdc249508df6af25d705d983d5a9a9d4d4c"
        }
    },
    "extract_dir": "core",
    "bin": [
        [
            "thunderbird.exe",
            "thunderbird-beta",
            "-profile \"$dir\\profile\""
