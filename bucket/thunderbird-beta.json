            "hash": "sha512:f53da7f66bc463d85e8c517945adf863c98863544668f7b493d1a910b08c9ba4d0f15e133014f3ea4e3747470789973a69139e066963a453864ff18f4f3a5834"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/thunderbird/releases/152.0b3/win32/en-US/Thunderbird%20Setup%20152.0b3.exe#/dl.7z",
            "hash": "sha512:45c8d8d82216e06a791709abf7b935548d8e18ea26985bfe3745be52038d682e57ede0ccd159b732bbf3be20df0deaafbc8811d5d0368da1568a8fa5edceb208"
