    "homepage": "https://www.thunderbird.net",
    "license": "MPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://archive.mozilla.org/pub/thunderbird/releases/149.0b3/win64/en-US/Thunderbird%20Setup%20149.0b3.exe#/dl.7z",
            "hash": "sha512:d48188b704198ae55ddb818bbbad2576a79e3fe50babc6c9cc5fb849e32ea88a5157c30b5631f0299de57cd07eb4614bcbf0778ccc2edd52fc00a993ded54167"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/thunderbird/releases/149.0b3/win32/en-US/Thunderbird%20Setup%20149.0b3.exe#/dl.7z",
            "hash": "sha512:daa47606fe9546d2cac38c959e818f7c6ab5a1644d4d87d8caea40c31d9c628f36e15c174acab5a41078d871156e4ffcd48289bcf5c9232732639e60a736943e"
        }
    },
    "extract_dir": "core",
    "bin": [
        [
            "thunderbird.exe",
            "thunderbird-beta",
            "-profile \"$dir\\profile\""
        ]
    ],
    "shortcuts": [
        [
            "thunderbird.exe",
            "Mozilla Thunderbird Beta",
            "-profile \"$dir\\profile\""
        ]
    ],
    "persist": "profile",
    "checkver": {
        "url": "https://product-details.mozilla.org/1.0/thunderbird_versions.json",
        "jsonpath": "$.LATEST_THUNDERBIRD_DEVEL_VERSION"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://archive.mozilla.org/pub/thunderbird/releases/$version/win64/en-US/Thunderbird%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/thunderbird/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64/en-US/$basename"
                }
            },
            "32bit": {
                "url": "https://archive.mozilla.org/pub/thunderbird/releases/$version/win32/en-US/Thunderbird%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/thunderbird/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win32/en-US/$basename"
                }
            }
        }
    }
}
