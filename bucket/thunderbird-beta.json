            "hash": "sha512:bb5407296567ef0b775abe0be608d7114f7688a082cea766f024a04c314de2efd2ded12b8ad9b8c9692b69fd115e7112c46eb9e670b191851a70787669b4e822"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/thunderbird/releases/153.0b2/win32/en-US/Thunderbird%20Setup%20153.0b2.exe#/dl.7z",
            "hash": "sha512:01541ed08278f1d0b8e5ce632f80d8a99ac58c7b97cd9ea8e6e4e66dfdbea5a94c62c82da128271e48cc1bb156d7ae33d010d90478f82b23c046374f1b21d6f9"
        }
    },
    "extract_dir": "core",
    "bin": [
        [
            "thunderbird.exe",
            "thunderbird-beta",
            "-profile \"$dir\\profile\""
