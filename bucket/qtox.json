{
    "version": "1.18.5",
    "description": "Chat, voice, video, and file transfer IM client using the encrypted peer-to-peer Tox protocol.",
    "homepage": "https://qtox.github.io/",
    "license": "GPL-3.0-or-later",
    "architecture": {
        "64bit": {
            "url": "https://github.com/TokTok/qTox/releases/download/v1.18.5/setup-qtox-x86_64-release.exe#/dl.7z",
            "hash": "d947e5cc1042b2ad72600a1e2b9952d1e5b0691930d619f4347dbb1085d76f09"
        },
        "32bit": {
            "url": "https://github.com/TokTok/qTox/releases/download/v1.18.5/setup-qtox-i686-release.exe#/dl.7z",
            "hash": "6e10084d02be8a2cb99c54fb56ab4a5b11f32680968df44ae10e529f14c20208"
        }
    },
    "pre_install": [
        "$qtoxCfg = \"$persist_dir\\qtox.ini\"",
        "$profile = \"$persist_dir\\profile.tox\"",
        "if (-not (Test-Path $qtoxCfg)) {",
        "  Set-Content -Value \"[Advanced]`nmakeToxPortable=true\" $qtoxCfg",
        "}",
        "if (-not (Test-Path $profile)) {",
        "  Set-Content -Value \"dummy replace me\" $profile",
        "}"
    ],
    "extract_dir": "bin",
    "bin": "qtox.exe",
    "shortcuts": [
        [
            "qtox.exe",
            "qTox"
        ]
    ],
    "persist": [
        "profile.tox",
        "profile.ini",
        "profile.db",
        "avatars",
        "emoticons",
        "downloads",
        "qtox.ini"
    ],
    "notes": [
        "Your username is 'profile' to keep things portable.",
        "Replace 'persist/qtox/profile.tox' with your own.",
        "profile.tox, profile.db and profile.ini configuration must be placed in the persist/qtox",
        "directory before starting. These can only be gotten from a previous installation of qtox."
    ],
    "checkver": {
        "github": "https://github.com/TokTok/qTox"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/TokTok/qTox/releases/download/v$version/setup-qtox-x86_64-release.exe#/dl.7z"
            },
            "32bit": {
                "url": "https://github.com/TokTok/qTox/releases/download/v$version/setup-qtox-i686-release.exe#/dl.7z"
            }
        }
    }
}
