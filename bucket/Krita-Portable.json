{
    "version": "5.3.0",
    "description": "Krita. A free digital painting application.",
    "homepage": "https://krita.org/",
    "license": "GPL-3.0-or-later",
    "changelog": "https://krita.org/en/download/krita-desktop/",
    "architecture": {
        "64bit": {
            "url": "https://download.kde.org/stable/krita/5.3.0/krita-x64-5.3.0.zip",
            "hash": "3f554c0c515e76014029a0d56988af2d722d1d20d39a8fc8c10b96bdb54a9961"
        }
    },
    "extract_dir": "krita-x64-5.3.0",
    "bin": [
        "bin\\krita.exe",
        "bin\\kritarunner.exe"
    ],
    "shortcuts": [
        [
            "bin\\krita.exe",
            "Krita"
        ]
    ],
    "checkver": {
        "url": "https://krita.org/en/download/",
        "regex": ">Download Krita ([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.kde.org/stable/krita/$version/krita-x64-$version.zip"
            }
        },
        "hash": {
            "url": "$url.sha256"
        },
        "extract_dir": "krita-x64-$version"
    }
}
