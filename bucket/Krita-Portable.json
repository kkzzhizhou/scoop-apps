{
    "version": "5.3.1",
    "description": "Krita. A free digital painting application.",
    "homepage": "https://krita.org/",
    "license": "GPL-3.0-or-later",
    "changelog": "https://krita.org/en/download/krita-desktop/",
    "architecture": {
        "64bit": {
            "url": "https://download.kde.org/stable/krita/5.3.1/krita-x64-5.3.1.zip",
            "hash": "dc595ef0f4c87cb93c08dd011bb38cdb9550ceb4134a176005997c6a1618b3e4"
        }
    },
    "extract_dir": "krita-x64-5.3.1",
    "bin": [
        "bin\\krita.exe",
        "bin\\kritarunner.exe"
    ],
    "shortcuts": [
        [
            "bin\\krita.exe",
            "Krita"
        ]
    ],
    "checkver": {
        "url": "https://krita.org/en/download/",
        "regex": ">Download Krita ([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.kde.org/stable/krita/$version/krita-x64-$version.zip"
            }
        },
        "hash": {
            "url": "$url.sha256"
        },
        "extract_dir": "krita-x64-$version"
    }
}
