    "homepage": "https://www.nexusmods.com/about/vortex",
    "license": "GPL-3.0-or-later",
    "architecture": {
        "64bit": {
            "url": "https://github.com/Nexus-Mods/Vortex/releases/download/v2.0.2/vortex-setup-2.0.2.exe#/dl.7z",
            "hash": "sha512:3a9cef9455155fc8e746c62fef00182a7985f2c8dac21e3763579892fdba2f52b014ef6fdc52decea344536e7696e835a9ffd475b8524cbf764e3725cbb9ad76",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
