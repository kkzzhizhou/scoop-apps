{
    "version": "1.19.28",
    "description": "A rule-based tunnel in Go (formerly Clash.Meta).",
    "homepage": "https://github.com/MetaCubeX/mihomo",
    "license": "GPL-3.0-or-later",
    "suggest": {
        "mihomo-service": "muggle/mihomo-shawl-service"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/MetaCubeX/mihomo/releases/download/v1.19.28/mihomo-windows-amd64-v1.19.28.zip",
            "hash": "27bdbd8f476dfb0f65a2a8ecf43cdf7edc0a132326efc7660308a1302c034a20"
        },
        "32bit": {
            "url": "https://github.com/MetaCubeX/mihomo/releases/download/v1.19.28/mihomo-windows-386-v1.19.28.zip",
            "hash": "1cc14bdde317b38b861569c1d2aaacaf49907c1707b5aa38838e549b451549b1"
        },
        "arm64": {
            "url": "https://github.com/MetaCubeX/mihomo/releases/download/v1.19.28/mihomo-windows-arm64-v1.19.28.zip",
            "hash": "25cedfb999864e834a3d8424cb8ea61b9145b3cb3aea0180b9fdc009623abeda"
        }
    },
    "pre_install": [
        "Get-ChildItem \"$dir\\mihomo*.exe\" | Rename-Item -NewName 'mihomo.exe'",
        "if (!(Test-Path \"$persist_dir\")) { New-Item -Path \"$persist_dir\" -ItemType Directory | Out-Null }",
        "if (!(Test-Path \"$persist_dir\\cache.db\")) { New-Item -Path \"$persist_dir\\cache.db\" -ItemType File | Out-Null }",
        "if (!(Test-Path \"$persist_dir\\config.yaml\")) { New-Item -Path \"$persist_dir\\config.yaml\" -ItemType File | Out-Null }"
    ],
    "post_install": [
        "$isAdmin = ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)",
        "if ($isAdmin) {",
        "    Remove-NetFirewallRule -DisplayName 'Mihomo-In' -ErrorAction SilentlyContinue | Out-Null",
        "    Remove-NetFirewallRule -DisplayName 'Mihomo-Out' -ErrorAction SilentlyContinue | Out-Null",
        "    New-NetFirewallRule -DisplayName 'Mihomo-In' -Direction Inbound -Program \"$original_dir\\mihomo.exe\" -Action Allow -Profile Any -Protocol TCP -ErrorAction SilentlyContinue | Out-Null",
        "    New-NetFirewallRule -DisplayName 'Mihomo-In' -Direction Inbound -Program \"$original_dir\\mihomo.exe\" -Action Allow -Profile Any -Protocol UDP -ErrorAction SilentlyContinue | Out-Null",
        "} else {",
        "    Write-Host 'Not running as Administrator. Requesting elevation via UAC to configure inbound firewall rule...' -ForegroundColor Yellow",
        "    try {",
        "        Start-Process powershell -ArgumentList '-NoProfile', '-WindowStyle', 'Hidden', '-Command', \"Remove-NetFirewallRule -DisplayName 'Mihomo-In','Mihomo-Out' -ErrorAction SilentlyContinue; New-NetFirewallRule -DisplayName 'Mihomo-In' -Direction Inbound -Program '$original_dir\\mihomo.exe' -Action Allow -Profile Any -Protocol TCP -ErrorAction SilentlyContinue | Out-Null; New-NetFirewallRule -DisplayName 'Mihomo-In' -Direction Inbound -Program '$original_dir\\mihomo.exe' -Action Allow -Profile Any -Protocol UDP -ErrorAction SilentlyContinue | Out-Null\" -Verb RunAs -Wait -ErrorAction Stop",
        "    } catch {",
        "        Write-Warning 'UAC elevation denied. Inbound firewall rule was not added.'",
        "    }",
        "}",
        "Write-Host ''",
        "Write-Host 'INFO: Inbound rules (Mihomo-In for TCP & UDP) have been configured and updated automatically.' -ForegroundColor Cyan",
        "Write-Host 'INFO: If your TUN/Mixed mode requires outbound rule, run PowerShell as Administrator and execute:' -ForegroundColor Cyan",
        "Write-Host \"New-NetFirewallRule -DisplayName 'Mihomo-Out' -Direction Outbound -Program '$original_dir\\mihomo.exe' -Action Allow -Profile Any\" -ForegroundColor Gray",
        "Write-Host ''"
    ],
    "uninstaller": {
        "script": [
            "$isAdmin = ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)",
            "$services = @('mihomo', 'mihomo-shawl') | Get-Service -ErrorAction SilentlyContinue",
            "if ($isAdmin) {",
            "    if ($services) {",
            "        foreach ($service in $services) {",
            "            if ($service.Status -eq 'Running') {",
            "                Write-Host \"Stopping '$($service.Name)' service...\" -ForegroundColor Yellow",
            "                Stop-Service -Name $service.Name -Force -ErrorAction SilentlyContinue | Out-Null",
            "            }",
            "            if ($service.Name -eq 'mihomo') {",
            "                Write-Host \"Uninstalling 'mihomo' service...\" -ForegroundColor Yellow",
            "                sc.exe delete mihomo | Out-Null",
            "            }",
            "        }",
            "    }",
            "    Write-Host 'Stopping any remaining Mihomo processes...' -ForegroundColor Yellow",
            "    Stop-Process -Name 'mihomo','mihomo-service' -Force -ErrorAction SilentlyContinue | Out-Null",
            "    Remove-NetFirewallRule -DisplayName 'Mihomo-In' -ErrorAction SilentlyContinue | Out-Null",
            "    Remove-NetFirewallRule -DisplayName 'Mihomo-Out' -ErrorAction SilentlyContinue | Out-Null",
            "} else {",
            "    Write-Host 'Not running as Administrator. Requesting elevation via UAC to stop/uninstall service, terminate processes, and remove firewall rules...' -ForegroundColor Yellow",
            "    $elevatedCmds = @()",
            "    if ($services) {",
            "        foreach ($service in $services) {",
            "            if ($service.Status -eq 'Running') {",
            "                $elevatedCmds += \"Stop-Service -Name '$($service.Name)' -Force -ErrorAction SilentlyContinue\"",
            "            }",
            "            if ($service.Name -eq 'mihomo') {",
            "                $elevatedCmds += \"sc.exe delete 'mihomo'\"",
            "            }",
            "        }",
            "    }",
            "    $elevatedCmds += \"Stop-Process -Name 'mihomo','mihomo-service' -Force -ErrorAction SilentlyContinue\"",
            "    $elevatedCmds += \"Remove-NetFirewallRule -DisplayName 'Mihomo-In','Mihomo-Out' -ErrorAction SilentlyContinue\"",
            "    $cmdString = $elevatedCmds -join '; '",
            "    try {",
            "        Start-Process powershell -ArgumentList '-NoProfile', '-WindowStyle', 'Hidden', '-Command', $cmdString -Verb RunAs -Wait -ErrorAction Stop",
            "    } catch {",
            "        Write-Warning 'UAC elevation denied. Failed to stop/uninstall service, terminate processes, and remove firewall rules.'",
            "    }",
            "}"
        ]
    },
    "persist": [
        "config.yaml",
        "ui",
        "proxies",
        "rules",
        "cache.db"
    ],
    "notes": "config.yaml should be placed in the root folder, WebUI should be placed in the 'ui' folder, and proxy providers and rule providers should be placed in the 'proxies' and 'rules' folders respectively.",
    "bin": [
        "mihomo.exe",
        [
            "mihomo.exe",
            "clash"
        ]
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/MetaCubeX/mihomo/releases/download/v$version/mihomo-windows-amd64-v$version.zip"
            },
            "32bit": {
                "url": "https://github.com/MetaCubeX/mihomo/releases/download/v$version/mihomo-windows-386-v$version.zip"
            },
            "arm64": {
                "url": "https://github.com/MetaCubeX/mihomo/releases/download/v$version/mihomo-windows-arm64-v$version.zip"
            }
        }
    }
}
