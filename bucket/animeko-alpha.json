{
    "version": "6.0.0-alpha01",
    "description": "One-stop online barrage drama tracking platform",
    "homepage": "https://github.com/open-ani/ani",
    "license": "GPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://github.com/open-ani/ani/releases/download/v6.0.0-alpha01/ani-6.0.0-alpha01-windows-x86_64.zip",
            "hash": "f7bd1318c9d4a2908d027a6f9cf53fdaff36a7898262ef40783e7810ddf46302",
            "extract_dir": "Ani"
        }
    },
    "bin": "Ani.exe",
    "shortcuts": [
        [
            "Ani.exe",
            "Ani"
        ]
    ],
    "post_install": [
        "& \"$(Find-BucketDirectory -Root -Name (coalesce $bucket 'muggle'))/scripts/DoradoHelper.ps1\" -Action Mount -PersistDir \"$persist_dir\" -Target \"$env:APPDATA/Him188\"",
        "& \"$(Find-BucketDirectory -Root -Name (coalesce $bucket 'muggle'))/scripts/DoradoHelper.ps1\" -Action Mount -Source \"$persist_dir/cache\" -Target \"$env:LOCALAPPDATA/Him188\""
    ],
    "pre_uninstall": [
        "& \"$(Find-BucketDirectory -Root -Name (coalesce $bucket 'muggle'))/scripts/DoradoHelper.ps1\" -Action Dismount -Target \"$env:APPDATA/Him188\"",
        "& \"$(Find-BucketDirectory -Root -Name (coalesce $bucket 'muggle'))/scripts/DoradoHelper.ps1\" -Action Dismount -Target \"$env:LOCALAPPDATA/Him188\""
    ],
    "checkver": {
        "url": "https://api.github.com/repos/open-ani/ani/releases",
        "jsonpath": "$..tag_name",
        "regex": "v([-\\d.\\w]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/open-ani/ani/releases/download/v$version/ani-$version-windows-x86_64.zip"
            }
        }
    }
}
