    ],
    "suggest": {
        "Microsoft Visual C++ Runtime 2022": "extras/vcredist2022"
    },
    "architecture": {
        "64bit": {
            "url": "https://nightly.eden-emu.dev/v1783682475.a27d35463e/Eden-Windows-a27d35463e-amd64-clang-pgo.zip",
            "hash": "ab0ba22df253d1618dae06eccab2c40bc20a64e72e0a60d63b3771f09a05b81a"
        },
        "arm64": {
            "url": "https://nightly.eden-emu.dev/v1783682475.a27d35463e/Eden-Windows-a27d35463e-arm64-clang-pgo.zip",
            "hash": "64864ed4d3d7f63d6e4b3771db456b3e2bdc1e16557869cc18b47c26fc6ac1b6"
        }
    },
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\")) {",
        "   New-item \"$persist_dir\" -ItemType Directory | Out-Null",
        "   New-item \"$persist_dir\\user\" -ItemType Directory | Out-Null",
        "   if (Test-Path \"$env:APPDATA\\eden\") {",
        "       Write-host \"Migrating AppData...\" -ForegroundColor yellow",
        "       Copy-Item -Path \"$env:APPDATA\\eden\\*\" -Destination \"$persist_dir\\user\" -Recurse",
        "       Remove-Item -Path \"$env:APPDATA\\eden\" -Recurse",
        "   }",
        "}"
    ],
    "bin": [
        [
            "eden.exe",
            "eden-nightly"
        ]
    ],
    "shortcuts": [
        [
            "eden.exe",
            "Eden (nightly)"
        ]
    ],
    "persist": "user",
    "checkver": {
        "url": "https://git.eden-emu.dev/api/v1/repos/eden-ci/nightly/releases/latest",
        "jsonpath": "$.tag_name",
        "regex": "v([\\d]+\\.(?<commit>[a-f\\d]+))"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://nightly.eden-emu.dev/v$version/Eden-Windows-$matchCommit-amd64-clang-pgo.zip"
            },
            "arm64": {
                "url": "https://nightly.eden-emu.dev/v$version/Eden-Windows-$matchCommit-arm64-clang-pgo.zip"
            }
        }
    }
}
