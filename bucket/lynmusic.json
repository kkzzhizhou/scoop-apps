        "url": "https://github.com/wesley666/LynMusic#License-1-ov-file"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/wesley666/LynMusic/releases/download/v1.0.9/LynMusic-1.0.9.msi",
            "hash": "3df5520a777f8fb95ed5b6812bc9603ac6d99d4371567c0d85621ec117b77651"
        }
    },
    "extract_dir": "LynMusic",
    "installer": {
        "script": [
            "# handle runtime cache",
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\appdata\" -Target \"$env:USERPROFILE\\.lynmusic\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "uninstaller": {
        "script": [
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Dismount-ExternalRuntimeData -Target \"$env:USERPROFILE\\.lynmusic\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "bin": "LynMusic.exe",
    "shortcuts": [
        [
            "LynMusic.exe",
            "LynMusic"
        ]
    ],
    "checkver": {
        "github": "https://api.github.com/repos/wesley666/LynMusic/releases",
        "jp": "$[0].assets[*].browser_download_url",
        "regex": "/releases/download/v([\\d.]+)/LynMusic-([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/wesley666/LynMusic/releases/download/v$version/LynMusic-$version.msi"
            }
        }
    }
}
