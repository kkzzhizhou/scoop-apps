            "Clash Party.exe",
            "Clash Party"
        ]
    ],
    "checkver": {
        "github": "https://api.github.com/repos/mihomo-party-org/clash-party/releases",
        "jp": "$[0].tag_name",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
