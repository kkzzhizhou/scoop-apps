{
    "version": "0.6.1",
    "description": "第三方网易云播放器 Hydrogen Music 复活版",
    "homepage": "https://github.com/ldx123000/Hydrogen-Music",
    "license": {
        "identifier": "MIT license",
        "url": "https://github.com/ldx123000/Hydrogen-Music#MIT-1-ov-file"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/ldx123000/Hydrogen-Music/releases/download/v0.6.1/Hydrogen.Music.Setup.0.6.1.exe#/dl.7z",
            "hash": "sha512:3ba2a4d97196b556dde2d0716c5c8c571e656f7eca5c63d6275348e2ff0f0412a6cffd1a88910772b06ced12b1a6fa37e107cf99fb84a438be3e7b034d8077b5",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\" -Force -Recurse"
            ]
        }
    },
    "installer": {
        "script": [
            "# handle runtime cache",
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\appdata\" -Target \"$env:APPDATA\\hydrogenmusic\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "uninstaller": {
        "script": [
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\hydrogenmusic\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "shortcuts": [
        [
            "Hydrogen Music.exe",
            "Hydrogen Music"
        ]
    ],
    "checkver": {
        "github": "https://api.github.com/repos/ldx123000/Hydrogen-Music/releases",
        "jp": "$[0].assets[*].browser_download_url",
        "regex": "/releases/download/v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ldx123000/Hydrogen-Music/releases/download/v$version/Hydrogen.Music.Setup.$version.exe#/dl.7z"
            }
        },
        "hash": {
            "url": "$baseurl/latest.yml",
            "regex": "sha512:\\s+$base64"
        }
    }
}
