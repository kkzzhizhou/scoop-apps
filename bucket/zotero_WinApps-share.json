    "architecture": {
        "64bit": {
            "url": "https://download.zotero.org/client/release/9.0.6/Zotero-9.0.6_win-x64.zip",
            "hash": "5101200aa900558d61abd6d0b4d504c8fb5b0e9edc9ee40f6d77bc21ec2eac9e"
        },
        "32bit": {
            "url": "https://download.zotero.org/client/release/9.0.6/Zotero-9.0.6_win32.zip",
            "hash": "6024f96786bc1a5d97acf005382d2353497cc912b079aa2ed5af0c5a0666649d"
        },
        "arm64": {
            "url": "https://download.zotero.org/client/release/9.0.6/Zotero-9.0.6_win-arm64.zip",
            "hash": "ab2cfd6ac70333040e83868da858ecc44a30e903bd6c50468ca02bb55b07d97b"
        }
    },
    "pre_install": [
        "$subdir = Get-ChildItem -Path $dir -Directory | Select-Object -First 1",
        "if ($subdir) { Move-Item -Path \"$($subdir.FullName)\\*\" -Destination $dir -Force }"
    ],
    "bin": "zotero.exe",
    "shortcuts": [
        [
            "zotero.exe",
            "Zotero"
        ]
    ],
    "checkver": {
        "script": [
            "try { $detail = Invoke-WebRequest 'https://www.zotero.org/download/client/dl?channel=release&platform=win-x64' -MaximumRedirection 0 -ErrorAction Ignore } catch { $_.Exception.Response }",
            "return $detail.Headers.Location"
        ],
        "regex": "Zotero-([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.zotero.org/client/release/$version/Zotero-$version_win-x64.zip"
            },
            "32bit": {
                "url": "https://download.zotero.org/client/release/$version/Zotero-$version_win32.zip"
            },
            "arm64": {
                "url": "https://download.zotero.org/client/release/$version/Zotero-$version_win-arm64.zip"
            }
        }
    }
}
