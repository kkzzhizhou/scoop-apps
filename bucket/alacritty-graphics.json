    },
    "url": "https://github.com/ayosec/alacritty/releases/download/v0.17.0-graphics/Alacritty-v0.17.0-graphics-portable.exe#/alacritty.exe",
    "hash": "4f07aec524d3310a95900272749ecf310c32b375c65e4b0a8e707fd75f6caca0",
    "bin": [
        [
            "alacritty.exe",
            "alacritty",
            "--config-file=$dir/config.toml"
        ]
    ],
    "shortcuts": [
        [
            "alacritty.exe",
            "Alacritty",
            "--config-file=$dir/config.toml"
        ]
    ],
    "pre_install": [
        "function create($path, $type, $content) {",
        "   if (-not (Test-Path \"$path\")) {",
        "       New-Item \"$path\" -ItemType $type -Value $content | Out-Null",
        "       Write-Output \"Creating $path...\"",
        "   }",
        "}",
        "create $dir/config.toml File"
    ],
    "persist": "config.toml",
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/ayosec/alacritty/releases/download/v$version-graphics/Alacritty-v$version-graphics-portable.exe#/alacritty.exe"
    }
}
