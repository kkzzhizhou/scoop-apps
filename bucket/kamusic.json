            "hash": "1ceef46ea44e07072a2d594126548e10c9aa59f4478575062c720059e257b6b2",
            "pre_install": [
                "Copy-Item \"$dir\\lib\\app\\*\" \"$dir\" -Recurse -Force -ErrorAction 'SilentlyContinue'",
                "Remove-Item -LiteralPath \"$dir\\[Content_Types].xml\" -Force -ErrorAction 'SilentlyContinue'",
                "Remove-Item \"$dir\\_rels\", \"$dir\\lib\", \"$dir\\*.nuspec\", \"$dir\\*.ico\" -Recurse -Force -ErrorAction 'SilentlyContinue'"
            ]
        }
    },
    "installer": {
        "script": [
            "# handle runtime cache",
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\cachedata\" -Target \"$env:LOCALAPPDATA\\kugou\"",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\appdata\" -Target \"$env:APPDATA\\kugou\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "uninstaller": {
        "script": [
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Dismount-ExternalRuntimeData -Target \"$env:LOCALAPPDATA\\kugou\"",
            "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\kugou\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "bin": "KugouAvaloniaPlayer.exe",
    "shortcuts": [
        [
            "KugouAvaloniaPlayer.exe",
            "KugouAvaloniaPlayer"
        ]
    ],
