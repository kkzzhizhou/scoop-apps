{
    "version": "master",
    "description": "PwnXSS: Vulnerability (XSS) scanner exploit.",
    "homepage": "https://github.com/pwn0sec/PwnXSS",
    "license": "MIT",
    "suggest": {
        "python": "uv"
    },
    "url": "https://github.com/pwn0sec/PwnXSS/archive/refs/heads/master.zip",
    "extract_dir": "pwnxss-master",
    "pre_install": [
        "Set-Content \"$dir\\pwnxss.bat\" '@pushd %~dp0",
        "@uv run python pwnxss.py %*",
        "@popd' -Encoding Ascii"
    ],
    "post_install": [
        "uv venv \"$dir\\.venv\"",
        "uv pip install -r $dir\\requirements.txt --python \"$dir\\.venv\\Scripts\\python.exe\""
    ],
    "bin": "pwnxss.bat",
    "notes": [
        "【工具类型】: Python工具",
        "【主要功能】: PwnXSS: Vulnerability (XSS) scanner exploit.",
        "【适用场景】: 根据描述推断的适用场景",
        "【技术特点】: 基于Python开发，需Python环境"
    ]
}
