            "shortcuts": [
                [
                    "PPSSPPWindows64.exe",
                    "PPSSPP"
                ]
            ]
        },
        "32bit": {
            "url": "https://ppsspp.org/files/1_20_1/ppsspp_win.zip",
            "hash": "ad872843d5ca12cb74e212a1ad8d0d66489b43cdbd6ed3f7d00855350aacf4f5",
            "shortcuts": [
                [
                    "PPSSPPWindows.exe",
                    "Sony PlayStation Portable [psp][ppsspp]"
                ]
            ]
        },
        "arm64": {
            "url": "https://ppsspp.org/files/1_20_1/PPSSPPWindowsARM64.zip",
            "hash": "579a1a879836b2b5842ecd75491c2fb1193db965a6270427c86e1c40a11f9a79",
            "shortcuts": [
                [
                    "PPSSPPWindowsARM64.exe",
                    "PPSSPP"
                ]
            ]
        }
    },
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\")) {",
        "   New-item \"$persist_dir\" -ItemType Directory | Out-Null",
        "   New-item \"$persist_dir\\memstick\" -ItemType Directory | Out-Null",
        "}"
    ],
    "persist": [
        "assets",
        "demos",
        "memstick"
    ],
    "checkver": {
        "github": "https://github.com/hrydgard/ppsspp",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://ppsspp.org/files/$underscoreVersion/ppsspp_win.zip"
            },
            "32bit": {
                "url": "https://ppsspp.org/files/$underscoreVersion/ppsspp_win.zip"
            },
            "arm64": {
                "url": "https://ppsspp.org/files/$underscoreVersion/PPSSPPWindowsARM64.zip"
            }
        }
    }
}
