{
    "description": "Official General-Availability Release of OpenJDK",
    "homepage": "https://jdk.java.net/",
    "version": "24.0.2-12",
    "license": "GPL-2.0-only WITH Classpath-exception-2.0",
    "url": "https://download.java.net/java/GA/jdk24.0.2/fdc5d0102fe0414db21410ad5834341f/12/GPL/openjdk-24.0.2_windows-x64_bin.zip",
    "hash": "683aad49e0a146c725d922efeaffe877deb108e58ee270ac5529467cf9bdd7ec",
    "extract_dir": "jdk-24.0.2",
    "pre_install": [
        "Set-Content \"$dir\\openjdk.bat\" '@pushd %~dp0",
        "@set JAVA_HOME=%~dp0",
        "@set path=%JAVA_HOME%\\bin;%path%;",
        "@popd' -Encoding Ascii"
    ],
    "bin": "openjdk.bat",
    "checkver": {
        "url": "https://jdk.java.net/",
        "regex": "jdk([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://download.java.net/java/GA/jdk$version/fdc5d0102fe0414db21410ad5834341f/12/GPL/openjdk-$version_windows-x64_bin.zip",
        "hash": {
            "url": "$url.sha256"
        },
        "extract_dir": "jdk-$version"
    },
    "notes": [
        "【工具类型】: 开发工具",
        "【主要功能】: OpenJDK官方正式版本，Java开发环境",
        "【适用场景】: Java开发、运行Java程序、开发调试",
        "【技术特点】: 开源免费，支持64位，自动配置JAVA_HOME"
    ]
}
