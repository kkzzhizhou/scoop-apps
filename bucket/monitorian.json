{
    "homepage": "https://github.com/emoacht/monitorian",
    "description": "A Windows desktop tool to adjust the brightness of multiple monitors with ease",
    "license": "MIT",
    "version": "4.15.2",
    "architecture": {
        "64bit": {
            "url": "https://github.com/emoacht/Monitorian/releases/download/4.15.2-Installer/MonitorianInstaller4152.zip",
            "hash": "1fab2d7ae397bdbcbe85cec5aac27c03ee52b1048facdbe630af33db1781e7b2"
        }
    },
    "pre_install": [
        "Expand-MsiArchive \"$dir\\Monitorian.Installer.msi\"  \"$dir\\temp\"",
        "Move-Item \"$dir\\temp\\PFiles\\Monitorian\\*\" -Destination \"$dir\"",
        "Remove-Item \"$dir\\Monitorian.Installer.msi\""
    ],
    "shortcuts": [
        [
            "Monitorian.exe",
            "Monitorian"
        ]
    ],
    "notes": ".NET Framework 4.8 is required.",
    "checkver": {
        "url": "https://github.com/emoacht/Monitorian/releases/latest",
        "regex": "/releases/tag/([\\d.]+)-Installer"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/emoacht/Monitorian/releases/download/$version-Installer/MonitorianInstaller$cleanVersion.zip"
            }
        }
    }
}
