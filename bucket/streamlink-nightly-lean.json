{
    "version": "8.4.0+65.gf7be251-1-py314",
    "description": "A command-line utility that pipes video streams from various services into a video player.",
    "homepage": "https://streamlink.github.io/",
    "license": "BSD-2-Clause",
    "notes": "You will find your config file here: '$dir\\config'. To customise it, read the docs here: https://streamlink.github.io/cli/config.html#syntax",
    "suggest": {
        "FFmpeg": [
            "ffmpeg",
            "ffmpeg-nightly"
        ],
        "mpv": [
            "extras/mpv",
            "extras/mpv-git"
        ]
    },
    "architecture": {
        "64bit": {
            "url": "https://nightly.link/streamlink/windows-builds/workflows/main/master/streamlink-8.4.0+65.gf7be251-1-py314-x86_64.zip",
            "hash": "f012b965b6b474890a41f181beb9d9a8a7138f8e93f0193fc104bb4d3e354383"
        }
    },
    "pre_install": [
        "$python = try { $null = (py.exe -0p | Select-Object -First 1) -cmatch '\\S+\\Z'; $Matches[0] } catch {}",
        "$null = $version -cmatch '-py(\\d)(\\d{1,2})\\Z'",
        "$paths = 'bin', 'pkgs'",
        "if ($python -and ($ver = try { [Version]((py.exe -V) -Replace '[^\\d.]') } catch {}) -lt [Version]\"$($Matches[1]).$([byte]$Matches[2] + 1).0\" -and $ver -ge [Version]\"$($Matches[1]).$($Matches[2]).0\") {",
        "    $null = New-Item -ItemType Junction -Path \"$dir/Python\" -Target (Split-Path $python)",
        "}",
        "else { $paths += 'Python' }",
        "$paths | ForEach-Object { Move-Item \"$dir/streamlink-$version-*/$_\" \"$dir\" }",
        "Remove-Item -Recurse \"$dir/streamlink-$version-*\"",
        "if (Test-Path \"$persist_dir/config\") { return }",
        "if (Test-Path \"$env:APPDATA/streamlink/config\") {",
        "    info 'Copying existing ''config'' from ''%APPDATA%\\streamlink\\config'''",
        "    return $null = Copy-Item \"$env:APPDATA/streamlink/config\" \"$dir/config\"",
        "}",
        "$null = New-Item \"$dir/config\""
    ],
    "bin": [
        [
            "bin/streamlink.exe",
            "streamlink",
            "--config \"$dir\\config\""
        ],
        "bin/streamlinkw.exe"
    ],
    "persist": "config",
    "checkver": {
        "script": [
            "try {",
            "    $id = (Invoke-RestMethod 'https://api.github.com/repositories/472790314/actions/workflows/main.yml/runs?branch=master&status=success&per_page=1' -Headers $(if ($auth = Get-GitHubToken) { @{authorization=\"Bearer $auth\"} })).workflow_runs[0].id",
            "    (Invoke-RestMethod \"https://api.github.com/repositories/472790314/actions/runs/$id/artifacts?per_page=1\" -Headers $(if ($auth = Get-GitHubToken) { @{authorization=\"Bearer $auth\"} })).artifacts[0].name",
            "}",
            "catch {",
            "    ''",
            "}"
        ],
        "regex": "\\Astreamlink-([^h-z]+-py\\d+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://nightly.link/streamlink/windows-builds/workflows/main/master/streamlink-$version-x86_64.zip"
            }
        }
    }
}
