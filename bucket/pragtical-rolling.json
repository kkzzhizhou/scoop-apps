{
    "version": "20260611-690-9b68176",
    "description": "The practical and pragmatic code editor (rolling release).",
    "homepage": "https://pragtical.dev/",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/pragtical/pragtical/releases/download/rolling/pragtical-rolling-windows-x86_64.zip",
            "hash": "c22e490e85714bd1422e43a0c51ed577a539cb73aee5b2d6e589b29c34d3ad4d"
        }
    },
    "extract_dir": "pragtical",
    "bin": "pragtical.exe",
    "shortcuts": [
        [
            "pragtical.exe",
            "Pragtical"
        ]
    ],
    "persist": "user",
    "checkver": {
        "github": "https://api.github.com/repos/pragtical/pragtical/actions/workflows/rolling.yml/runs?branch=master&status=success",
        "script": [
            "$content = ConvertFrom-Json $page",
            "if ((-not $content) -or (-not $content.workflow_runs) -or ($content.workflow_runs.Count -eq 0)) {",
            "    return $null",
            "}",
            "$release = $content.workflow_runs[0]",
            "$output = @{'result' = \"$($release.run_number) $($release.created_at | Get-Date -Format 'yyyy-MM-dd') $($release.head_sha)\"} | ConvertTo-Json -Compress",
            "Write-Output $output"
        ],
        "jsonpath": "$.result",
        "regex": "^(?<runId>\\d+) (?<year>\\d{4})-(?<month>\\d{2})-(?<day>\\d{2}) (?<hash>.{7})(?<rest>.*)$",
        "replace": "${year}${month}${day}-${runId}-${hash}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/pragtical/pragtical/releases/download/rolling/pragtical-rolling-windows-x86_64.zip"
            }
        }
    }
}
