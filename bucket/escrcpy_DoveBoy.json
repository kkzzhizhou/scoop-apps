    "shortcuts": [
        [
            "Escrcpy.exe",
            "Escrcpy"
        ]
    ],
    "checkver": {
        "github": "https://api.github.com/repos/viarotel-org/escrcpy/releases",
        "jp": "$[0].tag_name",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
