            "hash": "aa1768a9fc120e8b2020f882a1283adb72a06edf1cece58954c543d839f7b21f",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$PLUGINSDIR\", \"$dir\\`$R0\" -Force -Recurse"
            ]
        },
        "arm64": {
            "url": "https://github.com/viarotel-org/escrcpy/releases/download/v2.10.2/Escrcpy-2.10.2-win-setup-arm64.exe#/dl.7z",
            "hash": "202cc4e98cd1687b3d17e73cb727f419a53a79b162c2df4ec0d2754cde687d19",
