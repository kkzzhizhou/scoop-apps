{
    "version": "0.130.0",
    "description": "OpenAI Codex for Rust - AI-powered code completion and generation tool",
    "homepage": "https://github.com/openai/codex",
    "license": "Apache-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/openai/codex/releases/download/rust-v0.130.0/codex-npm-win32-x64-0.130.0.tgz",
            "hash": "2f6309d4cf55d5a49847a018c4dcd4354995324ed9d240a9d4f57fb3254f2fec",
            "installer": {
                "script": [
                    "$vendorRoot = Join-Path $dir 'package\\vendor\\x86_64-pc-windows-msvc'",
                    "$copyMap = @{",
                    "    'codex\\codex.exe' = 'codex.exe'",
                    "    'codex\\codex-command-runner.exe' = 'codex-command-runner.exe'",
                    "    'codex\\codex-windows-sandbox-setup.exe' = 'codex-windows-sandbox-setup.exe'",
                    "    'path\\rg.exe' = 'rg.exe'",
                    "}",
                    "foreach ($relativeSource in $copyMap.Keys) {",
                    "    $sourcePath = Join-Path $vendorRoot $relativeSource",
                    "    $destinationPath = Join-Path $dir $copyMap[$relativeSource]",
                    "    Move-Item -Force $sourcePath $destinationPath",
                    "}",
                    "Remove-Item (Join-Path $dir 'package') -Recurse -Force"
                ]
            }
        },
        "arm64": {
            "url": "https://github.com/openai/codex/releases/download/rust-v0.130.0/codex-npm-win32-arm64-0.130.0.tgz",
            "hash": "69329907688d5cf6786efff9a584a80f0649969deed6ca351770d0b8e83a1e53",
            "installer": {
                "script": [
                    "$vendorRoot = Join-Path $dir 'package\\vendor\\aarch64-pc-windows-msvc'",
                    "$copyMap = @{",
                    "    'codex\\codex.exe' = 'codex.exe'",
                    "    'codex\\codex-command-runner.exe' = 'codex-command-runner.exe'",
                    "    'codex\\codex-windows-sandbox-setup.exe' = 'codex-windows-sandbox-setup.exe'",
                    "    'path\\rg.exe' = 'rg.exe'",
                    "}",
                    "foreach ($relativeSource in $copyMap.Keys) {",
                    "    $sourcePath = Join-Path $vendorRoot $relativeSource",
                    "    $destinationPath = Join-Path $dir $copyMap[$relativeSource]",
                    "    Move-Item -Force $sourcePath $destinationPath",
                    "}",
                    "Remove-Item (Join-Path $dir 'package') -Recurse -Force"
                ]
            }
        }
    },
    "bin": [
        [
            "codex.exe",
            "codex"
        ],
        "codex-command-runner.exe",
        "codex-windows-sandbox-setup.exe"
    ],
    "checkver": {
        "github": "https://github.com/openai/codex",
        "regex": "rust-v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/openai/codex/releases/download/rust-v$version/codex-npm-win32-x64-$version.tgz"
            },
            "arm64": {
