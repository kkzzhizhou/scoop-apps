            "hash": "d6f9e53de1c45a12623e9f96aeda8d24268b1df481e318c9c5c5ab9dcd14f56c",
            "pre_install": "Remove-Item \"$dir\\`$*\" -Force -Recurse"
        },
        "arm64": {
            "url": "https://github.com/WCY-dt/MrRSS/releases/download/v1.3.25/MrRSS-1.3.25-windows-arm64-installer.exe#/dl.7z",
            "hash": "ff2535da629c7bcbf1b013d1c7e36cd00cb4c2d9e0ff733fce33b89082a3a882",
            "pre_install": "Remove-Item \"$dir\\`$*\" -Force -Recurse"
        }
    },
    "installer": {
        "script": [
            "# handle runtime cache",
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\appdata\" -Target \"$env:APPDATA\\MrRSS.exe\"",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\userdata\" -Target \"$env:APPDATA\\MrRSS\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "uninstaller": {
        "script": [
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\MrRSS.exe\"",
            "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\MrRSS\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
    "bin": "MrRSS.exe",
    "shortcuts": [
        [
            "MrRSS.exe",
            "MrRSS"
        ]
    ],
    "checkver": {
        "github": "https://api.github.com/repos/WCY-dt/MrRSS/releases",
        "jp": "$[0].assets[*].browser_download_url",
        "regex": "/releases/download/v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/WCY-dt/MrRSS/releases/download/v$version/MrRSS-$version-windows-amd64-installer.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/WCY-dt/MrRSS/releases/download/v$version/MrRSS-$version-windows-arm64-installer.exe#/dl.7z"
            }
        }
    }
