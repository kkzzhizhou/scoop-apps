{
	"version": "2.11.0",
	"description": "《明日方舟：终末地》游戏小助手 (Arknights: Endfield game assistant)",
	"homepage": "https://github.com/MaaEnd/MaaEnd",
	"license": {
		"identifier": "AGPL-3.0",
		"url": "https://github.com/MaaEnd/MaaEnd/blob/main/LICENSE"
	},
	"architecture": {
		"64bit": {
			"url": "https://github.com/MaaEnd/MaaEnd/releases/download/v2.11.0/MaaEnd-win-x86_64-v2.11.0.zip",
			"hash": "aa2f3c19864efb0ac0dbade7523765b7ba33cad4073bce8e14a177c31384fd40"
		},
		"arm64": {
			"url": "https://github.com/MaaEnd/MaaEnd/releases/download/v2.11.0/MaaEnd-win-aarch64-v2.11.0.zip",
			"hash": "6b00c5f06bd98a9922776aed9351c578fd4fc03f604f0e655f9103a152d63cb8"
		}
	},
	"checkver": {
		"script": [
			"$rel_info = Invoke-RestMethod -Uri 'https://api.github.com/repos/MaaEnd/MaaEnd/releases/latest'",
			"$latest_x64 = $rel_info.assets | Where-Object {$_.name -match 'win-x86_64'} | Select-Object -first 1",
			"$latest_arm64 = $rel_info.assets | Where-Object {$_.name -match 'win-aarch64'} | Select-Object -first 1",
			"$version = $rel_info.tag_name -replace '^v', ''",
			"Write-Output \"$version $($latest_x64.digest.Replace('sha256:','')) $($latest_arm64.digest.Replace('sha256:',''))\""
		],
		"regex": "(?<version>[\\d.]+)\\s(?<x64hash>[^\\s]+)?\\s(?<armhash>[^\\s]+)?"
	},
	"autoupdate": {
		"architecture": {
			"64bit": {
				"url": "https://github.com/MaaEnd/MaaEnd/releases/download/v$version/MaaEnd-win-x86_64-v$version.zip",
				"hash": "$matchX64hash"
			},
			"arm64": {
				"url": "https://github.com/MaaEnd/MaaEnd/releases/download/v$version/MaaEnd-win-aarch64-v$version.zip",
				"hash": "$matchArmhash"
			}
		}
	},
	"persist": ["cache", "config", "debug"],
	"shortcuts": [["MaaEnd.exe", "MaaEnd"]]
}
