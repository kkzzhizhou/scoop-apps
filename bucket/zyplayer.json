{
    "version": "3.4.7",
    "description": "跨平台桌面端视频资源播放器,免费高颜值.",
    "homepage": "https://github.com/Hiram-Wong/zyfun",
    "license": {
        "identifier": "AGPL-3.0 license",
        "url": "https://github.com/Hiram-Wong/zyfun#AGPL-3.0-1-ov-file"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Hiram-Wong/zyfun/releases/download/v3.4.7/zyfun-win-3.4.7-x64-setup.exe#/dl.7z",
            "hash": "sha512:63b5a10cea30cde3ebdb8c744a0a869dae0a734626759f1a087b5d43ae8ce1156b7d80a7e2406eaefea7d580a51441d202321fc933287809be42d9ff16f16e42",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\" -Recurse"
            ]
        },
        "arm64": {
            "url": "https://github.com/Hiram-Wong/zyfun/releases/download/v3.4.7/zyfun-win-3.4.7-arm64-setup.exe#/dl.7z",
            "hash": "sha512:63b5a10cea30cde3ebdb8c744a0a869dae0a734626759f1a087b5d43ae8ce1156b7d80a7e2406eaefea7d580a51441d202321fc933287809be42d9ff16f16e42",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-arm64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\" -Recurse"
            ]
        }
    },
    "installer": {
        "script": [
            "ensure \"$persist_dir\" | Out-Null",
            "New-Item \"$env:APPDATA\\zyplayer\" -ItemType Junction -Target \"$persist_dir\" | Out-Null"
        ]
    },
    "uninstaller": {
        "script": "Remove-Item \"$env:APPDATA\\zyplayer\" -Recurse -Force -ErrorAction 'SilentlyContinue'"
    },
    "bin": "zyfun.exe",
    "shortcuts": [
        [
            "zyfun.exe",
            "ZYFun"
        ]
    ],
    "checkver": {
        "github": "https://api.github.com/repos/Hiram-Wong/ZyPlayer/releases",
        "jp": "$[0].tag_name",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Hiram-Wong/zyfun/releases/download/v$version/zyfun-win-$version-x64-setup.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/Hiram-Wong/zyfun/releases/download/v$version/zyfun-win-$version-arm64-setup.exe#/dl.7z"
            }
        },
        "hash": {
            "url": "$baseurl/latest.yml",
            "regex": "sha512:\\s+$base64"
        }
    }
}
